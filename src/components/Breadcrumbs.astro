---
import { routeNames } from '../data/navigation'

const pathname = Astro.url.pathname
const segments = pathname.split('/').filter(Boolean)

// Don't show breadcrumbs on homepage
if (segments.length === 0) return

const pages = segments.map((seg, i) => ({
  name: routeNames[seg] || seg.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
  href: '/' + segments.slice(0, i + 1).join('/'),
  current: i === segments.length - 1,
}))
---

<nav aria-label="Breadcrumb" class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-white/5">
  <div class="mx-auto w-full max-w-7xl px-6 py-3 lg:px-8">
    <ol role="list" class="flex items-center space-x-4 text-sm">
      <li>
        <a href="/" class="text-gray-400 dark:text-gray-500 hover:text-gray-500 dark:hover:text-gray-300">
          <svg class="size-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 11h-1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-3a1 1 0 00-1-1H9a1 1 0 00-1 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-6H3a1 1 0 01-.707-1.707l7-7z" clip-rule="evenodd" />
          </svg>
          <span class="sr-only">Home</span>
        </a>
      </li>
      {pages.map((page) => (
        <li>
          <div class="flex items-center">
            <svg class="size-5 shrink-0 text-gray-300 dark:text-gray-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
            </svg>
            <a
              href={page.href}
              aria-current={page.current ? 'page' : undefined}
              class:list={[
                'ml-4 font-medium',
                page.current
                  ? 'text-gray-700 dark:text-gray-300'
                  : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200',
              ]}
            >
              {page.name}
            </a>
          </div>
        </li>
      ))}
    </ol>
  </div>
</nav>
