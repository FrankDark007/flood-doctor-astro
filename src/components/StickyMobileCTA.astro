---
import { cityData } from '../data/cities'
import { toTelHref } from '../utils/phone'

const phoneHref = toTelHref(cityData.phone)
---

<aside
  class="fixed inset-x-0 bottom-0 z-40 border-t border-white/10 bg-[#06172e]/96 px-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] pt-3 shadow-[0_-18px_45px_rgba(6,23,46,0.38)] backdrop-blur-xl lg:hidden"
  aria-label="Emergency mobile actions"
>
  <div class="mx-auto grid max-w-md grid-cols-2 gap-2">
    <a
      href={phoneHref}
      class="fd-btn fd-btn-primary min-h-[3.25rem] w-full px-2 text-xs sm:text-sm"
      aria-label={`Call Flood Doctor at ${cityData.phone}`}
    >
      <span>Call Now</span>
      <span class="hidden font-black min-[390px]:inline">{cityData.phone}</span>
    </a>
    <a
      href="/request/"
      aria-label="Request emergency service"
      class="fd-btn fd-btn-secondary min-h-[3.25rem] w-full px-2 text-xs sm:text-sm"
    >
      Request Service
    </a>
  </div>
</aside>

<style is:global>
  @media (max-width: 1023px) {
    body {
      padding-bottom: calc(5.25rem + env(safe-area-inset-bottom));
    }
  }
</style>
