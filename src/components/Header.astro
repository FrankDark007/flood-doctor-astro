---
import BrandLogo from './BrandLogo.astro'
import MobileMenu from './islands/MobileMenu.tsx'
import { cityData } from '../data/cities'
import { mainNavigation, secondaryNavigation } from '../data/navigation'
import { toTelHref } from '../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)

const currentPath = Astro.url.pathname
---

<header class="bg-white border-b border-slate-200">
  <nav aria-label="Global" class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8">
    <!-- Logo -->
    <div class="flex lg:flex-1">
      <BrandLogo cityName={cityData.name} showCity variant="compact" size="md" class="-m-1.5 p-1.5" />
    </div>

    <!-- Mobile menu button (React island) -->
    <div class="flex lg:hidden">
      <MobileMenu
        client:idle
        navigation={mainNavigation}
        secondaryNav={secondaryNavigation}
        phone={cityData.phone}
        cityName={cityData.name}
      />
    </div>

    <!-- Desktop nav -->
    <div class="hidden lg:flex lg:gap-x-8">
      {mainNavigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm/6 font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-600',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'text-blue-700'
              : 'text-slate-900 hover:text-blue-700',
          ]}
        >
          {item.name}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:gap-x-4">
      <a
        href={cityPhoneHref}
        class="text-sm/6 font-semibold text-slate-900 hover:text-blue-700 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-600"
      >
        {cityData.phone}
      </a>
      <a
        href="/request"
        class="rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-blue-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600"
      >
        Request Service
      </a>
    </div>
  </nav>
</header>
