---
import MobileMenu from './islands/MobileMenu.tsx'
import { cityData } from '../data/cities'
import { mainNavigation, secondaryNavigation } from '../data/navigation'

const currentPath = Astro.url.pathname
---

<header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-white/10">
  <nav aria-label="Global" class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8">
    <!-- Logo -->
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5 flex items-center gap-x-3">
        <span class="sr-only">Flood Doctor {cityData.name}</span>
        <img
          alt=""
          src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=500"
          class="h-8 w-auto"
        />
        <span class="hidden sm:block text-lg font-bold text-gray-900 dark:text-white">
          Flood Doctor <span class="text-indigo-600 dark:text-indigo-400">{cityData.name}</span>
        </span>
      </a>
    </div>

    <!-- Mobile menu button (React island) -->
    <div class="flex lg:hidden">
      <MobileMenu
        client:load
        navigation={mainNavigation}
        secondaryNav={secondaryNavigation}
        phone={cityData.phone}
        cityName={cityData.name}
      />
    </div>

    <!-- Desktop nav -->
    <div class="hidden lg:flex lg:gap-x-8">
      {mainNavigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm/6 font-semibold transition-colors',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'text-indigo-600 dark:text-indigo-400'
              : 'text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400',
          ]}
        >
          {item.name}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:gap-x-4">
      <a
        href={`tel:${cityData.phone.replace(/[^0-9+]/g, '')}`}
        class="text-sm/6 font-semibold text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400"
      >
        {cityData.phone}
      </a>
      <a
        href="/request"
        class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400"
      >
        Free Estimate
      </a>
    </div>
  </nav>
</header>
