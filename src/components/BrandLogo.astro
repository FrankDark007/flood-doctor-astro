---
interface Props {
  href?: string
  cityName?: string
  showCity?: boolean
  showTagline?: boolean
  variant?: 'full' | 'compact' | 'mark'
  tone?: 'light' | 'dark'
  size?: 'sm' | 'md' | 'lg'
  class?: string
}

const {
  href = '/',
  cityName,
  showCity = Boolean(cityName),
  showTagline = false,
  variant = 'full',
  tone = 'light',
  size = 'md',
  class: className = '',
} = Astro.props

const isMarkOnly = variant === 'mark'
const Element = href ? 'a' : 'span'
---

<Element
  href={href || undefined}
  class:list={['brand-logo', className]}
  data-variant={variant}
  data-tone={tone}
  data-size={size}
>
  <span class="brand-logo__mark-wrap" aria-hidden="true">
    <img
      class="brand-logo__mark"
      src="/graphics/flood-doctor-mark.svg"
      alt=""
      width="48"
      height="48"
      loading="eager"
      decoding="async"
    />
  </span>
  {!isMarkOnly && (
    <span class="brand-logo__copy">
      <span class="brand-logo__name">
        <span>Flood</span>
        <span class="brand-logo__accent">Doctor</span>
        {cityName && showCity && <span class="brand-logo__city">{cityName}</span>}
      </span>
      {showTagline && variant === 'full' && (
        <span class="brand-logo__tagline">Water damage response &amp; drying</span>
      )}
    </span>
  )}
</Element>

<style>
  .brand-logo {
    --logo-blue: var(--fd-blue-700, #0b63ce);
    --logo-navy: var(--fd-navy-950, #06172e);
    --logo-orange: var(--fd-orange-600, #d94a12);
    --logo-text: var(--fd-navy-950, #06172e);
    --logo-muted: var(--fd-slate-500, #64748b);
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    min-width: 0;
    color: var(--logo-text);
    text-decoration: none;
    vertical-align: middle;
  }

  .brand-logo[data-tone='dark'] {
    --logo-text: #ffffff;
    --logo-blue: #7dd3fc;
    --logo-muted: #cbd5e1;
    --logo-orange: #fb923c;
  }

  .brand-logo[data-size='sm'] {
    gap: 0.5rem;
  }

  .brand-logo[data-size='lg'] {
    gap: 0.75rem;
  }

  .brand-logo__mark-wrap {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    flex: 0 0 auto;
    border-radius: 0.875rem;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.98), rgb(220 238 255 / 0.88));
    box-shadow: 0 10px 24px rgb(6 23 46 / 0.18), inset 0 0 0 1px rgb(255 255 255 / 0.75);
  }

  .brand-logo[data-tone='dark'] .brand-logo__mark-wrap {
    box-shadow: 0 12px 28px rgb(0 0 0 / 0.24), inset 0 0 0 1px rgb(255 255 255 / 0.7);
  }

  .brand-logo__mark {
    display: block;
    width: 2rem;
    height: 2rem;
  }

  .brand-logo[data-size='sm'] .brand-logo__mark-wrap {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.75rem;
  }

  .brand-logo[data-size='sm'] .brand-logo__mark {
    width: 1.8rem;
    height: 1.8rem;
  }

  .brand-logo[data-size='lg'] .brand-logo__mark-wrap {
    width: 3.15rem;
    height: 3.15rem;
    border-radius: 1rem;
  }

  .brand-logo[data-size='lg'] .brand-logo__mark {
    width: 2.45rem;
    height: 2.45rem;
  }

  .brand-logo__copy {
    display: grid;
    gap: 0.125rem;
    min-width: 0;
  }

  .brand-logo__name {
    display: flex;
    align-items: baseline;
    gap: 0.22em;
    min-width: 0;
    color: var(--logo-text);
    font-size: 1.125rem;
    font-weight: 900;
    letter-spacing: -0.045em;
    line-height: 1;
    white-space: nowrap;
  }

  .brand-logo[data-size='sm'] .brand-logo__name {
    font-size: 1rem;
  }

  .brand-logo[data-size='lg'] .brand-logo__name {
    font-size: 1.45rem;
  }

  .brand-logo__accent {
    color: var(--logo-blue);
  }

  .brand-logo__city {
    margin-left: 0.25em;
    padding-left: 0.5em;
    border-left: 2px solid var(--logo-orange);
    color: var(--logo-muted);
    font-size: 0.72em;
    font-weight: 800;
    letter-spacing: -0.025em;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .brand-logo__tagline {
    color: var(--logo-muted);
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .brand-logo[data-variant='compact'] .brand-logo__tagline,
  .brand-logo[data-variant='mark'] .brand-logo__copy {
    display: none;
  }

  .brand-logo:where(a):focus-visible {
    outline: 3px solid var(--fd-focus, #38bdf8);
    outline-offset: 4px;
    border-radius: 1rem;
  }

  @media (max-width: 420px) {
    .brand-logo__city {
      display: none;
    }
  }
</style>
