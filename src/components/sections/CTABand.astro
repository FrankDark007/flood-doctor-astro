---
interface Props {
  heading?: string
  description?: string
  primaryText?: string
  primaryHref?: string
  secondaryText?: string
  secondaryHref?: string
}

const {
  heading = 'Ready to get started?',
  description = "Request service today. Our team is standing by 24/7 to help with your water damage emergency.",
  primaryText = 'Request Service',
  primaryHref = '/request/',
  secondaryText = 'Learn more',
  secondaryHref = '/about',
} = Astro.props

const normalizedPrimaryHref = primaryHref === '/request' ? '/request/' : primaryHref
---

<section class="relative isolate overflow-hidden bg-[#06172e]">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_18%_0%,rgba(20,120,230,0.34),transparent_28rem),radial-gradient(circle_at_85%_20%,rgba(217,74,18,0.18),transparent_24rem)]"></div>
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 sm:py-24 lg:flex lg:items-center lg:justify-between lg:gap-12 lg:px-8">
    <div>
      <p class="fd-badge fd-badge-emergency">Emergency-first support</p>
      <h2 class="mt-5 max-w-2xl text-3xl font-black tracking-tight text-white sm:text-5xl">
        {heading}
      </h2>
      <p class="mt-5 max-w-xl text-base leading-7 text-slate-300 sm:text-lg">
        {description}
      </p>
    </div>
    <div class="mt-10 flex flex-col gap-3 sm:flex-row lg:mt-0 lg:shrink-0">
      <a href={normalizedPrimaryHref} class="fd-btn fd-btn-primary">
        {primaryText}
      </a>
      {secondaryText && (
        <a href={secondaryHref} class="fd-btn fd-btn-outline">
          {secondaryText} <span aria-hidden="true">&rarr;</span>
        </a>
      )}
    </div>
  </div>
</section>
