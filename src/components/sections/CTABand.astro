---
interface Props {
  heading?: string
  description?: string
  primaryText?: string
  primaryHref?: string
  secondaryText?: string
  secondaryHref?: string
}

const {
  heading = 'Ready to get started?',
  description = "Get a free estimate today. Our team is standing by 24/7 to help with your water damage emergency.",
  primaryText = 'Get a Free Estimate',
  primaryHref = '/request',
  secondaryText = 'Learn more',
  secondaryHref = '/about',
} = Astro.props
---

<div class="bg-indigo-600 dark:bg-indigo-500">
  <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:flex lg:items-center lg:justify-between lg:px-8">
    <div>
      <h2 class="max-w-2xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">
        {heading}
      </h2>
      <p class="mt-6 max-w-xl text-lg/8 text-indigo-100">
        {description}
      </p>
    </div>
    <div class="mt-10 flex items-center gap-x-6 lg:mt-0 lg:shrink-0">
      <a
        href={primaryHref}
        class="rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-indigo-600 shadow-xs hover:bg-indigo-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        {primaryText}
      </a>
      {secondaryText && (
        <a href={secondaryHref} class="text-sm/6 font-semibold text-white">
          {secondaryText} <span aria-hidden="true">&rarr;</span>
        </a>
      )}
    </div>
  </div>
</div>
