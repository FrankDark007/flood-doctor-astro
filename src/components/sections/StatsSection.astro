---
interface StatItem {
  value: string
  label: string
}

interface Props {
  heading?: string
  subheading?: string
  description?: string
  stats: StatItem[]
  cityName?: string
}

const {
  heading = 'Our track record',
  subheading,
  description,
  stats,
  cityName,
} = Astro.props

const displaySubheading = subheading || (cityName ? `Trusted by ${cityName} homeowners` : 'Trusted by homeowners')
const displayDescription = description || (cityName
  ? `Our commitment to fast response times, quality workmanship, and transparent communication has made Flood Doctor the preferred restoration company in ${cityName} and surrounding areas.`
  : 'Our commitment to fast response times, quality workmanship, and transparent communication has made us the preferred restoration company.')
---

<div class="relative isolate overflow-hidden bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
  <img
    alt=""
    src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=2850&q=80&blend=111827&blend-mode=multiply&sat=-100&exp=15"
    class="absolute inset-0 -z-10 size-full object-cover opacity-10 dark:opacity-100"
  />
  <div
    aria-hidden="true"
    class="absolute -bottom-8 -left-96 -z-10 transform-gpu blur-3xl sm:-bottom-64 sm:-left-40 lg:-bottom-32 lg:left-8 xl:-left-10"
  >
    <div
      style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"
      class="aspect-[1266/975] w-[79.125rem] bg-gradient-to-tr from-[#ff4694] to-[#776fff] opacity-10 dark:opacity-20"
    ></div>
  </div>
  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">
      <h2 class="text-base/8 font-semibold text-indigo-600 dark:text-indigo-400">{heading}</h2>
      <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
        {displaySubheading}
      </p>
      <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
        {displayDescription}
      </p>
    </div>
    <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-10 text-gray-900 dark:text-white sm:mt-20 sm:grid-cols-2 sm:gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-4">
      {stats.map((stat) => (
        <div class="flex flex-col gap-y-3 border-l border-gray-300 dark:border-white/10 pl-6">
          <dt class="text-sm/6 text-gray-600 dark:text-white/80">{stat.label}</dt>
          <dd class="order-first text-3xl font-semibold tracking-tight">{stat.value}</dd>
        </div>
      ))}
    </dl>
  </div>
</div>
