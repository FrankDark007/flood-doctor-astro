---
interface Props {
  cityName?: string
}

const { cityName } = Astro.props
---

<div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto grid max-w-lg grid-cols-4 items-center gap-x-8 gap-y-12 sm:max-w-xl sm:grid-cols-6 sm:gap-x-10 sm:gap-y-14 lg:mx-0 lg:max-w-none lg:grid-cols-5">
      <img alt="IICRC Certified" src="https://tailwindcss.com/plus-assets/img/logos/158x48/transistor-logo-white.svg" width="158" height="48" class="col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 lg:col-span-1" />
      <img alt="RIA Member" src="https://tailwindcss.com/plus-assets/img/logos/158x48/reform-logo-white.svg" width="158" height="48" class="col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 lg:col-span-1" />
      <img alt="EPA Lead-Safe" src="https://tailwindcss.com/plus-assets/img/logos/158x48/tuple-logo-white.svg" width="158" height="48" class="col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 lg:col-span-1" />
      <img alt="BBB Accredited" src="https://tailwindcss.com/plus-assets/img/logos/158x48/savvycal-logo-white.svg" width="158" height="48" class="col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 sm:col-start-2 lg:col-span-1" />
      <img alt="State Farm Partner" src="https://tailwindcss.com/plus-assets/img/logos/158x48/statamic-logo-white.svg" width="158" height="48" class="col-span-2 col-start-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 sm:col-start-auto lg:col-span-1" />
    </div>
    {cityName && (
      <div class="mt-16 flex justify-center">
        <p class="relative rounded-full bg-gray-100 dark:bg-gray-800/75 px-4 py-1.5 text-sm/6 text-gray-600 dark:text-gray-400 ring-1 ring-gray-200 dark:ring-white/10 ring-inset">
          <span class="hidden md:inline">Trusted by homeowners and insurance companies across {cityName}. </span>
          <a href="/reviews" class="font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300">
            <span aria-hidden="true" class="absolute inset-0"></span> Read our reviews{' '}
            <span aria-hidden="true">&rarr;</span>
          </a>
        </p>
      </div>
    )}
  </div>
</div>
