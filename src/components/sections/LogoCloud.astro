---
interface Props {
  cityName?: string
}

const { cityName } = Astro.props

// Honest, text-based trust signals. The previous version shipped Tailwind UI
// demo logos (transistor/reform/tuple/savvycal/statamic) mislabeled as
// IICRC/RIA/EPA/BBB/State Farm — fake certification badges, a liability.
// Replace with plain claims we can stand behind. Restore real badge SVGs
// (verified) here only once we have licensed/owned assets.
const trustSignals = [
  'Licensed & Insured',
  'IICRC-Certified Technicians',
  '24/7 Emergency Response',
  'Direct Insurance Billing',
  'Locally Owned & Operated',
]
---

<div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <h2 class="text-center text-lg/8 font-semibold text-gray-900 dark:text-white">Why homeowners trust us</h2>
    <div class="mx-auto mt-10 flex max-w-4xl flex-wrap items-center justify-center gap-x-6 gap-y-4">
      {trustSignals.map((signal) => (
        <span class="inline-flex items-center rounded-full bg-white dark:bg-white/5 px-4 py-2 text-sm font-semibold text-gray-700 dark:text-gray-200 ring-1 ring-gray-200 dark:ring-white/10">
          {signal}
        </span>
      ))}
    </div>
    {cityName && (
      <div class="mt-16 flex justify-center">
        <p class="relative rounded-full bg-gray-100 dark:bg-gray-800/75 px-4 py-1.5 text-sm/6 text-gray-600 dark:text-gray-400 ring-1 ring-gray-200 dark:ring-white/10 ring-inset">
          <span class="hidden md:inline">Trusted by homeowners and insurance companies across {cityName}. </span>
          <a href="/reviews" class="font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300">
            <span aria-hidden="true" class="absolute inset-0"></span> Read our reviews{' '}
            <span aria-hidden="true">&rarr;</span>
          </a>
        </p>
      </div>
    )}
  </div>
</div>
