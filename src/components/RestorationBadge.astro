---
type BadgeKind =
  | 'emergency'
  | 'documentation'
  | 'drying'
  | 'inspection'
  | 'insurance-support'
  | 'local'
  | 'safety'

type BadgeTone = 'blue' | 'orange' | 'green' | 'slate'
type BadgeIcon = 'clipboard' | 'droplet' | 'home' | 'meter' | 'phone' | 'shield' | 'wind'

interface BadgePreset {
  label: string
  description?: string
  tone: BadgeTone
  icon: BadgeIcon
}

interface Props {
  kind?: BadgeKind
  label?: string
  description?: string
  tone?: BadgeTone
  icon?: BadgeIcon
  compact?: boolean
  class?: string
}

const presets: Record<BadgeKind, BadgePreset> = {
  emergency: {
    label: '24/7 emergency intake',
    description: 'Call-first response path',
    tone: 'orange',
    icon: 'phone',
  },
  documentation: {
    label: 'Job documentation',
    description: 'Photos, notes, and moisture readings',
    tone: 'blue',
    icon: 'clipboard',
  },
  drying: {
    label: 'Drying equipment planning',
    description: 'Air movement and dehumidification support',
    tone: 'blue',
    icon: 'wind',
  },
  inspection: {
    label: 'Moisture inspection',
    description: 'Find affected areas before repairs',
    tone: 'green',
    icon: 'meter',
  },
  'insurance-support': {
    label: 'Insurance documentation support',
    description: 'Scope notes for claim conversations',
    tone: 'slate',
    icon: 'shield',
  },
  local: {
    label: 'Northern Virginia service area',
    description: 'Availability confirmed by phone',
    tone: 'green',
    icon: 'home',
  },
  safety: {
    label: 'Safety-first mitigation',
    description: 'Source control before rebuild decisions',
    tone: 'orange',
    icon: 'droplet',
  },
}

const {
  kind = 'emergency',
  label,
  description,
  tone,
  icon,
  compact = false,
  class: className = '',
} = Astro.props

const preset = presets[kind]
const badgeLabel = label || preset.label
const badgeDescription = description ?? preset.description
const badgeTone = tone || preset.tone
const badgeIcon = icon || preset.icon

const icons: Record<BadgeIcon, string> = {
  clipboard:
    'M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm3 3h4M9 11h6M9 15h6M10 3.5a2 2 0 0 1 4 0',
  droplet:
    'M12 3.5C9.1 7.1 6.5 10.2 6.5 13.3a5.5 5.5 0 0 0 11 0C17.5 10.2 14.9 7.1 12 3.5Zm-2 10.2a2.8 2.8 0 0 0 2.9 2.8',
  home:
    'M4 11.5 12 5l8 6.5M6.5 10.5V20h11v-9.5M10 20v-5h4v5',
  meter:
    'M5 14a7 7 0 1 1 14 0v5H5v-5Zm4 1 3-5 3 5M8 19h8',
  phone:
    'M7.5 4.5 10 7l-1.5 2c1 2.1 2.4 3.5 4.5 4.5l2-1.5 2.5 2.5-1.4 3.1c-.3.7-1.1 1.1-1.8.9C9.6 17.2 6.8 14.4 5.5 9.7c-.2-.7.2-1.5.9-1.8l3.1-1.4Z',
  shield:
    'M12 3.5 18.5 6v5.5c0 4-2.6 7.2-6.5 9-3.9-1.8-6.5-5-6.5-9V6L12 3.5Zm-3 8.5 2 2 4-4',
  wind:
    'M4 8h10a2 2 0 1 0-2-2M4 12h14a2 2 0 1 1-2 2M4 16h8',
}
---

<span
  class:list={['restoration-badge', compact && 'restoration-badge--compact', className]}
  data-tone={badgeTone}
>
  <svg class="restoration-badge__icon" viewBox="0 0 24 24" aria-hidden="true">
    <path d={icons[badgeIcon]} />
  </svg>
  <span class="restoration-badge__copy">
    <span class="restoration-badge__label">{badgeLabel}</span>
    {badgeDescription && !compact && <span class="restoration-badge__description">{badgeDescription}</span>}
  </span>
</span>

<style>
  .restoration-badge {
    --badge-bg: #eff6ff;
    --badge-border: #bfdbfe;
    --badge-icon: #1a73e8;
    --badge-label: #0b1f3a;
    --badge-description: #475569;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    max-width: 100%;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--badge-border);
    border-radius: 999px;
    background: var(--badge-bg);
    color: var(--badge-label);
    box-shadow: 0 1px 0 rgb(11 31 58 / 0.06);
    vertical-align: middle;
  }

  .restoration-badge[data-tone='orange'] {
    --badge-bg: #fff7ed;
    --badge-border: #fed7aa;
    --badge-icon: #ea580c;
  }

  .restoration-badge[data-tone='green'] {
    --badge-bg: #ecfdf5;
    --badge-border: #bbf7d0;
    --badge-icon: #047857;
  }

  .restoration-badge[data-tone='slate'] {
    --badge-bg: #f8fafc;
    --badge-border: #cbd5e1;
    --badge-icon: #334155;
  }

  .restoration-badge__icon {
    width: 1.25rem;
    height: 1.25rem;
    flex: 0 0 auto;
    color: var(--badge-icon);
  }

  .restoration-badge__icon path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.9;
  }

  .restoration-badge__copy {
    display: grid;
    min-width: 0;
    gap: 0.125rem;
  }

  .restoration-badge__label {
    overflow-wrap: anywhere;
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .restoration-badge__description {
    color: var(--badge-description);
    font-size: 0.72rem;
    font-weight: 650;
    line-height: 1.2;
  }

  .restoration-badge--compact {
    gap: 0.45rem;
    padding: 0.45rem 0.625rem;
  }

  .restoration-badge--compact .restoration-badge__icon {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 420px) {
    .restoration-badge {
      border-radius: 1rem;
    }
  }
</style>
