---
import BrandLogo from './BrandLogo.astro'
import { cityData } from '../data/cities'
import { footerNavigation } from '../data/navigation'
import { HEADQUARTERS } from '../utils/schema'
import { toTelHref } from '../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)
const headquartersAddress = `${HEADQUARTERS.streetAddress}, ${HEADQUARTERS.addressLocality}, ${HEADQUARTERS.addressRegion} ${HEADQUARTERS.postalCode}`
const footerLabel = (item: { name: string; href: string }) => item.href === '/request' ? 'Request Service' : item.name
const footerHref = (item: { name: string; href: string }) => item.href === '/request' ? '/request/' : item.href
const privacyPolicyUrl = new URL('/privacy-policy/', Astro.site).toString()
const termsUrl = new URL('/terms/', Astro.site).toString()
---

<footer class="border-t border-white/10 bg-[#06172e] text-white">
  <div class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_15%_0%,rgba(20,120,230,0.28),transparent_30rem),radial-gradient(circle_at_90%_20%,rgba(217,74,18,0.16),transparent_26rem)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="grid gap-10 rounded-3xl border border-white/10 bg-white/[0.04] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.22)] backdrop-blur sm:p-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div>
          <p class="fd-badge fd-badge-emergency">24/7 emergency intake</p>
          <h2 class="mt-4 max-w-2xl text-3xl font-black tracking-tight text-white sm:text-5xl">
            Water damage? Start here.
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
            Flood Doctor {cityData.name} helps property owners start water damage cleanup, drying plans, documentation, and next-step coordination with clear communication.
          </p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
          <a href={cityPhoneHref} class="fd-btn fd-btn-primary w-full" aria-label={`Call Flood Doctor at ${cityData.phone}`}>
            Call Now {cityData.phone}
          </a>
          <a href="/request/" class="fd-btn fd-btn-secondary w-full">
            Request Service
          </a>
        </div>
      </div>

      <div class="mt-16 grid gap-12 border-t border-white/10 pt-12 lg:grid-cols-[0.95fr_1.55fr] lg:gap-16">
        <div>
          <BrandLogo cityName={cityData.name} showCity variant="compact" tone="dark" size="md" />
          <p class="mt-5 max-w-sm text-sm leading-6 text-slate-400">
            Water damage cleanup, drying, and documentation support for {cityData.name} and nearby Northern Virginia communities.
          </p>
          <p class="mt-4 text-sm leading-6 text-slate-400">Headquarters: {headquartersAddress}</p>
        </div>

        <div class="grid gap-8 sm:grid-cols-3">
          <div>
            <h3 class="text-sm font-black uppercase tracking-[0.14em] text-slate-200">Services</h3>
            <ul role="list" class="mt-5 space-y-3">
              {footerNavigation.services.map((item) => (
                <li>
                  <a href={footerHref(item)} class="text-sm leading-6 text-slate-400 transition hover:text-white focus-visible:rounded">{footerLabel(item)}</a>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-black uppercase tracking-[0.14em] text-slate-200">Company</h3>
            <ul role="list" class="mt-5 space-y-3">
              {footerNavigation.company.map((item) => (
                <li>
                  <a href={footerHref(item)} class="text-sm leading-6 text-slate-400 transition hover:text-white focus-visible:rounded">{footerLabel(item)}</a>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-black uppercase tracking-[0.14em] text-slate-200">Resources</h3>
            <ul role="list" class="mt-5 space-y-3">
              {footerNavigation.resources.map((item) => (
                <li>
                  <a href={footerHref(item)} class="text-sm leading-6 text-slate-400 transition hover:text-white focus-visible:rounded">{footerLabel(item)}</a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-8 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
        <p>&copy; {new Date().getFullYear()} Flood Doctor {cityData.name}. All rights reserved.</p>
        <div class="flex gap-x-5">
          <a href={privacyPolicyUrl} class="transition hover:text-white focus-visible:rounded">Privacy</a>
          <a href={termsUrl} class="transition hover:text-white focus-visible:rounded">Terms</a>
        </div>
      </div>
    </div>
  </div>
</footer>
