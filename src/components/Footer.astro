---
import BrandLogo from './BrandLogo.astro'
import { cityData } from '../data/cities'
import { footerNavigation } from '../data/navigation'
import { HEADQUARTERS } from '../utils/schema'
import { toTelHref } from '../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)
const headquartersAddress = `${HEADQUARTERS.streetAddress}, ${HEADQUARTERS.addressLocality}, ${HEADQUARTERS.addressRegion} ${HEADQUARTERS.postalCode}`
const footerLabel = (item: { name: string; href: string }) => item.href === '/request' ? 'Request Service' : item.name
---

<footer class="bg-slate-950 border-t border-white/10 text-white">
  <!-- CTA Section -->
  <div class="mx-auto max-w-7xl px-6 py-16 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-base/7 font-semibold text-orange-300">24/7 Emergency Intake</h2>
      <p class="mt-2 text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl">
        Water damage? We're here to help.
      </p>
      <p class="mx-auto mt-6 max-w-xl text-lg/8 text-pretty text-slate-300">
        Flood Doctor {cityData.name} helps property owners start water damage cleanup, drying plans, documentation, and next-step coordination with clear communication.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
        <a
          href={cityPhoneHref}
          class="rounded-md bg-orange-600 px-5 py-3 text-sm font-semibold text-white shadow-xs hover:bg-orange-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-300"
        >
          Call Now {cityData.phone}
        </a>
        <a
          href="/request"
          class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-950 shadow-xs hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        >
          Request Service
        </a>
      </div>
    </div>

    <!-- Navigation -->
    <div class="mt-24 border-t border-white/10 pt-12 xl:grid xl:grid-cols-3 xl:gap-8">
      <div>
        <BrandLogo cityName={cityData.name} showCity variant="compact" tone="dark" size="md" />
        <p class="mt-4 text-sm text-slate-400 max-w-xs">
          Water damage cleanup, drying, and documentation support for {cityData.name} and nearby Northern Virginia communities.
        </p>
        <p class="mt-2 text-sm text-slate-400">Headquarters: {headquartersAddress}</p>
      </div>
      <div class="mt-16 grid grid-cols-3 gap-8 xl:col-span-2 xl:mt-0">
        <div>
          <h3 class="text-sm/6 font-semibold text-white">Services</h3>
          <ul role="list" class="mt-6 space-y-4">
            {footerNavigation.services.map((item) => (
              <li>
                <a href={item.href} class="text-sm/6 text-slate-400 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300">{footerLabel(item)}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm/6 font-semibold text-white">Company</h3>
          <ul role="list" class="mt-6 space-y-4">
            {footerNavigation.company.map((item) => (
              <li>
                <a href={item.href} class="text-sm/6 text-slate-400 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300">{footerLabel(item)}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm/6 font-semibold text-white">Resources</h3>
          <ul role="list" class="mt-6 space-y-4">
            {footerNavigation.resources.map((item) => (
              <li>
                <a href={item.href} class="text-sm/6 text-slate-400 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300">{footerLabel(item)}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 border-t border-white/10 pt-8 md:flex md:items-center md:justify-between">
      <p class="text-sm/6 text-slate-400">
        &copy; {new Date().getFullYear()} Flood Doctor {cityData.name}. All rights reserved.
      </p>
      <div class="mt-4 md:mt-0 flex gap-x-4 text-sm text-slate-400">
        <a href="/privacy" class="hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300">Privacy</a>
        <a href="/terms" class="hover:text-white focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300">Terms</a>
      </div>
    </div>
  </div>
</footer>
