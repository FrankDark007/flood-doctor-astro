---
type RestorationMediaVariant = 'drying-wall' | 'equipment-detail' | 'response-van' | 'process'
type RestorationMediaTone = 'light' | 'dark'
type RestorationMediaAspect = 'wide' | 'card' | 'square'

interface Props {
  variant?: RestorationMediaVariant
  alt?: string
  caption?: string
  tone?: RestorationMediaTone
  aspect?: RestorationMediaAspect
  loading?: 'lazy' | 'eager'
  class?: string
}

const media: Record<RestorationMediaVariant, { src: string; width: number; height: number; alt: string; label: string }> = {
  'drying-wall': {
    src: '/graphics/restoration-drying-wall.svg',
    width: 960,
    height: 640,
    alt: 'Illustration of drying fans, a dehumidifier, floor protection, and moisture mapping in a water-damaged room.',
    label: 'Drying setup',
  },
  'equipment-detail': {
    src: '/graphics/restoration-equipment-detail.svg',
    width: 960,
    height: 640,
    alt: 'Illustration of a moisture meter, extraction hose, protected flooring, and field documentation clipboard.',
    label: 'Equipment detail',
  },
  'response-van': {
    src: '/graphics/restoration-response-van.svg',
    width: 960,
    height: 640,
    alt: 'Illustration of a restoration response van with safety cones, hose routing, and a home jobsite.',
    label: 'Response scene',
  },
  process: {
    src: '/graphics/restoration-process.svg',
    width: 960,
    height: 420,
    alt: 'Illustration of emergency intake, water extraction, drying and monitoring, and documentation steps.',
    label: 'Restoration process',
  },
}

const {
  variant = 'drying-wall',
  alt,
  caption,
  tone = 'light',
  aspect = variant === 'process' ? 'wide' : 'card',
  loading = 'lazy',
  class: className = '',
} = Astro.props

const item = media[variant] ?? media['drying-wall']
const imageAlt = alt ?? item.alt

// Visual assumptions: these are generic, self-owned vector jobsite scenes. They do not claim certifications,
// reviews, ratings, exact fleet appearance, or use stock/demo photography. Replace with verified field assets later.
---

<figure class:list={['restoration-media', className]} data-tone={tone} data-aspect={aspect}>
  <div class="restoration-media__frame">
    <img
      class="restoration-media__image"
      src={item.src}
      alt={imageAlt}
      width={item.width}
      height={item.height}
      loading={loading}
      decoding="async"
    />
    <span class="restoration-media__tag" aria-hidden="true">{item.label}</span>
  </div>
  {caption && <figcaption class="restoration-media__caption">{caption}</figcaption>}
</figure>

<style>
  .restoration-media {
    --media-navy: var(--fd-navy-950, #06172e);
    --media-blue: var(--fd-blue-700, #0b63ce);
    --media-sky: var(--fd-sky-400, #38bdf8);
    --media-orange: var(--fd-orange-600, #f97316);
    --media-border: rgb(11 99 206 / 0.18);
    --media-surface: rgb(255 255 255 / 0.9);
    --media-caption: var(--fd-slate-600, #475569);
    margin: 0;
    color: var(--media-navy);
  }

  .restoration-media[data-tone='dark'] {
    --media-border: rgb(125 211 252 / 0.28);
    --media-surface: rgb(6 23 46 / 0.72);
    --media-caption: #cbd5e1;
    color: #fff;
  }

  .restoration-media__frame {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border: 1px solid var(--media-border);
    border-radius: clamp(1.25rem, 3vw, 2rem);
    background:
      linear-gradient(135deg, rgb(56 189 248 / 0.16), transparent 34%),
      linear-gradient(315deg, rgb(249 115 22 / 0.16), transparent 30%),
      var(--media-surface);
    box-shadow:
      0 26px 70px rgb(6 23 46 / 0.16),
      inset 0 1px 0 rgb(255 255 255 / 0.65);
  }

  .restoration-media__frame::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: repeating-linear-gradient(135deg, rgb(6 23 46 / 0.045) 0 1px, transparent 1px 14px);
    content: '';
  }

  .restoration-media__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .restoration-media[data-aspect='wide'] .restoration-media__frame {
    aspect-ratio: 16 / 7;
  }

  .restoration-media[data-aspect='card'] .restoration-media__frame {
    aspect-ratio: 3 / 2;
  }

  .restoration-media[data-aspect='square'] .restoration-media__frame {
    aspect-ratio: 1;
  }

  .restoration-media__tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.48rem 0.72rem;
    border: 1px solid rgb(255 255 255 / 0.64);
    border-radius: 999px;
    background: rgb(6 23 46 / 0.76);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    box-shadow: 0 12px 24px rgb(6 23 46 / 0.22);
  }

  .restoration-media__tag::before {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--media-orange);
    box-shadow: 0 0 0 4px rgb(249 115 22 / 0.2);
    content: '';
  }

  .restoration-media__caption {
    max-width: 68ch;
    margin: 0.75rem 0 0;
    color: var(--media-caption);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.45;
  }

  @media (max-width: 640px) {
    .restoration-media[data-aspect='wide'] .restoration-media__frame,
    .restoration-media[data-aspect='card'] .restoration-media__frame {
      aspect-ratio: 4 / 3;
    }

    .restoration-media__tag {
      top: 0.75rem;
      left: 0.75rem;
      font-size: 0.66rem;
    }
  }
</style>
