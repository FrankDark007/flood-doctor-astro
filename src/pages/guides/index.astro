---
import { cityData } from '../../data/cities'
import { breadcrumbSchema, cityBaseUrl } from '../../utils/schema'

const _base = cityBaseUrl()
const targetPath = '/resources/homeowner-guides/'
const canonicalUrl = `${_base}${targetPath}`
const description = `Free water damage guides for ${cityData.name} homeowners. Emergency response, prevention tips, and insurance claims help from Flood Doctor.`
const structuredData = breadcrumbSchema([
  { name: 'Home', url: `${_base}/` },
  { name: 'Resources', url: `${_base}/resources/` },
  { name: 'Homeowner Guides', url: canonicalUrl },
])
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Homeowner Guides | Flood Doctor {cityData.name}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta http-equiv="refresh" content={`0;url=${targetPath}`} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <p>
      Homeowner guides have moved to
      <a href={targetPath}>/resources/homeowner-guides/</a>.
    </p>
  </body>
</html>
