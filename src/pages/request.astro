---
import BaseLayout from '../layouts/BaseLayout.astro'
import RequestForm from '../components/islands/RequestForm.tsx'
import { cityData } from '../data/cities'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Free Estimate - Flood Doctor ${cityData.name}`,
  provider: {
    '@type': 'LocalBusiness',
    name: `Flood Doctor ${cityData.name}`,
    telephone: cityData.phone,
  },
  areaServed: {
    '@type': 'City',
    name: cityData.name,
  },
}
---

<BaseLayout
  title={`Request a Free Estimate | Flood Doctor ${cityData.name}`}
  description={`Request a free water damage restoration estimate from Flood Doctor ${cityData.name}. 24/7 emergency response, 60-minute arrival. Call ${cityData.phone} or submit online.`}
  structuredData={structuredData}
>
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl">
          Request a Free Estimate
        </h1>
        <p class="mt-2 text-lg/8 text-gray-300">
          Tell us about your situation and we'll provide a free, no-obligation estimate. For emergencies, call
          <a href={`tel:${cityData.phone}`} class="text-indigo-400 hover:text-indigo-300 font-semibold"> {cityData.phone}</a> for the fastest response.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-4xl grid-cols-1 gap-x-8 gap-y-16 lg:grid-cols-5">
        <!-- Contact info sidebar -->
        <div class="lg:col-span-2">
          <div class="space-y-8">
            <div class="flex gap-x-4">
              <!-- phone outline 24 -->
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 shrink-0 text-indigo-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
              <div>
                <h3 class="text-sm font-semibold text-white">Emergency Line</h3>
                <p class="mt-1 text-sm text-gray-300">
                  <a href={`tel:${cityData.phone}`} class="hover:text-white">
                    {cityData.phone}
                  </a>
                </p>
              </div>
            </div>
            <div class="flex gap-x-4">
              <!-- clock outline 24 -->
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 shrink-0 text-indigo-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              <div>
                <h3 class="text-sm font-semibold text-white">Response Time</h3>
                <p class="mt-1 text-sm text-gray-300">60 minutes or less, 24/7/365</p>
              </div>
            </div>
            <div class="flex gap-x-4">
              <!-- envelope outline 24 -->
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 shrink-0 text-indigo-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              <div>
                <h3 class="text-sm font-semibold text-white">Email</h3>
                <p class="mt-1 text-sm text-gray-300">
                  <a href="mailto:info@flood.doctor" class="hover:text-white">
                    info@flood.doctor
                  </a>
                </p>
              </div>
            </div>
            <div class="flex gap-x-4">
              <!-- building-office-2 outline 24 -->
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 shrink-0 text-indigo-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 7.5h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
              </svg>
              <div>
                <h3 class="text-sm font-semibold text-white">Service Area</h3>
                <p class="mt-1 text-sm text-gray-300">
                  {cityData.name} &amp; all of Northern Virginia
                </p>
              </div>
            </div>
          </div>

          <div class="mt-10 rounded-2xl bg-white/5 p-6 outline-1 -outline-offset-1 outline-white/10">
            <h3 class="text-sm font-semibold text-white">What to expect</h3>
            <ol class="mt-4 space-y-3 text-sm text-gray-300">
              <li class="flex gap-x-3">
                <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-semibold text-indigo-400">
                  1
                </span>
                Submit your request with details about the damage
              </li>
              <li class="flex gap-x-3">
                <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-semibold text-indigo-400">
                  2
                </span>
                We'll contact you within 30 minutes during business hours
              </li>
              <li class="flex gap-x-3">
                <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-indigo-500/10 text-xs font-semibold text-indigo-400">
                  3
                </span>
                Free on-site assessment and detailed estimate
              </li>
            </ol>
          </div>
        </div>

        <!-- Request form island -->
        <RequestForm city={cityData.slug} client:load />
      </div>
    </div>
  </div>
</BaseLayout>
