---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContactForm from '../components/islands/ContactForm.tsx'
import Icon from '../components/Icon.astro'
import { cityData } from '../data/cities'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `Flood Doctor ${cityData.name}`,
  telephone: cityData.phone,
  email: 'info@flood.doctor',
  address: {
    '@type': 'PostalAddress',
    addressLocality: cityData.name,
    addressRegion: cityData.state,
  },
}

const serviceAreas = cityData.serviceAreas || [
  'Ashburn', 'Leesburg', 'Sterling', 'Herndon', 'Reston',
  'Fairfax', 'Arlington', 'Alexandria', 'McLean', 'Vienna',
  'Centreville', 'Chantilly', 'Springfield',
]
---

<BaseLayout
  title={`Contact Us | Flood Doctor ${cityData.name}`}
  description={`Contact Flood Doctor ${cityData.name} for emergency water damage restoration. Available 24/7 at ${cityData.phone}. Serving ${cityData.name} and all of Northern Virginia.`}
  structuredData={structuredData}
>
  <!-- Contact Form Section -->
  <div class="relative isolate">
    <div class="mx-auto grid max-w-7xl grid-cols-1 lg:grid-cols-2">
      <div class="relative px-6 pt-24 pb-20 sm:pt-32 lg:static lg:px-8 lg:py-48">
        <div class="mx-auto max-w-xl lg:mx-0 lg:max-w-lg">
          <div class="absolute inset-y-0 left-0 -z-10 w-full overflow-hidden ring-1 ring-white/10 lg:w-1/2">
            <svg
              aria-hidden="true"
              class="absolute inset-0 size-full mask-[radial-gradient(100%_100%_at_top_right,white,transparent)] stroke-white/10"
            >
              <defs>
                <pattern
                  x="100%"
                  y="-1"
                  id="contact-dark-pattern"
                  width="200"
                  height="200"
                  patternUnits="userSpaceOnUse"
                >
                  <path d="M130 200V.5M.5 .5H200" fill="none" />
                </pattern>
              </defs>
              <rect width="100%" height="100%" stroke-width="0" class="fill-gray-900" />
              <svg x="100%" y="-1" class="overflow-visible fill-gray-800/20">
                <path d="M-470.5 0h201v201h-201Z" stroke-width="0" />
              </svg>
              <rect fill="url(#contact-dark-pattern)" width="100%" height="100%" stroke-width="0" />
            </svg>
            <div
              aria-hidden="true"
              class="absolute top-[calc(100%-13rem)] -left-56 block transform-gpu blur-3xl lg:top-[calc(50%-7rem)] lg:left-[max(-14rem,calc(100%-59rem))]"
            >
              <div
                style="clip-path: polygon(74.1% 56.1%, 100% 38.6%, 97.5% 73.3%, 85.5% 100%, 80.7% 98.2%, 72.5% 67.7%, 60.2% 37.8%, 52.4% 32.2%, 47.5% 41.9%, 45.2% 65.8%, 27.5% 23.5%, 0.1% 35.4%, 17.9% 0.1%, 27.6% 23.5%, 76.1% 2.6%, 74.1% 56.1%)"
                class="aspect-[1155/678] w-[72.1875rem] bg-gradient-to-br from-[#80caff] to-[#4f46e5] opacity-20"
              >
              </div>
            </div>
          </div>
          <h1 class="text-4xl font-semibold tracking-tight text-pretty text-white sm:text-5xl">Get in Touch</h1>
          <p class="mt-6 text-lg/8 text-gray-400">
            Whether you have questions about our services, need an estimate, or are facing a water emergency — we're here to help. Reach out and our {cityData.name} team will respond promptly.
          </p>
          <dl class="mt-10 space-y-4 text-base/7 text-gray-300">
            <div class="flex gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">Address</span>
                <!-- building-office-2 outline 24 -->
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-6 text-gray-400">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 7.5h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
                </svg>
              </dt>
              <dd>
                Flood Doctor<br />
                Serving {cityData.name}, {cityData.state}
              </dd>
            </div>
            <div class="flex gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">Telephone</span>
                <!-- phone outline 24 -->
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-6 text-gray-400">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </dt>
              <dd>
                <a href={`tel:${cityData.phone}`} class="hover:text-white">
                  {cityData.phone}
                </a>
                <p class="text-sm text-gray-500">24/7 Emergency Line</p>
              </dd>
            </div>
            <div class="flex gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">Email</span>
                <!-- envelope outline 24 -->
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-6 text-gray-400">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </dt>
              <dd>
                <a href="mailto:info@flood.doctor" class="hover:text-white">
                  info@flood.doctor
                </a>
              </dd>
            </div>
          </dl>

          <!-- Service Areas -->
          <div class="mt-10 border-t border-white/10 pt-8">
            <h3 class="text-sm font-semibold text-white">Service Areas</h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {serviceAreas.map((area: string) => (
                <span class="rounded-full bg-white/5 px-3 py-1 text-xs text-gray-400 ring-1 ring-white/10">
                  {area}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
      <ContactForm city={cityData.slug} client:load />
    </div>
  </div>

  <!-- Map / Hours Section -->
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Hours & Availability</h2>
        <p class="mt-6 text-lg/8 text-gray-400">
          Water damage doesn't wait for business hours — and neither do we.
        </p>
      </div>
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        <div class="rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10">
          <h3 class="text-lg font-semibold text-white">Emergency Response</h3>
          <p class="mt-2 text-3xl font-bold text-indigo-400">24/7/365</p>
          <p class="mt-2 text-sm text-gray-400">We respond to water emergencies around the clock, including holidays and weekends.</p>
        </div>
        <div class="rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10">
          <h3 class="text-lg font-semibold text-white">Office Hours</h3>
          <p class="mt-2 text-sm text-gray-300">Monday – Friday: 8:00 AM – 6:00 PM</p>
          <p class="mt-1 text-sm text-gray-300">Saturday: 9:00 AM – 2:00 PM</p>
          <p class="mt-1 text-sm text-gray-300">Sunday: Emergency Only</p>
        </div>
        <div class="rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10">
          <h3 class="text-lg font-semibold text-white">Response Time</h3>
          <p class="mt-2 text-3xl font-bold text-indigo-400">&lt;60 min</p>
          <p class="mt-2 text-sm text-gray-400">Average on-site arrival time for emergency calls in the {cityData.name} area.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
