---
import BaseLayout from '../layouts/BaseLayout.astro'
import FAQAccordion from '../components/islands/FAQAccordion.tsx'
import { faqs } from '../data/faqs'
import { cityData } from '../data/cities'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
}
---

<BaseLayout
  title={`FAQ | Flood Doctor ${cityData.name}`}
  description={`Frequently asked questions about water damage restoration, mold remediation, insurance claims, and Flood Doctor's services in ${cityData.name}, Virginia.`}
  structuredData={structuredData}
>
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Frequently Asked Questions
        </h1>
        <p class="mt-6 text-lg/8 text-gray-400">
          Got questions about water damage restoration? We've got answers. If you don't find what you're looking for, <a href="/contact" class="text-indigo-400 hover:text-indigo-300">contact us</a> or call <a href={`tel:${cityData.phone}`} class="text-indigo-400 hover:text-indigo-300">{cityData.phone}</a>.
        </p>
        <div class="mt-10">
          <FAQAccordion client:load faqs={faqs} />
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl rounded-2xl bg-white/5 p-8 text-center outline-1 -outline-offset-1 outline-white/10 sm:p-12">
        <h2 class="text-2xl font-semibold text-white">Still have questions?</h2>
        <p class="mt-4 text-gray-400">Our team is ready to help 24/7. Get a free estimate or call us directly.</p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href="/request"
            class="rounded-md bg-indigo-500 px-6 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-400"
          >
            Request Free Estimate
          </a>
          <a
            href={`tel:${cityData.phone}`}
            class="rounded-md bg-white/10 px-6 py-2.5 text-sm font-semibold text-white hover:bg-white/20"
          >
            Call {cityData.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
