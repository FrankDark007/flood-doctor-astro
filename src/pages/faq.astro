---
import BaseLayout from '../layouts/BaseLayout.astro'
import FAQAccordion from '../components/islands/FAQAccordion.tsx'
import CTABand from '../components/sections/CTABand.astro'
import { faqs } from '../data/faqs'
import { cityData } from '../data/cities'
import { faqPageSchema } from '../utils/schema'
import { toTelHref } from '../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)

const structuredData = faqPageSchema(faqs)
---

<BaseLayout
  title={`FAQ | Flood Doctor ${cityData.name}`}
  description={`Frequently asked questions about water damage restoration, mold remediation, insurance claims, and Flood Doctor's services in ${cityData.name}, Virginia.`}
  structuredData={structuredData}
>
  <!-- FAQ Section — matching FAQDark.tsx -->
  <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-4xl divide-y divide-gray-200 dark:divide-white/10">
        <h1 class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
          Frequently asked questions
        </h1>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-400">
          Got questions about water damage restoration? We've got answers. If you don't find what you're looking for,{' '}
          <a href="/contact" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300">contact us</a>{' '}
          or call{' '}
          <a href={cityPhoneHref} class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300">{cityData.phone}</a>.
        </p>
        <div class="mt-10">
          <FAQAccordion client:visible faqs={faqs} />
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="bg-gray-50 dark:bg-gray-900 pb-24 sm:pb-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl rounded-2xl bg-gray-100 dark:bg-white/5 p-8 text-center outline-1 -outline-offset-1 outline-gray-200 dark:outline-white/10 sm:p-12">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">Still have questions?</h2>
        <p class="mt-4 text-gray-600 dark:text-gray-400">Our team is ready to help 24/7. Get a free estimate or call us directly.</p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href="/request"
            class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-6 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400"
          >
            Request Free Estimate
          </a>
          <a
            href={cityPhoneHref}
            class="rounded-md bg-gray-200 dark:bg-white/10 px-6 py-2.5 text-sm font-semibold text-gray-900 dark:text-white hover:bg-gray-300 dark:hover:bg-white/20"
          >
            Call {cityData.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
