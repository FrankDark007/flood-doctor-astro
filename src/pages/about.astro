---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContactForm from '../components/islands/ContactForm.tsx'
import { cityData } from '../data/cities'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  mainEntity: {
    '@type': 'LocalBusiness',
    name: `Flood Doctor ${cityData.name}`,
    description: `Professional water damage restoration company serving ${cityData.name} and Northern Virginia since 2014.`,
    telephone: cityData.phone,
    foundingDate: '2014',
    areaServed: {
      '@type': 'State',
      name: 'Virginia',
    },
  },
}

const timeline = [
  {
    name: 'Founded in Virginia',
    description: 'Flood Doctor was established to bring fast, professional water damage restoration to Northern Virginia homeowners and businesses.',
    date: '2014',
    dateTime: '2014',
  },
  {
    name: 'IICRC Certified Team',
    description: 'Our entire crew earned IICRC certifications in Water Damage Restoration (WRT) and Applied Structural Drying (ASD).',
    date: '2016',
    dateTime: '2016',
  },
  {
    name: 'Expanded to 13 Cities',
    description: 'Grew service area across Northern Virginia including Ashburn, Leesburg, Sterling, Herndon, Reston, Fairfax, and beyond.',
    date: '2019',
    dateTime: '2019',
  },
  {
    name: '2,500+ Restorations',
    description: 'Passed 2,500 completed restorations with a 98.7% customer satisfaction rate and 4.9-star Google rating.',
    date: '2025',
    dateTime: '2025',
  },
]

const values = [
  {
    name: 'Rapid Response',
    description: 'Every minute counts with water damage. Our teams arrive on-site within 60 minutes, 24 hours a day, 365 days a year.',
  },
  {
    name: 'Transparent Pricing',
    description: 'No hidden fees or surprise charges. We provide detailed estimates before work begins and coordinate directly with your insurance.',
  },
  {
    name: 'Certified Expertise',
    description: 'IICRC-certified technicians use industrial-grade equipment and follow science-based drying protocols for every job.',
  },
  {
    name: 'Community First',
    description: "We're your neighbors. When disaster strikes, we treat your home like it's our own — because this is our community too.",
  },
]
---

<BaseLayout
  title={`About Us | Flood Doctor ${cityData.name}`}
  description={`Learn about Flood Doctor — Northern Virginia's trusted water damage restoration company since 2014. IICRC certified, 4.9-star rated, serving ${cityData.name} and 13 cities.`}
  structuredData={structuredData}
>
  <main class="isolate">
    <!-- Hero section -->
    <div class="relative isolate -z-10 overflow-hidden bg-gradient-to-b from-indigo-100/20 dark:from-indigo-900/20 pt-14">
      <div
        aria-hidden="true"
        class="absolute inset-y-0 right-1/2 -z-10 -mr-96 w-[200%] origin-top-right skew-x-[-30deg] bg-white dark:bg-gray-900 shadow-xl ring-1 shadow-indigo-500/10 ring-gray-200 dark:ring-white/5 sm:-mr-80 lg:-mr-96"
      ></div>
      <div class="mx-auto max-w-7xl px-6 py-32 sm:py-40 lg:px-8">
        <div class="mx-auto max-w-2xl lg:mx-0 lg:grid lg:max-w-none lg:grid-cols-2 lg:gap-x-16 lg:gap-y-8 xl:grid-cols-1 xl:grid-rows-1 xl:gap-x-8">
          <h1 class="max-w-2xl text-5xl font-semibold tracking-tight text-balance text-gray-900 dark:text-white sm:text-7xl lg:col-span-2 xl:col-auto">
            Your Trusted Water Damage Restoration Team
          </h1>
          <div class="mt-6 max-w-xl lg:mt-0 xl:col-end-1 xl:row-start-1">
            <p class="text-lg font-medium text-pretty text-gray-500 dark:text-gray-400 sm:text-xl/8">
              Since 2014, Flood Doctor has been Northern Virginia's go-to restoration company. We combine rapid emergency response with certified expertise to restore homes and businesses after water damage, flooding, and mold — minimizing damage and getting life back to normal, fast.
            </p>
          </div>
          <img
            alt="Flood Doctor restoration team at work"
            src="https://images.unsplash.com/photo-1567532900872-f4e906cbf06a?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1280&q=80"
            class="mt-10 aspect-[6/5] w-full max-w-lg rounded-2xl object-cover outline-1 -outline-offset-1 outline-gray-200 dark:outline-white/10 sm:mt-16 lg:mt-0 lg:max-w-none xl:row-span-2 xl:row-end-2 xl:mt-36"
          />
        </div>
      </div>
      <div class="absolute inset-x-0 bottom-0 -z-10 h-24 bg-gradient-to-t from-white dark:from-gray-900 sm:h-32"></div>
    </div>

    <!-- Timeline section -->
    <div class="mx-auto -mt-8 max-w-7xl px-6 lg:px-8">
      <div class="mx-auto grid max-w-2xl grid-cols-1 gap-8 overflow-hidden lg:mx-0 lg:max-w-none lg:grid-cols-4">
        {timeline.map((item) => (
          <div>
            <time datetime={item.dateTime} class="flex items-center text-sm/6 font-semibold text-indigo-600 dark:text-indigo-400">
              <svg viewBox="0 0 4 4" aria-hidden="true" class="mr-4 size-1 flex-none">
                <circle r="2" cx="2" cy="2" fill="currentColor" />
              </svg>
              {item.date}
              <div
                aria-hidden="true"
                class="absolute -ml-2 h-px w-screen -translate-x-full bg-gray-200 dark:bg-white/10 sm:-ml-4 lg:static lg:-mr-6 lg:ml-8 lg:w-auto lg:flex-auto lg:translate-x-0"
              ></div>
            </time>
            <p class="mt-6 text-lg/8 font-semibold tracking-tight text-gray-900 dark:text-white">{item.name}</p>
            <p class="mt-1 text-base/7 text-gray-500 dark:text-gray-400">{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Values section -->
    <div class="py-24 sm:py-32 mt-32 sm:mt-40">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:mx-0">
          <h2 class="text-3xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-4xl">
            What Sets Us Apart
          </h2>
          <p class="mt-6 text-lg/8 text-gray-500 dark:text-gray-400">
            Flood Doctor isn't just another restoration company. We're a team that genuinely cares about our community and treats every job — big or small — with the same urgency and professionalism.
          </p>
        </div>
        <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 text-base/7 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-4">
          {values.map((value) => (
            <div>
              <dt class="font-semibold text-gray-900 dark:text-white">{value.name}</dt>
              <dd class="mt-1 text-gray-500 dark:text-gray-400">{value.description}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- Stats section -->
    <div class="mt-16 sm:mt-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:max-w-none">
          <div class="text-center">
            <h2 class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
              Trusted by {cityData.name} Families
            </h2>
            <p class="mt-4 text-lg/8 text-gray-600 dark:text-gray-300">
              The numbers speak for themselves.
            </p>
          </div>
          <dl class="mt-16 grid grid-cols-1 gap-0.5 overflow-hidden rounded-2xl text-center sm:grid-cols-2 lg:grid-cols-4">
            <div class="flex flex-col bg-gray-100 dark:bg-white/5 p-8">
              <dt class="text-sm/6 font-semibold text-gray-600 dark:text-gray-300">Response Time</dt>
              <dd class="order-first text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">&lt;60 min</dd>
            </div>
            <div class="flex flex-col bg-gray-100 dark:bg-white/5 p-8">
              <dt class="text-sm/6 font-semibold text-gray-600 dark:text-gray-300">Restorations Completed</dt>
              <dd class="order-first text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">2,500+</dd>
            </div>
            <div class="flex flex-col bg-gray-100 dark:bg-white/5 p-8">
              <dt class="text-sm/6 font-semibold text-gray-600 dark:text-gray-300">Customer Satisfaction</dt>
              <dd class="order-first text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">98.7%</dd>
            </div>
            <div class="flex flex-col bg-gray-100 dark:bg-white/5 p-8">
              <dt class="text-sm/6 font-semibold text-gray-600 dark:text-gray-300">Google Rating</dt>
              <dd class="order-first text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">4.9 ★</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>

    <!-- Our Commitment / CTA section -->
    <div class="mt-32 overflow-hidden sm:mt-40">
      <div class="mx-auto max-w-7xl px-6 lg:flex lg:px-8">
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-12 gap-y-16 lg:mx-0 lg:max-w-none lg:min-w-full lg:flex-none lg:gap-y-8">
          <div class="lg:col-end-1 lg:w-full lg:max-w-lg lg:pb-8">
            <h2 class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Our Commitment</h2>
            <p class="mt-6 text-xl/8 text-gray-600 dark:text-gray-300">
              When water damage strikes your {cityData.name} home or business, every minute matters. Our commitment is simple: rapid response, expert restoration, and treating your property like our own.
            </p>
            <p class="mt-6 text-base/7 text-gray-500 dark:text-gray-400">
              We work directly with all major insurance carriers, handling the paperwork so you can focus on what matters. Our IICRC-certified technicians use industrial-grade equipment and science-based protocols to ensure complete restoration — no shortcuts, no cutting corners.
            </p>
            <div class="mt-8 flex gap-x-4">
              <a
                href="/request"
                class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"
              >
                Request Free Estimate
              </a>
              <a
                href={`tel:${cityData.phone}`}
                class="rounded-md bg-gray-200 dark:bg-white/10 px-3.5 py-2.5 text-sm font-semibold text-gray-900 dark:text-white shadow-xs hover:bg-gray-300 dark:hover:bg-white/20"
              >
                Call {cityData.phone}
              </a>
            </div>
          </div>
          <div class="flex flex-wrap items-start justify-end gap-6 sm:gap-8 lg:contents">
            <div class="w-0 flex-auto lg:ml-auto lg:w-auto lg:flex-none lg:self-end">
              <img
                alt="Water damage restoration work"
                src="https://images.unsplash.com/photo-1670272502246-768d249768ca?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1152&q=80"
                class="aspect-[7/5] w-[37rem] max-w-none rounded-2xl bg-gray-200 dark:bg-gray-800 object-cover max-sm:w-[30rem]"
              />
            </div>
            <div class="contents lg:col-span-2 lg:col-end-2 lg:ml-auto lg:flex lg:w-[37rem] lg:items-start lg:justify-end lg:gap-x-8">
              <div class="order-first flex w-64 flex-none justify-end self-end max-sm:w-40 lg:w-auto">
                <img
                  alt="Restoration equipment"
                  src="https://images.unsplash.com/photo-1605656816944-971cd5c1407f?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=768&h=604&q=80"
                  class="aspect-[4/3] w-[24rem] max-w-none flex-none rounded-2xl bg-gray-200 dark:bg-gray-800 object-cover"
                />
              </div>
              <div class="flex w-96 flex-auto justify-end lg:w-auto lg:flex-none">
                <img
                  alt="Professional team"
                  src="https://images.unsplash.com/photo-1568992687947-868a62a9f521?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1152&h=842&q=80"
                  class="aspect-[7/5] w-[37rem] max-w-none flex-none rounded-2xl bg-gray-200 dark:bg-gray-800 object-cover max-sm:w-[30rem]"
                />
              </div>
              <div class="hidden sm:block sm:w-0 sm:flex-auto lg:w-auto lg:flex-none">
                <img
                  alt="Drying process"
                  src="https://images.unsplash.com/photo-1612872087720-bb876e2e67d1?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=768&h=604&q=80"
                  class="aspect-[4/3] w-[24rem] max-w-none rounded-2xl bg-gray-200 dark:bg-gray-800 object-cover"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Section -->
    <div class="relative isolate mt-32 sm:mt-40">
      <div class="mx-auto grid max-w-7xl grid-cols-1 lg:grid-cols-2">
        <div class="relative px-6 pt-24 pb-20 sm:pt-32 lg:static lg:px-8 lg:py-48">
          <div class="mx-auto max-w-xl lg:mx-0 lg:max-w-lg">
            <div class="absolute inset-y-0 left-0 -z-10 w-full overflow-hidden ring-1 ring-gray-200 dark:ring-white/10 lg:w-1/2">
              <svg
                aria-hidden="true"
                class="absolute inset-0 size-full mask-[radial-gradient(100%_100%_at_top_right,white,transparent)] stroke-gray-200 dark:stroke-white/10"
              >
                <defs>
                  <pattern
                    x="100%"
                    y="-1"
                    id="about-contact-pattern"
                    width="200"
                    height="200"
                    patternUnits="userSpaceOnUse"
                  >
                    <path d="M130 200V.5M.5 .5H200" fill="none" />
                  </pattern>
                </defs>
                <rect width="100%" height="100%" stroke-width="0" class="fill-white dark:fill-gray-900" />
                <svg x="100%" y="-1" class="overflow-visible fill-gray-100/20 dark:fill-gray-800/20">
                  <path d="M-470.5 0h201v201h-201Z" stroke-width="0" />
                </svg>
                <rect fill="url(#about-contact-pattern)" width="100%" height="100%" stroke-width="0" />
              </svg>
              <div
                aria-hidden="true"
                class="absolute top-[calc(100%-13rem)] -left-56 block transform-gpu blur-3xl lg:top-[calc(50%-7rem)] lg:left-[max(-14rem,calc(100%-59rem))]"
              >
                <div
                  style="clip-path: polygon(74.1% 56.1%, 100% 38.6%, 97.5% 73.3%, 85.5% 100%, 80.7% 98.2%, 72.5% 67.7%, 60.2% 37.8%, 52.4% 32.2%, 47.5% 41.9%, 45.2% 65.8%, 27.5% 23.5%, 0.1% 35.4%, 17.9% 0.1%, 27.6% 23.5%, 76.1% 2.6%, 74.1% 56.1%)"
                  class="aspect-[1155/678] w-[72.1875rem] bg-gradient-to-br from-[#80caff] to-[#4f46e5] opacity-20"
                >
                </div>
              </div>
            </div>
            <h2 class="text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">Get in touch</h2>
            <p class="mt-6 text-lg/8 text-gray-500 dark:text-gray-400">
              Ready to talk? Whether you need a quote, have questions, or need emergency help — reach out and we'll respond fast.
            </p>
            <dl class="mt-10 space-y-4 text-base/7 text-gray-600 dark:text-gray-300">
              <div class="flex gap-x-4">
                <dt class="flex-none">
                  <span class="sr-only">Telephone</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-6 text-gray-500 dark:text-gray-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                  </svg>
                </dt>
                <dd>
                  <a href={`tel:${cityData.phone}`} class="hover:text-gray-900 dark:hover:text-white">
                    {cityData.phone}
                  </a>
                </dd>
              </div>
              <div class="flex gap-x-4">
                <dt class="flex-none">
                  <span class="sr-only">Email</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-6 text-gray-500 dark:text-gray-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                </dt>
                <dd>
                  <a href="mailto:info@flood.doctor" class="hover:text-gray-900 dark:hover:text-white">
                    info@flood.doctor
                  </a>
                </dd>
              </div>
            </dl>
          </div>
        </div>
        <ContactForm client:load />
      </div>
    </div>
  </main>
</BaseLayout>
