---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { guideArticles, guidesList } from '../../../data/guides'
import { cityData } from '../../../data/cities'
import { toTelHref } from '../../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)

export function getStaticPaths() {
  return Object.keys(guideArticles).map((slug) => ({
    params: { slug },
    props: { guide: guideArticles[slug] },
  }))
}

const { guide } = Astro.props
const sanitizeCopy = (value: string) => value
  .replace(/within\s+60 minutes/gi, 'as quickly as possible')
  .replace(/60[\s-]minute/gi, 'prompt')
  .replace(/60 minutes/gi, 'the first few minutes')
  .replace(/IICRC-certified/gi, 'trained')
  .replace(/IICRC/g, 'industry')
  .replace(/direct\s+billing/gi, 'claim documentation support')
  .replace(/all\s+major\s+carriers/gi, 'insurance adjusters')
  .replace(/Free[ \t]+Estimate/g, 'Request Service')

const safeGuide = {
  ...guide,
  heroImage: '/graphics/water-emergency-pattern.svg',
  subtitle: sanitizeCopy(guide.subtitle),
  content: sanitizeCopy(guide.content),
}
const otherGuides = guidesList
  .filter((g) => g.slug !== guide.slug)
  .map((g) => ({ ...g, heroImage: '/graphics/water-emergency-pattern.svg', subtitle: sanitizeCopy(g.subtitle) }))
---

<BaseLayout
  title={`${safeGuide.title} | Flood Doctor ${cityData.name}`}
  description={safeGuide.subtitle}
>
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-12 gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        <!-- Guide content -->
        <div class="lg:col-span-2">
          <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">{safeGuide.title}</h1>
          <p class="mt-4 text-lg text-gray-300">{safeGuide.subtitle}</p>

          <div class="relative mt-10">
            <img alt="" src={safeGuide.heroImage} class="aspect-video w-full rounded-2xl bg-gray-800 object-cover" />
            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/10"></div>
          </div>

          <div
            class="prose prose-invert prose-lg mt-12 max-w-none prose-headings:text-white prose-p:text-gray-300 prose-a:text-indigo-400 prose-blockquote:border-indigo-500 prose-blockquote:text-gray-300 prose-strong:text-white prose-li:text-gray-300"
            set:html={safeGuide.content}
          />
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10">
            <h3 class="text-lg font-semibold text-white">Need Immediate Help?</h3>
            <p class="mt-2 text-sm text-gray-400">
              Our emergency team is available 24/7. Don't wait — water damage gets worse every hour.
            </p>
            <a
              href={cityPhoneHref}
              class="mt-6 block w-full rounded-md bg-indigo-500 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-indigo-400"
            >
              Call {cityData.phone}
            </a>
            <a
              href="/request"
              class="mt-3 block w-full rounded-md bg-white/10 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-white/20"
            >
              Request Emergency Service
            </a>
          </div>

          <div class="mt-10">
            <h3 class="text-lg font-semibold text-white">More Guides</h3>
            <div class="mt-6 space-y-6">
              {otherGuides.map((other) => (
                <article class="relative">
                  <h4 class="text-sm font-semibold text-white">
                    <a href={`/resources/homeowner-guides/${other.slug}`}>
                      <span class="absolute inset-0"></span>
                      {other.title}
                    </a>
                  </h4>
                  <p class="mt-1 line-clamp-2 text-xs text-gray-400">{other.subtitle}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
