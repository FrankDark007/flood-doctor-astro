---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { cityData } from '../../data/cities'
import { breadcrumbSchema, cityBaseUrl } from '../../utils/schema'
import { toTelHref } from '../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)
const _base = cityBaseUrl()

const resources = [
  {
    title: 'FAQ',
    description: 'Straight answers about water damage restoration, mold concerns, documentation, insurance conversations, and service intake.',
    href: '/resources/faq',
  },
  {
    title: 'Homeowner Guides',
    description: 'Long-form guides for preparation, response, cleanup decisions, and recovery after water enters the property.',
    href: '/resources/homeowner-guides',
  },
  {
    title: 'Insurance Claims Guide',
    description: 'Practical documentation and claim-process guidance for water damage events.',
    href: '/resources/insurance-guide',
  },
  {
    title: 'Emergency Checklists',
    description: 'Field-ready checklists for active water damage, storm preparation, post-flood safety, and emergency kits.',
    href: '/resources/emergency-checklists',
  },
  {
    title: 'Blog',
    description: 'Editorial advice on prevention, drying decisions, cleanup timing, and protecting a home after water damage.',
    href: '/blog',
  },
]

const structuredData = breadcrumbSchema([
  { name: 'Home', url: `${_base}/` },
  { name: 'Resources', url: `${_base}/resources/` },
])
---

<BaseLayout
  title={`Resources | Flood Doctor ${cityData.name}`}
  description={`Water damage resources for ${cityData.name} homeowners. FAQs, guides, insurance help, emergency checklists, and expert advice from Flood Doctor.`}
  structuredData={structuredData}
>
  <div class="content-page">
    <section class="hero" aria-labelledby="resources-title">
      <div class="page-shell hero-grid">
        <div>
          <p class="eyebrow">Resources</p>
          <h1 id="resources-title">Water Damage Guidance Before Decisions Get Expensive</h1>
          <p class="hero-lede">
            Helpful guides, checklists, and FAQ answers for the first hours after a leak, storm, overflow, or wet basement.
            Use these resources to get oriented, then call if conditions are urgent.
          </p>
          <div class="button-row">
            <a class="button button-primary" href="/request">Request Emergency Service</a>
            <a class="button button-secondary" href={cityPhoneHref}>Call {cityData.phone}</a>
          </div>
        </div>
        <aside class="hero-card">
          <p class="eyebrow">Start Here</p>
          <h2>Active water?</h2>
          <p>If water is still entering or safety is uncertain, stop reading and call the emergency line first.</p>
        </aside>
      </div>
    </section>

    <section class="section soft" aria-labelledby="resource-library-title">
      <div class="page-shell">
        <div class="section-heading">
          <p class="eyebrow dark">Resource Library</p>
          <h2 id="resource-library-title">Choose the guide that matches the moment</h2>
          <p class="section-lede">Short answers for urgent decisions, longer reads for planning, and checklists you can keep handy.</p>
        </div>
        <div class="card-grid">
          {resources.map((resource) => (
            <a href={resource.href} class="card card-link">
              <h3>{resource.title}</h3>
              <p>{resource.description}</p>
              <span class="text-link">Open resource <span aria-hidden="true">&rarr;</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section navy" aria-labelledby="resource-cta-title">
      <div class="page-shell split-grid">
        <div>
          <p class="eyebrow">Need Immediate Help?</p>
          <h2 id="resource-cta-title">Use the emergency path when damage is active</h2>
          <p class="section-lede">Guides are useful, but they do not replace live intake when water is moving through the property.</p>
        </div>
        <div class="navy-card">
          <div class="button-row">
            <a class="button button-primary" href="/request">Request Emergency Service</a>
            <a class="button button-secondary" href={cityPhoneHref}>Call {cityData.phone}</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>


<style>
  :global(html) {
    overflow-x: hidden;
  }

  .content-page {
    --fd-blue: #1a73e8;
    --fd-blue-dark: #0f4fb8;
    --fd-navy: #071a33;
    --fd-navy-2: #0b1f3a;
    --fd-ink: #102033;
    --fd-muted: #53647a;
    --fd-soft: #eef6ff;
    --fd-soft-2: #f7fbff;
    --fd-orange: #c2410c;
    --fd-orange-dark: #9a3412;
    --fd-line: #d9e6f5;
    --fd-white: #ffffff;
    width: 100%;
    overflow-x: clip;
    background: linear-gradient(180deg, #f7fbff 0%, #ffffff 34%, #eef6ff 100%);
    color: var(--fd-ink);
    font-family: 'Avenir Next', 'Trebuchet MS', Verdana, sans-serif;
  }

  .page-shell {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 18%, rgba(26, 115, 232, 0.38), transparent 34rem),
      radial-gradient(circle at 16% 100%, rgba(194, 65, 12, 0.22), transparent 30rem),
      linear-gradient(135deg, var(--fd-navy), var(--fd-navy-2));
    color: white;
    padding: clamp(4.5rem, 9vw, 7rem) 0;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.12;
    background-image: url('/graphics/water-emergency-pattern.svg');
    background-size: 420px 420px;
    mix-blend-mode: screen;
  }

  .hero-grid,
  .split-grid,
  .article-grid,
  .contact-grid,
  .request-grid,
  .legal-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 0.8fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .eyebrow {
    margin: 0 0 0.85rem;
    color: #fed7aa;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .eyebrow.dark {
    color: var(--fd-orange-dark);
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    color: white;
    font-size: clamp(2.65rem, 7vw, 5.4rem);
    font-weight: 900;
    letter-spacing: -0.07em;
    line-height: 0.95;
    text-wrap: balance;
  }

  h2 {
    margin: 0;
    color: var(--fd-navy);
    font-size: clamp(1.95rem, 4vw, 3.1rem);
    font-weight: 880;
    letter-spacing: -0.052em;
    line-height: 1;
  }

  h3 {
    margin: 0;
    color: var(--fd-navy);
    font-size: 1.08rem;
    font-weight: 830;
    letter-spacing: -0.025em;
    line-height: 1.25;
  }

  .hero-lede,
  .section-lede {
    margin: 1.25rem 0 0;
    max-width: 44rem;
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 560;
    line-height: 1.75;
  }

  .hero-lede {
    color: #d7e5f7;
  }

  .section-lede,
  .card p,
  .side-card p,
  .check-card li,
  .legal-copy p,
  .article-card p {
    color: var(--fd-muted);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    margin-top: 1.75rem;
  }

  .button {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.82rem 1.18rem;
    font-size: 0.94rem;
    font-weight: 850;
    line-height: 1.15;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button:focus-visible,
  .text-link:focus-visible,
  .card-link:focus-visible {
    outline: 3px solid rgba(26, 115, 232, 0.45);
    outline-offset: 3px;
  }

  .button-primary {
    background: var(--fd-orange);
    color: white;
    box-shadow: 0 16px 30px rgba(249, 115, 22, 0.24);
  }

  .button-primary:hover {
    background: var(--fd-orange-dark);
  }

  .button-secondary {
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.08);
    color: white;
  }

  .button-light {
    border: 1px solid rgba(11, 31, 58, 0.16);
    background: white;
    color: var(--fd-navy);
    box-shadow: 0 12px 28px rgba(15, 79, 184, 0.12);
  }

  .section {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
  }

  .section.soft {
    background: linear-gradient(180deg, var(--fd-soft-2), #ffffff);
  }

  .section.navy {
    background: var(--fd-navy);
    color: white;
  }

  .section.navy h2,
  .section.navy h3 {
    color: white;
  }

  .section.navy .section-lede,
  .section.navy p {
    color: #c9d7e8;
  }

  .section-heading {
    max-width: 48rem;
  }

  .section-heading.center {
    margin-inline: auto;
    text-align: center;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .card-grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card-grid.four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card,
  .side-card,
  .form-panel,
  .check-card,
  .article-card,
  .legal-copy,
  .review-placeholder {
    min-width: 0;
    border: 1px solid var(--fd-line);
    border-radius: 1.35rem;
    background: white;
    box-shadow: 0 12px 34px rgba(11, 31, 58, 0.07);
  }

  .card,
  .side-card,
  .check-card,
  .article-card,
  .legal-copy,
  .review-placeholder {
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .card p,
  .side-card p,
  .article-card p {
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.4rem;
  }

  .pill {
    border: 1px solid rgba(217, 230, 245, 0.82);
    border-radius: 999px;
    background: white;
    color: var(--fd-navy);
    padding: 0.52rem 0.75rem;
    font-size: 0.86rem;
    font-weight: 780;
  }

  .hero-card,
  .navy-card {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 1.5rem;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.055));
    padding: clamp(1.25rem, 4vw, 2rem);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  .hero-card h2,
  .hero-card h3,
  .navy-card h2,
  .navy-card h3 {
    color: white;
  }

  .hero-card p,
  .hero-card li,
  .navy-card p,
  .navy-card li {
    color: #d7e5f7;
  }

  .number-list,
  .clean-list,
  .columns-list {
    display: grid;
    gap: 0.85rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .columns-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .number-list li,
  .clean-list li,
  .columns-list li {
    position: relative;
    padding-left: 1.7rem;
    line-height: 1.55;
  }

  .number-list li::before,
  .clean-list li::before,
  .columns-list li::before {
    content: '';
    position: absolute;
    top: 0.58rem;
    left: 0;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--fd-orange);
  }

  .text-link,
  .card-link {
    color: var(--fd-blue-dark);
    font-weight: 850;
    text-decoration: none;
  }

  .prose-wrap :global(h2) {
    margin-top: 2.6rem;
    color: var(--fd-navy);
    font-size: clamp(1.65rem, 3vw, 2.2rem);
    letter-spacing: -0.04em;
  }

  .prose-wrap :global(h2:first-child) {
    margin-top: 0;
  }

  .prose-wrap :global(p),
  .prose-wrap :global(li) {
    color: var(--fd-muted);
    line-height: 1.78;
  }

  .prose-wrap :global(a) {
    color: var(--fd-blue-dark);
    font-weight: 800;
  }

  .prose-wrap :global(strong) {
    color: var(--fd-navy);
  }

  .prose-wrap :global(blockquote) {
    margin: 2rem 0;
    border-left: 4px solid var(--fd-orange);
    border-radius: 1rem;
    background: var(--fd-soft);
    padding: 1rem 1.25rem;
  }

  .visual-card {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 1.6rem;
    background: rgba(255, 255, 255, 0.08);
  }

  .visual-card img {
    display: block;
    width: 100%;
    height: auto;
  }

  .resource-browser,
  .dark-island {
    border-radius: 1.5rem;
    background: var(--fd-navy);
    padding: clamp(1rem, 3vw, 2rem);
    box-shadow: 0 24px 70px rgba(11, 31, 58, 0.16);
  }

  .form-panel {
    overflow: hidden;
    background: var(--fd-navy);
  }

  .form-panel :global(form) {
    padding: clamp(1.25rem, 4vw, 2rem) !important;
  }

  .form-panel :global(label),
  .form-panel :global(h3),
  .form-panel :global(button) {
    color: white;
  }

  .form-panel :global(button[type='submit']) {
    border-radius: 999px;
    background: var(--fd-orange);
  }

  .form-panel :global(button[type='submit']:hover) {
    background: var(--fd-orange-dark);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    margin-bottom: 1.25rem;
    color: #d7e5f7;
    font-size: 0.9rem;
  }

  .meta-pill {
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    padding: 0.4rem 0.7rem;
    color: white;
    font-weight: 780;
  }

  .article-image {
    overflow: hidden;
    margin-top: 2rem;
    border-radius: 1.35rem;
    background: var(--fd-soft);
  }

  .article-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 920px) {
    .hero-grid,
    .split-grid,
    .article-grid,
    .contact-grid,
    .request-grid,
    .legal-grid {
      grid-template-columns: 1fr;
    }

    .card-grid,
    .card-grid.four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .page-shell {
      width: min(100% - 1.25rem, 1120px);
    }

    .hero {
      padding: 4.5rem 0 4rem;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(2.2rem, 11vw, 3rem);
      letter-spacing: -0.052em;
      line-height: 0.99;
    }

    h2 {
      font-size: clamp(1.8rem, 9vw, 2.35rem);
    }

    .button-row {
      align-items: stretch;
      flex-direction: column;
    }

    .button {
      width: 100%;
      text-align: center;
    }

    .card-grid,
    .card-grid.two,
    .card-grid.four,
    .columns-list {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .button {
      transition: none;
    }

    .button:hover {
      transform: none;
    }
  }
</style>
