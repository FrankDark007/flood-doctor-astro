---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { cityData } from '../../data/cities'
import { toTelHref } from '../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)

const resources = [
  {
    title: 'FAQ',
    description: 'Answers to common questions about water damage restoration, mold remediation, insurance claims, and our services.',
    href: '/resources/faq',
  },
  {
    title: 'Homeowner Guides',
    description: 'In-depth guides to help you prepare for, respond to, and recover from water damage in your home.',
    href: '/resources/homeowner-guides',
  },
  {
    title: 'Insurance Claims Guide',
    description: 'Step-by-step guidance for filing water damage insurance claims and maximizing your coverage.',
    href: '/resources/insurance-guide',
  },
  {
    title: 'Emergency Checklists',
    description: 'Printable checklists for immediate response, storm preparation, post-flood safety, and emergency kits.',
    href: '/resources/emergency-checklists',
  },
  {
    title: 'Blog',
    description: 'Tips, news, and expert insights on water damage prevention, restoration, and home maintenance.',
    href: '/blog',
  },
]
---

<BaseLayout
  title={`Resources | Flood Doctor ${cityData.name}`}
  description={`Water damage resources for ${cityData.name} homeowners. FAQs, guides, insurance help, emergency checklists, and expert advice from Flood Doctor.`}
>
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl">Resources</h1>
        <p class="mt-6 text-lg/8 text-gray-300">
          Everything you need to prepare for, respond to, and recover from water damage. Free guides, checklists, and expert advice.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-6 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {resources.map((resource) => (
          <a
            href={resource.href}
            class="group relative flex flex-col rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10 transition hover:bg-white/10"
          >
            <h2 class="text-lg font-semibold text-white group-hover:text-indigo-400">{resource.title}</h2>
            <p class="mt-3 grow text-sm/6 text-gray-400">{resource.description}</p>
            <span class="mt-6 text-sm font-semibold text-indigo-400 group-hover:text-indigo-300">
              Learn more <span aria-hidden="true">&rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl rounded-2xl bg-white/5 p-8 text-center outline-1 -outline-offset-1 outline-white/10 sm:p-12">
        <h2 class="text-2xl font-semibold text-white">Need immediate help?</h2>
        <p class="mt-4 text-gray-400">Our emergency team is available 24/7 and prioritizes urgent water damage calls.</p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href="/request"
            class="rounded-md bg-indigo-500 px-6 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-400"
          >
            Request Emergency Service
          </a>
          <a
            href={cityPhoneHref}
            class="rounded-md bg-white/10 px-6 py-2.5 text-sm font-semibold text-white hover:bg-white/20"
          >
            Call {cityData.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
