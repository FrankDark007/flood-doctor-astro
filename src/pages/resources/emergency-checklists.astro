---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { cityData } from '../../data/cities'
import { breadcrumbSchema, cityBaseUrl } from '../../utils/schema'
import { toTelHref } from '../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)
const _base = cityBaseUrl()

const checklists = [
  {
    title: 'When Water Damage Strikes',
    subtitle: 'Immediate first steps',
    items: [
      'Ensure personal safety — do not enter standing water near electrical outlets or appliances',
      'Shut off the water supply at the main valve if the source is plumbing-related',
      'Turn off electricity to affected areas at the breaker panel only if safe to access',
      'Call Flood Doctor for emergency intake and mitigation planning',
      'Contact your insurance company to start a claim',
      'Take photos and video of damage before moving items if it is safe',
      'Move valuable items and furniture away from standing water if safe',
      'Open windows and doors for ventilation if weather permits',
      'Place aluminum foil under furniture legs to reduce staining on wet carpet',
      'Do not use a household vacuum to remove water',
    ],
  },
  {
    title: 'Before the Storm',
    subtitle: 'Preparation checklist for severe weather',
    items: [
      'Clear gutters and downspouts of debris to support drainage',
      'Check sump pump operation by pouring water in the pit to test it',
      'Install or test a battery backup for the sump pump',
      'Inspect and seal visible foundation cracks when appropriate',
      'Move valuables and important documents to upper floors or waterproof containers',
      'Know the location of your main water shut-off valve',
      'Know the location of your electrical panel',
      'Photograph your home and belongings before damage occurs',
      'Review your insurance policy and flood coverage details',
      'Stock emergency supplies: flashlights, batteries, first aid kit, bottled water',
    ],
  },
  {
    title: 'Post-Flood Safety',
    subtitle: 'What to do after flooding subsides',
    items: [
      'Do not re-enter your home until authorities confirm it is safe',
      'Wear protective gear: rubber boots, gloves, and an N95 mask',
      'Check for sagging ceilings, warped walls, or shifted foundations',
      'Do not turn on electricity until the system has been inspected if flooding was significant',
      'Do not use tap water until it has been declared safe by local authorities',
      'Document all damage with photos and video for your insurance claim',
      'Remove standing water as quickly as practical to limit secondary damage',
      'Discard food, medicine, and cosmetics that contacted floodwater',
      'Open windows and use fans only after standing water is removed and power is safe',
      'Watch for musty odors, discoloration, and other moisture concerns in the following days',
    ],
  },
  {
    title: 'Emergency Kit Essentials',
    subtitle: 'Keep these items ready and accessible',
    items: [
      'Flashlights and extra batteries',
      'First aid kit with essential medications',
      'Bottled water — one gallon per person per day for at least three days',
      'Non-perishable food and a manual can opener',
      'Battery-powered or hand-crank radio',
      'Portable phone charger',
      'Important documents in a waterproof container',
      'Cash in small bills',
      'N95 masks and rubber gloves',
      'Garbage bags and plastic sheeting',
      'Duct tape and basic tools',
      'Whistle to signal for help',
    ],
  },
]

const structuredData = breadcrumbSchema([
  { name: 'Home', url: `${_base}/` },
  { name: 'Resources', url: `${_base}/resources/` },
  { name: 'Emergency Checklists', url: `${_base}/resources/emergency-checklists/` },
])
---

<BaseLayout
  title={`Emergency Checklists | Flood Doctor ${cityData.name}`}
  description={`Emergency water damage checklists for ${cityData.name} homeowners. Immediate response, storm prep, post-flood safety, and emergency kit essentials.`}
  structuredData={structuredData}
>
  <div class="content-page">
    <section class="hero" aria-labelledby="checklists-title">
      <div class="page-shell hero-grid">
        <div>
          <p class="eyebrow">Emergency Checklists</p>
          <h1 id="checklists-title">Clear Steps for High-Stress Water Events</h1>
          <p class="hero-lede">Use these checklists to reduce confusion before, during, and after a water emergency.</p>
          <div class="button-row">
            <a class="button button-primary" href="/request">Request Emergency Service</a>
            <a class="button button-secondary" href={cityPhoneHref}>Call {cityData.phone}</a>
          </div>
        </div>
        <aside class="hero-card">
          <p class="eyebrow">Safety First</p>
          <h2>If in doubt, stay out</h2>
          <p>A checklist cannot make an unsafe room safe. Avoid standing water around electricity and call for live guidance.</p>
        </aside>
      </div>
    </section>

    <section class="section soft" aria-labelledby="checklist-library-title">
      <div class="page-shell">
        <div class="section-heading">
          <p class="eyebrow dark">Printable Rhythm</p>
          <h2 id="checklist-library-title">Four checklists for different phases</h2>
        </div>
        <div class="card-grid two">
          {checklists.map((checklist) => (
            <section class="check-card">
              <h3>{checklist.title}</h3>
              <p>{checklist.subtitle}</p>
              <ul class="clean-list">
                {checklist.items.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>


<style>
  :global(html) {
    overflow-x: hidden;
  }

  .content-page {
    --fd-blue: #1a73e8;
    --fd-blue-dark: #0f4fb8;
    --fd-navy: #071a33;
    --fd-navy-2: #0b1f3a;
    --fd-ink: #102033;
    --fd-muted: #53647a;
    --fd-soft: #eef6ff;
    --fd-soft-2: #f7fbff;
    --fd-orange: #c2410c;
    --fd-orange-dark: #9a3412;
    --fd-line: #d9e6f5;
    --fd-white: #ffffff;
    width: 100%;
    overflow-x: clip;
    background: linear-gradient(180deg, #f7fbff 0%, #ffffff 34%, #eef6ff 100%);
    color: var(--fd-ink);
    font-family: 'Avenir Next', 'Trebuchet MS', Verdana, sans-serif;
  }

  .page-shell {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 18%, rgba(26, 115, 232, 0.38), transparent 34rem),
      radial-gradient(circle at 16% 100%, rgba(194, 65, 12, 0.22), transparent 30rem),
      linear-gradient(135deg, var(--fd-navy), var(--fd-navy-2));
    color: white;
    padding: clamp(4.5rem, 9vw, 7rem) 0;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.12;
    background-image: url('/graphics/water-emergency-pattern.svg');
    background-size: 420px 420px;
    mix-blend-mode: screen;
  }

  .hero-grid,
  .split-grid,
  .article-grid,
  .contact-grid,
  .request-grid,
  .legal-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 0.8fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .eyebrow {
    margin: 0 0 0.85rem;
    color: #fed7aa;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .eyebrow.dark {
    color: var(--fd-orange-dark);
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    color: white;
    font-size: clamp(2.65rem, 7vw, 5.4rem);
    font-weight: 900;
    letter-spacing: -0.07em;
    line-height: 0.95;
    text-wrap: balance;
  }

  h2 {
    margin: 0;
    color: var(--fd-navy);
    font-size: clamp(1.95rem, 4vw, 3.1rem);
    font-weight: 880;
    letter-spacing: -0.052em;
    line-height: 1;
  }

  h3 {
    margin: 0;
    color: var(--fd-navy);
    font-size: 1.08rem;
    font-weight: 830;
    letter-spacing: -0.025em;
    line-height: 1.25;
  }

  .hero-lede,
  .section-lede {
    margin: 1.25rem 0 0;
    max-width: 44rem;
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 560;
    line-height: 1.75;
  }

  .hero-lede {
    color: #d7e5f7;
  }

  .section-lede,
  .card p,
  .side-card p,
  .check-card li,
  .legal-copy p,
  .article-card p {
    color: var(--fd-muted);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    margin-top: 1.75rem;
  }

  .button {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.82rem 1.18rem;
    font-size: 0.94rem;
    font-weight: 850;
    line-height: 1.15;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button:focus-visible,
  .text-link:focus-visible,
  .card-link:focus-visible {
    outline: 3px solid rgba(26, 115, 232, 0.45);
    outline-offset: 3px;
  }

  .button-primary {
    background: var(--fd-orange);
    color: white;
    box-shadow: 0 16px 30px rgba(249, 115, 22, 0.24);
  }

  .button-primary:hover {
    background: var(--fd-orange-dark);
  }

  .button-secondary {
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.08);
    color: white;
  }

  .button-light {
    border: 1px solid rgba(11, 31, 58, 0.16);
    background: white;
    color: var(--fd-navy);
    box-shadow: 0 12px 28px rgba(15, 79, 184, 0.12);
  }

  .section {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
  }

  .section.soft {
    background: linear-gradient(180deg, var(--fd-soft-2), #ffffff);
  }

  .section.navy {
    background: var(--fd-navy);
    color: white;
  }

  .section.navy h2,
  .section.navy h3 {
    color: white;
  }

  .section.navy .section-lede,
  .section.navy p {
    color: #c9d7e8;
  }

  .section-heading {
    max-width: 48rem;
  }

  .section-heading.center {
    margin-inline: auto;
    text-align: center;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .card-grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card-grid.four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card,
  .side-card,
  .form-panel,
  .check-card,
  .article-card,
  .legal-copy,
  .review-placeholder {
    min-width: 0;
    border: 1px solid var(--fd-line);
    border-radius: 1.35rem;
    background: white;
    box-shadow: 0 12px 34px rgba(11, 31, 58, 0.07);
  }

  .card,
  .side-card,
  .check-card,
  .article-card,
  .legal-copy,
  .review-placeholder {
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .card p,
  .side-card p,
  .article-card p {
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.4rem;
  }

  .pill {
    border: 1px solid rgba(217, 230, 245, 0.82);
    border-radius: 999px;
    background: white;
    color: var(--fd-navy);
    padding: 0.52rem 0.75rem;
    font-size: 0.86rem;
    font-weight: 780;
  }

  .hero-card,
  .navy-card {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 1.5rem;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.055));
    padding: clamp(1.25rem, 4vw, 2rem);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  .hero-card h2,
  .hero-card h3,
  .navy-card h2,
  .navy-card h3 {
    color: white;
  }

  .hero-card p,
  .hero-card li,
  .navy-card p,
  .navy-card li {
    color: #d7e5f7;
  }

  .number-list,
  .clean-list,
  .columns-list {
    display: grid;
    gap: 0.85rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .columns-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .number-list li,
  .clean-list li,
  .columns-list li {
    position: relative;
    padding-left: 1.7rem;
    line-height: 1.55;
  }

  .number-list li::before,
  .clean-list li::before,
  .columns-list li::before {
    content: '';
    position: absolute;
    top: 0.58rem;
    left: 0;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--fd-orange);
  }

  .text-link,
  .card-link {
    color: var(--fd-blue-dark);
    font-weight: 850;
    text-decoration: none;
  }

  .prose-wrap :global(h2) {
    margin-top: 2.6rem;
    color: var(--fd-navy);
    font-size: clamp(1.65rem, 3vw, 2.2rem);
    letter-spacing: -0.04em;
  }

  .prose-wrap :global(h2:first-child) {
    margin-top: 0;
  }

  .prose-wrap :global(p),
  .prose-wrap :global(li) {
    color: var(--fd-muted);
    line-height: 1.78;
  }

  .prose-wrap :global(a) {
    color: var(--fd-blue-dark);
    font-weight: 800;
  }

  .prose-wrap :global(strong) {
    color: var(--fd-navy);
  }

  .prose-wrap :global(blockquote) {
    margin: 2rem 0;
    border-left: 4px solid var(--fd-orange);
    border-radius: 1rem;
    background: var(--fd-soft);
    padding: 1rem 1.25rem;
  }

  .visual-card {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 1.6rem;
    background: rgba(255, 255, 255, 0.08);
  }

  .visual-card img {
    display: block;
    width: 100%;
    height: auto;
  }

  .resource-browser,
  .dark-island {
    border-radius: 1.5rem;
    background: var(--fd-navy);
    padding: clamp(1rem, 3vw, 2rem);
    box-shadow: 0 24px 70px rgba(11, 31, 58, 0.16);
  }

  .form-panel {
    overflow: hidden;
    background: var(--fd-navy);
  }

  .form-panel :global(form) {
    padding: clamp(1.25rem, 4vw, 2rem) !important;
  }

  .form-panel :global(label),
  .form-panel :global(h3),
  .form-panel :global(button) {
    color: white;
  }

  .form-panel :global(button[type='submit']) {
    border-radius: 999px;
    background: var(--fd-orange);
  }

  .form-panel :global(button[type='submit']:hover) {
    background: var(--fd-orange-dark);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    margin-bottom: 1.25rem;
    color: #d7e5f7;
    font-size: 0.9rem;
  }

  .meta-pill {
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    padding: 0.4rem 0.7rem;
    color: white;
    font-weight: 780;
  }

  .article-image {
    overflow: hidden;
    margin-top: 2rem;
    border-radius: 1.35rem;
    background: var(--fd-soft);
  }

  .article-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 920px) {
    .hero-grid,
    .split-grid,
    .article-grid,
    .contact-grid,
    .request-grid,
    .legal-grid {
      grid-template-columns: 1fr;
    }

    .card-grid,
    .card-grid.four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .page-shell {
      width: min(100% - 1.25rem, 1120px);
    }

    .hero {
      padding: 4.5rem 0 4rem;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(2.2rem, 11vw, 3rem);
      letter-spacing: -0.052em;
      line-height: 0.99;
    }

    h2 {
      font-size: clamp(1.8rem, 9vw, 2.35rem);
    }

    .button-row {
      align-items: stretch;
      flex-direction: column;
    }

    .button {
      width: 100%;
      text-align: center;
    }

    .card-grid,
    .card-grid.two,
    .card-grid.four,
    .columns-list {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .button {
      transition: none;
    }

    .button:hover {
      transform: none;
    }
  }
</style>
