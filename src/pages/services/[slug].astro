---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Icon from '../../components/Icon.astro'
import FAQAccordion from '../../components/islands/FAQAccordion.tsx'
import { allServices, getService } from '../../data/services'
import { cityData } from '../../data/cities'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths: GetStaticPaths = () => {
  return allServices.map((service) => ({
    params: { slug: service.slug },
  }))
}

const { slug } = Astro.params
const service = getService(slug as string)

if (!service) {
  return Astro.redirect('/404')
}

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.name,
  description: service.description,
  provider: {
    '@type': 'LocalBusiness',
    name: `Flood Doctor ${cityData.name}`,
    telephone: cityData.phone,
    address: {
      '@type': 'PostalAddress',
      addressLocality: cityData.name,
      addressRegion: cityData.state,
    },
  },
  areaServed: {
    '@type': 'City',
    name: cityData.name,
  },
}

const blogPosts = [
  {
    title: 'How to Handle Water Damage Before Help Arrives',
    href: '/blog/water-damage-first-steps',
    description: 'Quick actions you can take to minimize damage while waiting for professional restoration services to arrive at your property.',
    imageUrl: 'https://images.unsplash.com/photo-1496128858413-b36217c2ce36?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=3603&q=80',
    date: 'Jan 15, 2026',
    datetime: '2026-01-15',
    category: 'Emergency Tips',
  },
  {
    title: 'Understanding Your Water Damage Insurance Claim',
    href: '/blog/insurance-claim-guide',
    description: 'A step-by-step guide to filing and maximizing your water damage insurance claim with documentation tips from our certified estimators.',
    imageUrl: 'https://images.unsplash.com/photo-1547586696-ea22b4d4235d?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=3270&q=80',
    date: 'Jan 8, 2026',
    datetime: '2026-01-08',
    category: 'Insurance',
  },
  {
    title: 'Signs of Hidden Water Damage in Your Home',
    href: '/blog/hidden-water-damage-signs',
    description: 'Learn to spot the subtle warning signs of water damage that could be lurking behind your walls, under floors, or in your ceiling.',
    imageUrl: 'https://images.unsplash.com/photo-1492724441997-5dc865305da7?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=3270&q=80',
    date: 'Dec 20, 2025',
    datetime: '2025-12-20',
    category: 'Prevention',
  },
]

const timeline = [
  { name: 'Emergency Call', description: 'Call our 24/7 hotline. A certified technician is dispatched to your location within minutes.', date: 'Step 1' },
  { name: 'Inspection & Assessment', description: 'Thorough moisture mapping with thermal imaging and hygrometers to document the full extent of damage.', date: 'Step 2' },
  { name: 'Water Extraction & Drying', description: 'Industrial-grade extraction followed by strategic dehumidifier and air mover placement for optimal drying.', date: 'Step 3' },
  { name: 'Restoration & Rebuild', description: 'Complete repair of damaged structures, flooring, and finishes to return your property to pre-loss condition.', date: 'Step 4' },
]
---

<BaseLayout
  title={service.name}
  description={service.description}
  structuredData={structuredData}
>
  <!-- ═══ HERO ═══ -->
  <div class="relative isolate overflow-hidden bg-white dark:bg-gray-900">
    <svg
      aria-hidden="true"
      class="absolute inset-x-0 top-0 -z-10 h-[64rem] w-full mask-[radial-gradient(32rem_32rem_at_center,white,transparent)] stroke-gray-200 dark:stroke-white/10"
    >
      <defs>
        <pattern
          x="50%"
          y="-1"
          id="service-hero-pattern"
          width="200"
          height="200"
          patternUnits="userSpaceOnUse"
        >
          <path d="M.5 200V.5H200" fill="none" />
        </pattern>
      </defs>
      <rect fill="url(#service-hero-pattern)" width="100%" height="100%" stroke-width="0" />
    </svg>
    <div
      aria-hidden="true"
      class="absolute top-0 right-0 left-1/2 -z-10 -ml-24 transform-gpu overflow-hidden blur-3xl lg:ml-24 xl:ml-48"
    >
      <div
        style="clip-path: polygon(63.1% 29.5%, 100% 17.1%, 76.6% 3%, 48.4% 0%, 44.6% 4.7%, 54.5% 25.3%, 59.8% 49%, 55.2% 57.8%, 44.4% 57.2%, 27.8% 47.9%, 35.1% 81.5%, 0% 97.7%, 39.2% 100%, 35.2% 81.4%, 97.2% 52.8%, 63.1% 29.5%)"
        class="aspect-[801/1036] w-[50.0625rem] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 dark:opacity-30"
      ></div>
    </div>
    <div class="mx-auto max-w-7xl px-6 pt-36 pb-24 sm:pt-60 sm:pb-32 lg:flex lg:items-center lg:gap-x-10 lg:px-8 lg:pt-40 lg:pb-40">
      <div class="mx-auto max-w-2xl lg:mx-0 lg:flex-auto">
        <h1 class="mt-10 text-5xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-7xl">
          {service.name}
        </h1>
        <p class="mt-8 text-lg font-medium text-pretty text-gray-600 dark:text-gray-400 sm:text-xl/8">
          {service.description}
        </p>
        <div class="mt-10 flex items-center gap-x-6">
          <a
            href="/request"
            class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"
          >
            Get a Free Estimate
          </a>
          <a href={`tel:${cityData.phone.replace(/[^0-9+]/g, '')}`} class="text-sm/6 font-semibold text-gray-900 dark:text-white">
            Call Now <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
      <div class="mt-16 sm:mt-24 lg:mt-0 lg:shrink-0 lg:grow">
        <div class="mx-auto w-full max-w-lg lg:max-w-none">
          <img
            alt={service.name}
            src={service.heroImageUrl}
            class="w-full rounded-2xl object-cover shadow-xl ring-1 ring-gray-200 dark:ring-white/10 lg:aspect-[3/2] lg:max-w-xl"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ LOGO CLOUD ═══ -->
  <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 class="text-center text-lg/8 font-semibold text-gray-900 dark:text-white">Certified & Trusted by Industry Leaders</h2>
      <div class="mx-auto mt-10 grid max-w-lg grid-cols-4 items-center gap-x-8 gap-y-10 sm:max-w-xl sm:grid-cols-6 sm:gap-x-10 lg:mx-0 lg:max-w-none lg:grid-cols-5">
        {service.logos.slice(0, 5).map((logo, i) => (
          <img
            alt={logo.name}
            src={logo.src}
            width="158"
            height="48"
            class:list={[
              'col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0',
              i === 3 && 'sm:col-start-2',
              i === 4 && 'col-start-2 sm:col-start-auto',
              i < 3 ? '' : '',
              `lg:col-span-1`,
            ]}
          />
        ))}
      </div>
    </div>
  </div>

  <!-- ═══ FEATURES ═══ -->
  <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">What's included</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
          {service.name}
        </p>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
          {service.tagline}
        </p>
      </div>
      <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 text-base/7 text-gray-600 dark:text-gray-400 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 lg:gap-x-16">
        {service.features.map((feature) => (
          <div class="relative pl-9">
            <dt class="inline font-semibold text-gray-900 dark:text-white">
              <Icon name={feature.icon} class="absolute top-1 left-1 size-5 text-indigo-600 dark:text-indigo-500" />
              {feature.name}
            </dt>{' '}
            <dd class="inline">{feature.description}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- ═══ CONTENT (sticky image) ═══ -->
  <div class="relative isolate overflow-hidden bg-white dark:bg-gray-900 px-6 py-24 sm:py-32 lg:overflow-visible lg:px-0">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <svg
        aria-hidden="true"
        class="absolute top-0 left-[max(50%,25rem)] h-[64rem] w-[128rem] -translate-x-1/2 mask-[radial-gradient(64rem_64rem_at_top,white,transparent)] stroke-gray-200 dark:stroke-gray-800"
      >
        <defs>
          <pattern x="50%" y="-1" id="content-pattern" width="200" height="200" patternUnits="userSpaceOnUse">
            <path d="M100 200V.5M.5 .5H200" fill="none" />
          </pattern>
        </defs>
        <svg x="50%" y="-1" class="overflow-visible fill-gray-100 dark:fill-gray-800/50">
          <path d="M-100.5 0h201v201h-201Z M699.5 0h201v201h-201Z M499.5 400h201v201h-201Z M-300.5 600h201v201h-201Z" stroke-width="0" />
        </svg>
        <rect fill="url(#content-pattern)" width="100%" height="100%" stroke-width="0" />
      </svg>
    </div>
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-start lg:gap-y-10">
      <div class="lg:col-span-2 lg:col-start-1 lg:row-start-1 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8">
        <div class="lg:pr-4">
          <div class="lg:max-w-lg">
            <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">In-depth</p>
            <h2 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
              How Our {service.name} Process Works
            </h2>
            <p class="mt-6 text-xl/8 text-gray-600 dark:text-gray-300">
              {service.contentParagraphs[0]}
            </p>
          </div>
        </div>
      </div>
      <div class="-mt-12 -ml-12 p-12 lg:sticky lg:top-4 lg:col-start-2 lg:row-span-2 lg:row-start-1 lg:overflow-hidden">
        <img
          alt={service.name}
          src={service.heroImageUrl}
          class="w-[48rem] max-w-none rounded-xl bg-gray-100 dark:bg-gray-800 shadow-xl ring-1 ring-gray-200 dark:ring-white/10 sm:w-[57rem]"
        />
      </div>
      <div class="lg:col-span-2 lg:col-start-1 lg:row-start-2 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8">
        <div class="lg:pr-4">
          <div class="max-w-xl text-base/7 text-gray-600 dark:text-gray-400 lg:max-w-lg">
            {service.contentParagraphs.slice(1).map((paragraph, idx) => (
              <p class={idx > 0 ? 'mt-8' : ''}>{paragraph}</p>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ STATS / TIMELINE ═══ -->
  <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Our Process</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
          How We Restore Your Property
        </p>
      </div>
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 overflow-hidden lg:mx-0 lg:max-w-none lg:grid-cols-4">
        {timeline.map((item) => (
          <div>
            <div class="flex items-center text-sm/6 font-semibold text-indigo-600 dark:text-indigo-400">
              <svg viewBox="0 0 4 4" aria-hidden="true" class="mr-4 size-1 flex-none">
                <circle r="2" cx="2" cy="2" fill="currentColor" />
              </svg>
              {item.date}
              <div
                aria-hidden="true"
                class="absolute -ml-2 h-px w-screen -translate-x-full bg-gray-200 dark:bg-white/15 sm:-ml-4 lg:static lg:-mr-6 lg:ml-8 lg:w-auto lg:flex-auto lg:translate-x-0"
              ></div>
            </div>
            <p class="mt-6 text-lg/8 font-semibold tracking-tight text-gray-900 dark:text-white">{item.name}</p>
            <p class="mt-1 text-base/7 text-gray-600 dark:text-gray-400">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ═══ KEY METRICS ═══ -->
  <div class="relative isolate overflow-hidden bg-white dark:bg-gray-900 py-24 sm:py-32">
    <img
      alt=""
      src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=2850&q=80&blend=111827&blend-mode=multiply&sat=-100&exp=15"
      class="absolute inset-0 -z-10 size-full object-cover opacity-20 dark:opacity-100"
    />
    <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">
        <h2 class="text-base/8 font-semibold text-indigo-600 dark:text-indigo-400">Our track record</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
          Trusted by {cityData.name} Homeowners
        </p>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
          Our commitment to fast response, quality workmanship, and transparent communication has made us the preferred restoration company in {cityData.name} and surrounding areas.
        </p>
      </div>
      <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-10 text-gray-900 dark:text-white sm:mt-20 sm:grid-cols-2 sm:gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-4">
        {service.stats.map((stat) => (
          <div class="flex flex-col gap-y-3 border-l border-gray-200 dark:border-white/10 pl-6">
            <dt class="text-sm/6 text-gray-600 dark:text-white/80">{stat.label}</dt>
            <dd class="order-first text-3xl font-semibold tracking-tight">{stat.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- ═══ WORKFLOW / CTA ═══ -->
  <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">
        <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Why choose us</p>
        <h2 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
          Professional Restoration You Can Trust
        </h2>
        <div class="mt-10 grid max-w-xl grid-cols-1 gap-8 text-base/7 text-gray-600 dark:text-gray-300 lg:max-w-none lg:grid-cols-2">
          <div>
            <p>
              When disaster strikes, you need a team that responds fast and gets the job done right the first time.
              Our IICRC-certified technicians bring years of hands-on experience to every restoration project,
              using state-of-the-art equipment and proven techniques to minimize damage and accelerate recovery.
            </p>
            <p class="mt-8">
              We work directly with all major insurance carriers, handling the claims process from documentation
              to final payment so you can focus on what matters most — getting your life back to normal.
            </p>
          </div>
          <div>
            <p>
              Every property and every water damage event is unique. That's why we create a customized restoration
              plan for each project, tailored to the specific type of damage, affected materials, and your
              property's construction.
            </p>
            <p class="mt-8">
              From the initial emergency response through final reconstruction, you'll have a dedicated project
              manager as your single point of contact. We keep you informed at every step and ensure the work
              meets our rigorous quality standards before we consider any project complete.
            </p>
          </div>
        </div>
        <div class="mt-10 flex">
          <a
            href="/request"
            class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"
          >
            Get a Free Estimate
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ TESTIMONIAL ═══ -->
  <div class="bg-gray-50 dark:bg-gray-900 pt-24 pb-16 sm:pt-32 sm:pb-24 xl:pb-32">
    <div class="bg-white dark:bg-gray-800/50 pb-20 outline outline-gray-200 dark:outline-white/5 sm:pb-24 xl:pb-0">
      <div class="mx-auto flex max-w-7xl flex-col items-center gap-x-8 gap-y-10 px-6 sm:gap-y-8 lg:px-8 xl:flex-row xl:items-stretch">
        <div class="-mt-8 w-full max-w-2xl xl:-mb-8 xl:w-96 xl:flex-none">
          <div class="relative aspect-[2/1] h-full after:absolute after:inset-0 after:rounded-2xl after:ring-1 after:ring-inset after:ring-gray-200 dark:after:ring-white/15 md:-mx-8 xl:mx-0 xl:aspect-auto">
            <img
              alt={service.testimonial.author}
              src={service.testimonial.imageUrl}
              class="absolute inset-0 size-full rounded-2xl bg-gray-200 dark:bg-gray-700 object-cover"
            />
          </div>
        </div>
        <div class="w-full max-w-2xl xl:max-w-none xl:flex-auto xl:px-16 xl:py-24">
          <figure class="relative isolate pt-6 sm:pt-12">
            <svg
              fill="none"
              viewBox="0 0 162 128"
              aria-hidden="true"
              class="absolute top-0 left-0 -z-10 h-32 stroke-gray-300 dark:stroke-white/20"
            >
              <path
                d="M65.5697 118.507L65.8918 118.89C68.9503 116.314 71.367 113.253 73.1386 109.71C74.9162 106.155 75.8027 102.28 75.8027 98.0919C75.8027 94.237 75.16 90.6155 73.8708 87.2314C72.5851 83.8565 70.8137 80.9533 68.553 78.5292C66.4529 76.1079 63.9476 74.2482 61.0407 72.9536C58.2795 71.4949 55.276 70.767 52.0386 70.767C48.9935 70.767 46.4686 71.1668 44.4872 71.9924L44.4799 71.9955L44.4726 71.9988C42.7101 72.7999 41.1035 73.6831 39.6544 74.6492C38.2407 75.5916 36.8279 76.455 35.4159 77.2394L35.4047 77.2457L35.3938 77.2525C34.2318 77.9787 32.6713 78.3634 30.6736 78.3634C29.0405 78.3634 27.5131 77.2868 26.1274 74.8257C24.7483 72.2185 24.0519 69.2166 24.0519 65.8071C24.0519 60.0311 25.3782 54.4081 28.0373 48.9335C30.703 43.4454 34.3114 38.345 38.8667 33.6325C43.5812 28.761 49.0045 24.5159 55.1389 20.8979C60.1667 18.0071 65.4966 15.6179 71.1291 13.7305C73.8626 12.8145 75.8027 10.2968 75.8027 7.38572C75.8027 3.6497 72.6341 0.62247 68.8814 1.1527C61.1635 2.2432 53.7398 4.41426 46.6119 7.66522C37.5369 11.6459 29.5729 17.0612 22.7236 23.9105C16.0322 30.6019 10.618 38.4859 6.47981 47.558L6.47976 47.558L6.47682 47.5647C2.4901 56.6544 0.5 66.6148 0.5 77.4391C0.5 84.2996 1.61702 90.7679 3.85425 96.8404L3.8558 96.8445C6.08991 102.749 9.12394 108.02 12.959 112.654L12.959 112.654L12.9646 112.661C16.8027 117.138 21.2829 120.739 26.4034 123.459L26.4033 123.459L26.4144 123.465C31.5505 126.033 37.0873 127.316 43.0178 127.316C47.5035 127.316 51.6783 126.595 55.5376 125.148L55.5376 125.148L55.5477 125.144C59.5516 123.542 63.0052 121.456 65.9019 118.881L65.5697 118.507Z"
                id="testimonial-quote"
              />
              <use x="86" href="#testimonial-quote" />
            </svg>
            <blockquote class="text-xl/8 font-semibold text-gray-900 dark:text-gray-100 sm:text-2xl/9">
              <p>"{service.testimonial.quote}"</p>
            </blockquote>
            <figcaption class="mt-8 text-base">
              <div class="font-semibold text-gray-900 dark:text-gray-100">{service.testimonial.author}</div>
              <div class="mt-1 text-gray-500 dark:text-gray-400">{service.testimonial.role}</div>
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ BLOG PREVIEW ═══ -->
  <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-semibold tracking-tight text-balance text-gray-900 dark:text-white sm:text-5xl">From the blog</h2>
        <p class="mt-2 text-lg/8 text-gray-600 dark:text-gray-300">Tips and guides to help protect your property from water damage.</p>
      </div>
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {blogPosts.map((post) => (
          <article class="flex flex-col items-start justify-between">
            <div class="relative w-full">
              <img
                alt=""
                src={post.imageUrl}
                class="aspect-video w-full rounded-2xl bg-gray-100 dark:bg-gray-800 object-cover sm:aspect-[2/1] lg:aspect-[3/2]"
              />
              <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-gray-200 dark:ring-white/10" />
            </div>
            <div class="flex max-w-xl grow flex-col justify-between">
              <div class="mt-8 flex items-center gap-x-4 text-xs">
                <time datetime={post.datetime} class="text-gray-500 dark:text-gray-400">{post.date}</time>
                <span class="relative z-10 rounded-full bg-gray-100 dark:bg-gray-800/60 px-3 py-1.5 font-medium text-gray-700 dark:text-gray-300">
                  {post.category}
                </span>
              </div>
              <div class="group relative grow">
                <h3 class="mt-3 text-lg/6 font-semibold text-gray-900 dark:text-white group-hover:text-gray-600 dark:group-hover:text-gray-300">
                  <a href={post.href}>
                    <span class="absolute inset-0"></span>
                    {post.title}
                  </a>
                </h3>
                <p class="mt-5 line-clamp-3 text-sm/6 text-gray-600 dark:text-gray-400">{post.description}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- ═══ RELATED SERVICES ═══ -->
  <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-5">
        <div class="col-span-2">
          <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Everything you need</h2>
          <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
            Related Services
          </p>
          <p class="mt-6 text-base/7 text-gray-600 dark:text-gray-300">
            Our {service.name.toLowerCase()} work often pairs with these complementary services to deliver a complete restoration solution for your property.
          </p>
        </div>
        <dl class="col-span-3 grid grid-cols-1 gap-x-8 gap-y-10 text-base/7 text-gray-600 dark:text-gray-300 sm:grid-cols-2 lg:gap-y-16">
          {service.relatedFeatures.map((feature) => (
            <div class="relative pl-9">
              <dt class="font-semibold text-gray-900 dark:text-white">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="absolute top-1 left-0 h-5 w-5 text-indigo-600 dark:text-indigo-500">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                </svg>
                {feature.name}
              </dt>
              <dd class="mt-2">{feature.description}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>

  <!-- ═══ FAQ ═══ -->
  <div class="bg-white dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8 lg:py-40">
      <div class="mx-auto max-w-4xl">
        <h2 class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Frequently asked questions</h2>
        <FAQAccordion client:visible faqs={service.faqs} />
      </div>
    </div>
  </div>
</BaseLayout>
