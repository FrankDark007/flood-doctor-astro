---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Icon from '../../../components/Icon.astro'
import FAQAccordion from '../../../components/islands/FAQAccordion.tsx'
import { cityData } from '../../../data/cities'
import { getDivisionCategories, getCategoryServices, getNodeByPath } from '../../../data/services/service-tree'
import { getService } from '../../../data/services'
import { serviceSchema, faqPageSchema, breadcrumbSchema, cityBaseUrl } from '../../../utils/schema'
import { getCityServiceContent } from '../../../data/city-content'
import { blogPosts } from '../../../data/blog'
import type { GetStaticPaths } from 'astro'
import { toTelHref } from '../../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)

const safeText = (value = '') => String(value)
  .replace(/Free Estimate/g, 'Request Service')
  .replace(/free estimate/g, 'service request')
  .replace(/IICRC-Certified Technicians/g, 'Trained Restoration Crews')
  .replace(/IICRC-certified technicians/g, 'restoration technicians')
  .replace(/IICRC-certified/g, 'trained')
  .replace(/\bIICRC\b/g, 'industry')
  .replace(/IICRC certifications/g, 'industry training')
  .replace(/\bcertified\b/gi, 'trained')
  .replace(/\bcertifications\b/gi, 'training')
  .replace(/Licensed & Insured/g, 'Property Restoration Support')
  .replace(/Direct Insurance Billing/g, 'Insurance Documentation Help')
  .replace(/direct\s+billing/gi, 'insurance documentation help')
  .replace(/all\s+major\s+carriers/gi, 'insurance carriers')
  .replace(/Trusted by/g, 'Serving')
  .replace(/under\s+60 minutes/gi, 'as quickly as possible')
  .replace(/within\s+60 minutes/gi, 'as quickly as possible')
  .replace(/60[\s-]minute/gi, 'prompt')
  .replace(/60 minute/gi, 'prompt')
  .replace(/15\+/g, 'many')
  .replace(/45\+/g, 'many')

export const getStaticPaths: GetStaticPaths = () => {
  const paths: { params: { slug: string }; props: { pageType: string; categorySlug?: string; serviceSlug?: string } }[] = []

  const categories = getDivisionCategories('residential')
  for (const category of categories) {
    // Category page: /services/residential/restoration-services
    paths.push({
      params: { slug: category.slug },
      props: { pageType: 'category', categorySlug: category.slug },
    })

    // Service pages: /services/residential/restoration-services/water-damage-restoration
    for (const service of category.children || []) {
      paths.push({
        params: { slug: `${category.slug}/${service.slug}` },
        props: { pageType: 'service', categorySlug: category.slug, serviceSlug: service.slug },
      })
    }
  }

  return paths
}

const { pageType, categorySlug, serviceSlug } = Astro.props

// Category page
if (pageType === 'category') {
  var categoryNode = getNodeByPath(`/services/residential/${categorySlug}`)
  var categoryServices = getCategoryServices('residential', categorySlug!)
}

// Service detail page
if (pageType === 'service') {
  var service = getService(serviceSlug!)
  var categoryForService = getNodeByPath(`/services/residential/${categorySlug}`)
}

// City content overlay — null means use generic ServiceData fallback
const cityContent = (pageType === 'service' && serviceSlug)
  ? getCityServiceContent(cityData.slug, serviceSlug)
  : null

// Get related blog posts for cross-linking
const relatedBlogs = cityContent?.relatedBlogSlugs
  ? blogPosts.filter(p => cityContent.relatedBlogSlugs.includes(p.slug)).slice(0, 3)
  : []

// Use city-specific FAQs when available, otherwise generic
const displayFaqs = (cityContent?.faqs && cityContent.faqs.length > 0)
  ? cityContent.faqs
  : service?.faqs ?? []

const safeFaqs = displayFaqs.map((faq) => ({
  ...faq,
  question: safeText(faq.question),
  answer: safeText(faq.answer),
}))

// Structured data: Service + FAQPage (when FAQs exist) + BreadcrumbList (AEO)
const _base = cityBaseUrl()
const serviceStructuredData = service
  ? [
      serviceSchema({ ...service, description: safeText(service.description) }),
      ...(safeFaqs.length ? [faqPageSchema(safeFaqs)] : []),
      breadcrumbSchema([
        { name: 'Home', url: `${_base}/` },
        { name: 'Services', url: `${_base}/services` },
        { name: 'Residential', url: `${_base}/services/residential` },
        ...(categoryForService ? [{ name: categoryForService.name, url: `${_base}${categoryForService.path}` }] : []),
        { name: service.name, url: `${_base}${Astro.url.pathname}` },
      ]),
    ]
  : undefined

// Page title & description — city-specific when available
const pageTitle = cityContent?.meta?.title
  ? safeText(cityContent.meta.title)
  : service ? `${service.name} in ${cityData.name}, ${cityData.stateAbbr} | Flood Doctor` : ''
const pageDescription = cityContent?.meta?.description
  ? safeText(cityContent.meta.description)
  : (service ? `${service.name} in ${cityData.name}, ${cityData.stateAbbr}. ${safeText(service.description)}` : '')

const imageUrl = (url = '', params = '') => url.endsWith('.svg') ? url : `${url}${params}`
---

{pageType === 'category' && categoryNode ? (
  <BaseLayout
    title={`${categoryNode.name} | Residential | Flood Doctor ${cityData.name}`}
    description={`${categoryNode.description} Professional residential ${categoryNode.name.toLowerCase()} in ${cityData.name}.`}
  >
    <div class="py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:mx-0">
          <nav class="flex text-sm text-gray-400 mb-8" aria-label="Breadcrumb">
            <a href="/" class="hover:text-white">Home</a>
            <span class="mx-2">/</span>
            <a href="/services" class="hover:text-white">Services</a>
            <span class="mx-2">/</span>
            <a href="/services/residential" class="hover:text-white">Residential</a>
            <span class="mx-2">/</span>
            <span class="text-white">{categoryNode.name}</span>
          </nav>
          <div class="flex items-center gap-x-3">
            <Icon name={categoryNode.icon || 'check'} class="size-8 text-indigo-400" />
            <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">{categoryNode.name}</h1>
          </div>
          <p class="mt-6 text-lg/8 text-gray-300">{categoryNode.description}</p>
        </div>

        <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-2">
          {categoryServices.map((svc) => (
            <a href={svc.path} class="group relative flex flex-col rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10 transition hover:bg-white/10 hover:outline-indigo-500/50">
              <h2 class="text-xl font-semibold text-white group-hover:text-indigo-400">{svc.name}</h2>
              <p class="mt-3 grow text-sm/6 text-gray-400">{svc.description}</p>
              <span class="mt-6 text-sm font-semibold text-indigo-400 group-hover:text-indigo-300">
                Learn more <span aria-hidden="true">&rarr;</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl rounded-2xl bg-white/5 p-8 text-center outline-1 -outline-offset-1 outline-white/10 sm:p-12">
          <h2 class="text-2xl font-semibold text-white">Need help choosing a service?</h2>
          <p class="mt-4 text-gray-400">Call us for an assessment. We'll recommend the right solution for your situation.</p>
          <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
            <a href="/request" class="rounded-md bg-indigo-500 px-6 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-400">Request Service</a>
            <a href={cityPhoneHref} class="rounded-md bg-white/10 px-6 py-2.5 text-sm font-semibold text-white hover:bg-white/20">Call {cityData.phone}</a>
          </div>
        </div>
      </div>
    </div>
  </BaseLayout>
) : service ? (
  <BaseLayout
    title={pageTitle}
    description={pageDescription}
    structuredData={serviceStructuredData}
  >
    <!-- Hero -->
    <div class="relative isolate overflow-hidden bg-white dark:bg-gray-900">
      <svg aria-hidden="true" class="absolute inset-x-0 top-0 -z-10 h-[64rem] w-full mask-[radial-gradient(32rem_32rem_at_center,white,transparent)] stroke-gray-200 dark:stroke-white/10">
        <defs><pattern x="50%" y="-1" id="service-hero-pattern" width="200" height="200" patternUnits="userSpaceOnUse"><path d="M.5 200V.5H200" fill="none" /></pattern></defs>
        <rect fill="url(#service-hero-pattern)" width="100%" height="100%" stroke-width="0" />
      </svg>
      <div class="mx-auto max-w-7xl px-6 pt-36 pb-24 sm:pt-60 sm:pb-32 lg:flex lg:items-center lg:gap-x-10 lg:px-8 lg:pt-40 lg:pb-40">
        <div class="mx-auto max-w-2xl lg:mx-0 lg:flex-auto">
          <nav class="flex text-sm text-gray-400 dark:text-gray-500 mb-6" aria-label="Breadcrumb">
            <a href="/" class="hover:text-gray-900 dark:hover:text-white">Home</a>
            <span class="mx-2">/</span>
            <a href="/services" class="hover:text-gray-900 dark:hover:text-white">Services</a>
            <span class="mx-2">/</span>
            <a href="/services/residential" class="hover:text-gray-900 dark:hover:text-white">Residential</a>
            <span class="mx-2">/</span>
            {categoryForService && (
              <>
                <a href={categoryForService.path} class="hover:text-gray-900 dark:hover:text-white">{categoryForService.name}</a>
                <span class="mx-2">/</span>
              </>
            )}
            <span class="text-gray-900 dark:text-white">{service.name}</span>
          </nav>
          <h1 class="text-5xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-7xl">
            {safeText(cityContent?.h1 ?? `${service.name} in ${cityData.name}, ${cityData.stateAbbr}`)}
          </h1>
          <p class="mt-8 text-lg font-medium text-pretty text-gray-600 dark:text-gray-400 sm:text-xl/8">{safeText(service.description)}</p>
          <div class="mt-10 flex items-center gap-x-6">
            <a href="/request" class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400">Request Service</a>
            <a href={cityPhoneHref} class="text-sm/6 font-semibold text-gray-900 dark:text-white">Call Now <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
        <div class="mt-16 sm:mt-24 lg:mt-0 lg:shrink-0 lg:grow">
          <img alt={service.name} src={imageUrl(service.heroImageUrl, '&fm=avif&w=800&q=70')} width="800" height="533" fetchpriority="high" decoding="async" class="w-full rounded-2xl object-cover shadow-xl ring-1 ring-gray-200 dark:ring-white/10 lg:aspect-[3/2] lg:max-w-xl" />
        </div>
      </div>
    </div>

    <!-- City-Specific Intro Section (only when cityContent exists) -->
    {cityContent?.introSection && (
      <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl">
            <h2 class="text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">{safeText(cityContent.introSection.headline)}</h2>
            <div class="mt-8 space-y-6 text-base/7 text-gray-600 dark:text-gray-400">
              {cityContent.introSection.paragraphs.map((p) => <p>{safeText(p)}</p>)}
            </div>
            <p class="mt-8 text-sm font-medium text-indigo-600 dark:text-indigo-400">{safeText(cityContent.introSection.localContext)}</p>
          </div>
        </div>
      </div>
    )}

    <!-- Trust signals (honest, text-based — no fake certification badges) -->
    <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <h2 class="text-center text-lg/8 font-semibold text-gray-900 dark:text-white">Why homeowners trust us</h2>
        <div class="mx-auto mt-10 flex max-w-4xl flex-wrap items-center justify-center gap-x-6 gap-y-4">
          {['Emergency Intake', 'Trained Restoration Crews', '24/7 Availability', 'Insurance Documentation Help', 'Local Service Coordination'].map((signal) => (
            <span class="inline-flex items-center rounded-full bg-white dark:bg-white/5 px-4 py-2 text-sm font-semibold text-gray-700 dark:text-gray-200 ring-1 ring-gray-200 dark:ring-white/10">{signal}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Features -->
    <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:mx-0">
          <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">What's included</h2>
          <p class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">{service.name}</p>
          <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">{safeText(service.tagline)}</p>
        </div>
        <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 text-base/7 text-gray-600 dark:text-gray-400 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 lg:gap-x-16">
          {service.features.map((feature) => (
            <div class="relative pl-9">
              <dt class="inline font-semibold text-gray-900 dark:text-white">
                <Icon name={feature.icon} class="absolute top-1 left-1 size-5 text-indigo-600 dark:text-indigo-500" />
                {safeText(feature.name)}
              </dt>{' '}
              <dd class="inline">{safeText(feature.description)}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <!-- City-Specific Process Steps (replaces generic content when available) -->
    {cityContent?.processSteps && cityContent.processSteps.length > 0 ? (
      <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl">
            <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Our process</h2>
            <p class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">How We Restore Your {cityData.name} Property</p>
          </div>
          <div class="mx-auto mt-16 max-w-3xl">
            <div class="space-y-12">
              {cityContent.processSteps.map((step, idx) => (
                <div class="relative flex gap-x-6">
                  <div class="flex flex-col items-center">
                    <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-indigo-600 dark:bg-indigo-500 text-sm font-bold text-white">
                      {idx + 1}
                    </div>
                    {idx < cityContent.processSteps.length - 1 && (
                      <div class="mt-2 w-px grow bg-gray-200 dark:bg-white/10" />
                    )}
                  </div>
                  <div class="pb-8">
                    <div class="flex items-center gap-x-3">
                      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{safeText(step.title)}</h3>
                      {step.timeframe && (
                        <span class="inline-flex items-center rounded-full bg-indigo-50 dark:bg-indigo-500/10 px-2.5 py-0.5 text-xs font-medium text-indigo-700 dark:text-indigo-400">{safeText(step.timeframe)}</span>
                      )}
                    </div>
                    <p class="mt-2 text-base/7 text-gray-600 dark:text-gray-400">{safeText(step.description)}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    ) : (
      <!-- Generic Content (fallback) -->
      <div class="relative isolate overflow-hidden bg-white dark:bg-gray-900 px-6 py-24 sm:py-32 lg:overflow-visible lg:px-0">
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-start lg:gap-y-10">
          <div class="lg:col-span-2 lg:col-start-1 lg:row-start-1 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8">
            <div class="lg:pr-4">
              <div class="lg:max-w-lg">
                <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">In-depth</p>
                <h2 class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">How Our {service.name} Process Works</h2>
                <p class="mt-6 text-xl/8 text-gray-600 dark:text-gray-300">{safeText(service.contentParagraphs[0])}</p>
              </div>
            </div>
          </div>
          <div class="-mt-12 -ml-12 p-12 lg:sticky lg:top-4 lg:col-start-2 lg:row-span-2 lg:row-start-1 lg:overflow-hidden">
            <img alt={service.name} src={imageUrl(service.heroImageUrl, '&fm=avif&w=912&q=70')} width="912" height="608" loading="lazy" decoding="async" class="w-[48rem] max-w-none rounded-xl bg-gray-100 dark:bg-gray-800 shadow-xl ring-1 ring-gray-200 dark:ring-white/10 sm:w-[57rem]" />
          </div>
          <div class="lg:col-span-2 lg:col-start-1 lg:row-start-2 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8">
            <div class="lg:pr-4">
              <div class="max-w-xl text-base/7 text-gray-600 dark:text-gray-400 lg:max-w-lg">
                {service.contentParagraphs.slice(1).map((paragraph, idx) => (
                  <p class={idx > 0 ? 'mt-8' : ''}>{safeText(paragraph)}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- City-Specific Local Challenges -->
    {cityContent?.localChallenges && cityContent.localChallenges.length > 0 && (
      <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:mx-0">
            <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Local expertise</h2>
            <p class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">{cityData.name} Challenges We Solve</p>
          </div>
          <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-2">
            {cityContent.localChallenges.map((challenge) => (
              <div class="rounded-2xl bg-gray-50 dark:bg-white/5 p-8 ring-1 ring-gray-200 dark:ring-white/10">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{safeText(challenge.title)}</h3>
                <p class="mt-3 text-sm/6 text-gray-600 dark:text-gray-400">{safeText(challenge.description)}</p>
                <div class="mt-4 border-t border-gray-200 dark:border-white/10 pt-4">
                  <p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Our solution</p>
                  <p class="mt-1 text-sm/6 text-gray-600 dark:text-gray-400">{safeText(challenge.solution)}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- City-Specific Equipment Section -->
    {cityContent?.equipmentSection && (
      <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:mx-0">
            <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Professional equipment</h2>
            <p class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">{safeText(cityContent.equipmentSection.headline)}</p>
          </div>
          <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-6 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
            {cityContent.equipmentSection.equipment.map((item) => (
              <div class="rounded-xl bg-white dark:bg-white/5 p-6 ring-1 ring-gray-200 dark:ring-white/10">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{safeText(item.name)}</h3>
                {item.brand && <span class="mt-1 inline-block text-xs text-indigo-600 dark:text-indigo-400">{safeText(item.brand)}</span>}
                <p class="mt-2 text-sm/6 text-gray-600 dark:text-gray-400">{safeText(item.purpose)}</p>
              </div>
            ))}
          </div>
          <p class="mx-auto mt-10 max-w-3xl text-sm/6 text-gray-500 dark:text-gray-500">{safeText(cityContent.equipmentSection.localNote)}</p>
        </div>
      </div>
    )}

    <!-- City-Specific Pricing Section -->
    {cityContent?.pricingSection && (
      <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl">
            <h2 class="text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">{safeText(cityContent.pricingSection.headline)}</h2>
            <p class="mt-6 text-base/7 text-gray-600 dark:text-gray-400">{safeText(cityContent.pricingSection.intro)}</p>
            <ul class="mt-8 space-y-3">
              {cityContent.pricingSection.factors.map((factor) => (
                <li class="flex gap-x-3 text-sm/6 text-gray-600 dark:text-gray-400">
                  <svg class="mt-1 size-4 shrink-0 text-indigo-600 dark:text-indigo-500" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                  </svg>
                  {safeText(factor)}
                </li>
              ))}
            </ul>
            <p class="mt-8 text-sm font-medium text-indigo-600 dark:text-indigo-400">{safeText(cityContent.pricingSection.cta)}</p>
          </div>
        </div>
      </div>
    )}

    <!-- City-Specific Service Area -->
    {cityContent?.serviceAreaSection && (
      <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl">
            <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Service area</h2>
            <p class="mt-2 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">{service.name} Throughout {cityData.name}</p>
            <div class="mt-8 flex flex-wrap gap-2">
              {cityContent.serviceAreaSection.neighborhoods.map((n) => (
                <span class="inline-flex items-center rounded-full bg-indigo-50 dark:bg-indigo-500/10 px-3 py-1.5 text-sm font-medium text-indigo-700 dark:text-indigo-400">{n}</span>
              ))}
            </div>
            <p class="mt-6 text-sm/6 text-gray-600 dark:text-gray-400">{safeText(cityContent.serviceAreaSection.responseTime)}</p>
          </div>
        </div>
      </div>
    )}

    <!-- Related Services -->
    <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-5">
          <div class="col-span-2">
            <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Everything you need</h2>
            <p class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Related Services</p>
          </div>
          <dl class="col-span-3 grid grid-cols-1 gap-x-8 gap-y-10 text-base/7 text-gray-600 dark:text-gray-300 sm:grid-cols-2 lg:gap-y-16">
            {service.relatedFeatures.map((feature) => (
              <div class="relative pl-9">
                <dt class="font-semibold text-gray-900 dark:text-white">
                  <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="absolute top-1 left-0 h-5 w-5 text-indigo-600 dark:text-indigo-500">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                  </svg>
                  {safeText(feature.name)}
                </dt>
                <dd class="mt-2">{safeText(feature.description)}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>

    <!-- Related Blog Articles (when city content has blog cross-links) -->
    {relatedBlogs.length > 0 && (
      <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:mx-0">
            <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Learn more</h2>
            <p class="mt-2 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Related Articles</p>
          </div>
          <div class="mx-auto mt-10 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-3">
            {relatedBlogs.map((post) => (
              <a href={post.href} class="group flex flex-col rounded-2xl bg-white dark:bg-white/5 ring-1 ring-gray-200 dark:ring-white/10 overflow-hidden transition hover:ring-indigo-500/50">
                <img src={post.imageUrl} alt={post.title} loading="lazy" decoding="async" width="640" height="360" class="aspect-[16/9] w-full object-cover" />
                <div class="p-6">
                  <div class="text-xs font-medium text-indigo-600 dark:text-indigo-400">{post.category.title}</div>
                  <h3 class="mt-2 text-base font-semibold text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400">{post.title}</h3>
                  <p class="mt-2 text-sm/6 text-gray-600 dark:text-gray-400 line-clamp-2">{safeText(post.description)}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- FAQ -->
    <div class="bg-gray-50 dark:bg-gray-900">
      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8 lg:py-40">
        <div class="mx-auto max-w-4xl">
          <h2 class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Frequently asked questions</h2>
          <FAQAccordion client:visible faqs={safeFaqs} />
        </div>
      </div>
    </div>

    <!-- City-Specific Final CTA -->
    {cityContent?.finalCTA ? (
      <div class="bg-indigo-600 dark:bg-indigo-500">
        <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
          <div class="mx-auto max-w-2xl text-center">
            <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">{safeText(cityContent.finalCTA.headline)}</h2>
            <p class="mt-6 text-lg/8 text-indigo-100">{safeText(cityContent.finalCTA.paragraph)}</p>
            <div class="mt-10 flex items-center justify-center gap-x-6">
              <a href="/request" class="rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-indigo-600 shadow-xs hover:bg-indigo-50">Request Service</a>
              <a href={cityPhoneHref} class="text-sm/6 font-semibold text-white">Call {cityData.phone} <span aria-hidden="true">&rarr;</span></a>
            </div>
          </div>
        </div>
      </div>
    ) : null}
  </BaseLayout>
) : (
  <BaseLayout title="Not Found" noIndex>
    <div class="py-24 text-center">
      <h1 class="text-4xl font-semibold text-white">Page not found</h1>
      <p class="mt-4 text-gray-400">The service you're looking for doesn't exist.</p>
      <a href="/services/residential" class="mt-8 inline-block text-indigo-400 hover:text-indigo-300">Back to Residential Services</a>
    </div>
  </BaseLayout>
)}
