---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Icon from '../../../components/Icon.astro'
import FAQAccordion from '../../../components/islands/FAQAccordion.tsx'
import { cityData } from '../../../data/cities'
import { getDivisionCategories, getCategoryServices, getNodeByPath } from '../../../data/services/service-tree'
import { getService } from '../../../data/services'
import { serviceSchema, faqPageSchema, breadcrumbSchema, cityBaseUrl } from '../../../utils/schema'
import { getCityServiceContent } from '../../../data/city-content'
import { blogPosts } from '../../../data/blog'
import type { GetStaticPaths } from 'astro'
import { toTelHref } from '../../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)

const safeText = (value = '') => String(value)
  .replace(/Free[ \t]+Estimate/g, 'Request Service')
  .replace(/free[ \t]+estimate/g, 'service request')
  .replace(/IICRC-Certified Technicians/g, 'Trained Restoration Crews')
  .replace(/IICRC-certified technicians/g, 'restoration technicians')
  .replace(/IICRC-certified/g, 'trained')
  .replace(/\bIICRC\b/g, 'industry')
  .replace(/IICRC certifications/g, 'industry training')
  .replace(/\bcertified\b/gi, 'trained')
  .replace(/\bcertifications\b/gi, 'training')
  .replace(/HIPAA-compliant/gi, 'privacy-aware')
  .replace(/OSHA-compliant/gi, 'safety-conscious')
  .replace(/EPA and OSHA workplace standards/gi, 'workplace safety expectations')
  .replace(/Licensed & Insured/g, 'Property Restoration Support')
  .replace(/Direct Insurance Billing/g, 'Insurance Documentation Help')
  .replace(/direct\s+billing/gi, 'insurance documentation help')
  .replace(/all\s+major\s+carriers/gi, 'insurance carriers')
  .replace(/Trusted by/g, 'Serving')
  .replace(/under\s+60 minutes/gi, 'as quickly as possible')
  .replace(/within\s+60 minutes/gi, 'as quickly as possible')
  .replace(/60[\s-]minute/gi, 'prompt')
  .replace(/60 minute/gi, 'prompt')
  .replace(/15\+/g, 'many')
  .replace(/45\+/g, 'many')

export const getStaticPaths: GetStaticPaths = () => {
  const paths: { params: { slug: string }; props: { pageType: string; categorySlug?: string; serviceSlug?: string } }[] = []

  const categories = getDivisionCategories('commercial')
  for (const category of categories) {
    paths.push({
      params: { slug: category.slug },
      props: { pageType: 'category', categorySlug: category.slug },
    })

    for (const service of category.children || []) {
      paths.push({
        params: { slug: `${category.slug}/${service.slug}` },
        props: { pageType: 'service', categorySlug: category.slug, serviceSlug: service.slug },
      })
    }
  }

  return paths
}

const { pageType, categorySlug, serviceSlug } = Astro.props

if (pageType === 'category') {
  var categoryNode = getNodeByPath(`/services/commercial/${categorySlug}`)
  var categoryServices = getCategoryServices('commercial', categorySlug!)
}

if (pageType === 'service') {
  var service = getService(serviceSlug!)
  var categoryForService = getNodeByPath(`/services/commercial/${categorySlug}`)
}

const cityContent = (pageType === 'service' && serviceSlug)
  ? getCityServiceContent(cityData.slug, serviceSlug)
  : null

const relatedBlogs = cityContent?.relatedBlogSlugs
  ? blogPosts.filter(p => cityContent.relatedBlogSlugs.includes(p.slug)).slice(0, 3)
  : []

const displayFaqs = (cityContent?.faqs && cityContent.faqs.length > 0)
  ? cityContent.faqs
  : service?.faqs ?? []

const safeFaqs = displayFaqs.map((faq) => ({
  ...faq,
  question: safeText(faq.question),
  answer: safeText(faq.answer),
}))

const siblingServices = (pageType === 'service' && categorySlug)
  ? getCategoryServices('commercial', categorySlug!).filter((node) => node.slug !== serviceSlug).slice(0, 4)
  : []

const _base = cityBaseUrl()
const categoryStructuredData = categoryNode
  ? breadcrumbSchema([
      { name: 'Home', url: `${_base}/` },
      { name: 'Services', url: `${_base}/services/` },
      { name: 'Commercial', url: `${_base}/services/commercial/` },
      { name: categoryNode.name, url: `${_base}${Astro.url.pathname}` },
    ])
  : undefined
const serviceStructuredData = service
  ? [
      serviceSchema({ ...service, description: safeText(service.description) }),
      ...(safeFaqs.length ? [faqPageSchema(safeFaqs)] : []),
      breadcrumbSchema([
        { name: 'Home', url: `${_base}/` },
        { name: 'Services', url: `${_base}/services` },
        { name: 'Commercial', url: `${_base}/services/commercial` },
        ...(categoryForService ? [{ name: categoryForService.name, url: `${_base}${categoryForService.path}` }] : []),
        { name: service.name, url: `${_base}${Astro.url.pathname}` },
      ]),
    ]
  : undefined

const pageTitle = cityContent?.meta?.title
  ? safeText(cityContent.meta.title)
  : service ? `${service.name} in ${cityData.name}, ${cityData.stateAbbr} | Flood Doctor` : ''
const pageDescription = cityContent?.meta?.description
  ? safeText(cityContent.meta.description)
  : (service ? `${service.name} in ${cityData.name}, ${cityData.stateAbbr}. ${safeText(service.description)}` : '')

const isCityVariant = cityData.slug !== 'main'
const cityServiceAreas = isCityVariant
  ? (cityContent?.serviceAreaSection?.neighborhoods?.filter(Boolean) ?? [])
  : []
const cityServiceAreaChips = cityServiceAreas.slice(0, 10)
const nearbyCommunityChips = isCityVariant
  ? (cityData.serviceArea ?? [])
      .filter((area) => area && area !== cityData.name && !cityServiceAreas.includes(area))
      .slice(0, 8)
  : []
const localJobNotes = isCityVariant && cityContent?.localChallenges?.length
  ? cityContent.localChallenges.slice(0, 3)
  : []
const hasCityBrief = isCityVariant && Boolean(cityContent) && (
  Boolean(cityContent?.introSection?.localContext) ||
  cityServiceAreaChips.length > 0 ||
  nearbyCommunityChips.length > 0 ||
  localJobNotes.length > 0
)
const cityRequestLabel = isCityVariant && cityContent ? `Request ${cityData.name} Service` : 'Request Service'
const imageUrl = (url = '', params = '') => url.endsWith('.svg') ? url : `${url}${params}`
const fallbackProcessSteps = service?.contentParagraphs?.map((paragraph, idx) => ({
  title: idx === 0 ? 'Assess the damage and safety conditions' : idx === 1 ? 'Map moisture and define scope' : idx === 2 ? 'Dry, clean, and monitor' : 'Document close-out and next steps',
  description: paragraph,
})) ?? []
const whenToCall = [
  'Water is actively entering, standing, or spreading into new rooms.',
  'Drywall, flooring, insulation, ceilings, or contents are wet and need a documented scope.',
  'Sewage, stormwater, mold odor, electrical concerns, or access hazards may be involved.',
]
const serviceLocalAreas = isCityVariant
  ? (cityServiceAreaChips.length > 0 ? cityServiceAreaChips.slice(0, 6) : cityData.serviceArea?.slice(0, 6) ?? [])
  : []
const safetyChecks = [
  'Confirm source control, shutoff authority, occupied areas, and whether electrical, sewage, ceiling, or structural hazards are present.',
  'Separate wet and dry operational zones where safe, then identify tenant, guest, patient, student, or employee impacts.',
  'Preserve first-condition photos, affected-area notes, equipment impacts, and stakeholder contacts before cleanup changes the site.',
]
const affectedMaterials = [
  { material: 'Partitions, ceilings, and insulation', action: 'Track water migration through shared walls, ceiling cavities, and fire-rated assemblies before drying or removal decisions.' },
  { material: 'Flooring and operational surfaces', action: 'Identify carpet tile, resilient flooring, concrete, hardwood, and specialty surfaces that affect equipment placement.' },
  { material: 'Inventory, records, and electronics', action: 'Separate salvageable items, document non-restorable materials, and protect business-critical assets when safe.' },
  { material: 'Mechanical and shared systems', action: 'Coordinate around HVAC, elevators, drains, electrical rooms, and building access constraints.' },
]
const documentationItems = [
  'Source notes, affected-area map, access constraints, occupancy impacts, and safety observations.',
  'Moisture readings or material condition notes when they are part of the commercial restoration scope.',
  'Photo-backed scope summaries that help owners, managers, tenants, carriers, and repair partners work from the same facts.',
]
const equipmentProof = [
  { label: 'Moisture mapping', body: 'Meters and inspection notes help locate where water traveled across rooms, units, or building assemblies.' },
  { label: 'Equipment planning', body: 'Air movement, dehumidification, containment, filtration, or removal decisions are matched to use type and access.' },
  { label: 'Monitoring', body: 'Follow-up observations support drying decisions, phasing, and close-out documentation when drying is part of the scope.' },
]
---

{pageType === 'category' && categoryNode ? (
  <BaseLayout
    title={`${categoryNode.name} | Commercial | Flood Doctor ${cityData.name}`}
    description={`${categoryNode.description} Professional commercial ${categoryNode.name.toLowerCase()} in ${cityData.name}.`}
    structuredData={categoryStructuredData}
  >
    <main class="detail-page">
      <section class="detail-hero category-hero" aria-labelledby="category-title">
        <div class="detail-shell hero-grid">
          <div>
            <nav class="breadcrumb" aria-label="Breadcrumb">
              <a href="/">Home</a><span>/</span><a href="/services">Services</a><span>/</span><a href="/services/commercial">Commercial</a><span>/</span><span>{categoryNode.name}</span>
            </nav>
            <p class="eyebrow">Commercial service category</p>
            <h1 id="category-title">{categoryNode.name}</h1>
            <p class="hero-lede">{safeText(categoryNode.description)} Service intake is available for {cityData.name} properties when water, contamination, or drying decisions need a clear next step.</p>
            <div class="action-row">
              <a class="fd-btn fd-btn-primary" href={cityPhoneHref}>Call Now {cityData.phone}</a>
              <a class="fd-btn fd-btn-secondary" href="/request">Request Service</a>
            </div>
          </div>
          <aside class="command-card">
            <span>Category scope</span>
            <strong>Choose the closest service, then describe what happened.</strong>
            <p>Routing stays the same: intake, safety notes, affected-area details, documentation needs, and the right restoration path.</p>
          </aside>
        </div>
      </section>

      <section class="section light-section" aria-labelledby="category-services-title">
        <div class="detail-shell">
          <div class="split-heading">
            <div>
              <p class="eyebrow">Included services</p>
              <h2 id="category-services-title">Services in this category</h2>
            </div>
            <p>Each service page keeps the same emergency-first structure with definition, scope, process, local details, FAQ, and request actions.</p>
          </div>
          <div class="service-link-grid">
            {categoryServices.map((svc) => (
              <a href={svc.path} class="service-link-card">
                <strong>{svc.name}</strong>
                <p>{safeText(svc.description)}</p>
                <span>Open service <span aria-hidden="true">&rarr;</span></span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section category-authority" aria-labelledby="category-authority-title">
        <div class="detail-shell category-authority-grid">
          <div>
            <p class="eyebrow">How this category is scoped</p>
            <h2 id="category-authority-title">Match the service to source, operations, and safety conditions</h2>
            <p>Commercial routing works best when the first notes include what happened, which areas are affected, who needs access, and what documentation stakeholders may need.</p>
          </div>
          <div class="authority-cards">
            <article>
              <span>Safety</span>
              <p>{safetyChecks[0]}</p>
            </article>
            <article>
              <span>Materials</span>
              <p>{affectedMaterials[0].action}</p>
            </article>
            <article>
              <span>Documentation</span>
              <p>{documentationItems[0]}</p>
            </article>
          </div>
        </div>
      </section>

      <section class="final-cta" aria-labelledby="category-cta-title">
        <div class="detail-shell final-panel">
          <div>
            <p class="eyebrow">Need help choosing?</p>
            <h2 id="category-cta-title">Send the damage details and we will route the request</h2>
            <p>Start with what happened, where the water went, and whether the source is controlled.</p>
          </div>
          <div class="action-row final-actions">
            <a class="fd-btn fd-btn-primary" href={cityPhoneHref}>Call Now {cityData.phone}</a>
            <a class="fd-btn fd-btn-outline" href="/request">Request Service</a>
          </div>
        </div>
      </section>
    </main>
  </BaseLayout>
) : service ? (
  <BaseLayout
    title={pageTitle}
    description={pageDescription}
    structuredData={serviceStructuredData}
  >
    <main class="detail-page">
      <section class="detail-hero" aria-labelledby="service-title">
        <div class="detail-shell hero-grid">
          <div>
            <nav class="breadcrumb" aria-label="Breadcrumb">
              <a href="/">Home</a><span>/</span><a href="/services">Services</a><span>/</span><a href="/services/commercial">Commercial</a><span>/</span>
              {categoryForService && <><a href={categoryForService.path}>{categoryForService.name}</a><span>/</span></>}
              <span>{service.name}</span>
            </nav>
            <p class="eyebrow">Commercial emergency service</p>
            <h1 id="service-title">{safeText(cityContent?.h1 ?? `${service.name} in ${cityData.name}, ${cityData.stateAbbr}`)}</h1>
            <p class="hero-lede">{safeText(service.description)}</p>
            <div class="action-row">
              <a class="fd-btn fd-btn-primary" href={cityPhoneHref}>Call Now {cityData.phone}</a>
              <a class="fd-btn fd-btn-secondary" href="/request">{cityRequestLabel}</a>
            </div>
          </div>
          <aside class="hero-media">
            <img alt={service.name} src={imageUrl(service.heroImageUrl, '&fm=avif&w=800&q=70')} width="800" height="533" fetchpriority="high" decoding="async" />
            <div class="media-status">
              <span>First response focus</span>
              <strong>Safety, water path, affected materials, documentation.</strong>
            </div>
            {serviceLocalAreas.length > 0 && (
              <div class="hero-local" aria-label={`${cityData.name} service-area context`}>
                <span>{cityData.name} context</span>
                <div>
                  {serviceLocalAreas.map((area) => <em>{safeText(area)}</em>)}
                </div>
              </div>
            )}
          </aside>
        </div>
      </section>

      {hasCityBrief && (
        <section class="section city-brief-section" aria-labelledby="city-brief-title">
          <div class="detail-shell city-brief-panel">
            <div class="city-brief-copy">
              <p class="eyebrow">{cityData.name} service notes</p>
              <h2 id="city-brief-title">Local details to include in the request</h2>
              {cityContent?.introSection?.localContext && <p>{safeText(cityContent.introSection.localContext)}</p>}
            </div>
            <div class="city-brief-groups">
              {cityServiceAreaChips.length > 0 && (
                <article>
                  <h3>Service-area signals</h3>
                  <div class="chip-list">
                    {cityServiceAreaChips.map((area) => <span>{safeText(area)}</span>)}
                  </div>
                </article>
              )}
              {nearbyCommunityChips.length > 0 && (
                <article>
                  <h3>Nearby communities</h3>
                  <div class="chip-list nearby-list">
                    {nearbyCommunityChips.map((area) => <span>{safeText(area)}</span>)}
                  </div>
                </article>
              )}
              {localJobNotes.length > 0 && (
                <article class="local-job-context">
                  <h3>Local job context</h3>
                  <ul>
                    {localJobNotes.map((note) => (
                      <li>
                        <strong>{safeText(note.title)}</strong>
                        <span>{safeText(note.description)}</span>
                      </li>
                    ))}
                  </ul>
                </article>
              )}
            </div>
          </div>
        </section>
      )}

      <section class="section safety-section" aria-labelledby="safety-title">
        <div class="detail-shell safety-grid">
          <div>
            <p class="eyebrow">Active water safety triage</p>
            <h2 id="safety-title">Stabilize safety, access, and operations first</h2>
            <p>Use these checks before moving inventory, reopening areas, cutting materials, or changing the first-condition documentation.</p>
          </div>
          <ul>
            {safetyChecks.map((item) => <li>{safeText(item)}</li>)}
          </ul>
        </div>
      </section>

      <section class="section definition-section" aria-labelledby="definition-title">
        <div class="detail-shell definition-grid">
          <div class="definition-copy">
            <p class="eyebrow">Definition + scope</p>
            <h2 id="definition-title">What {service.name} covers</h2>
            <p>{safeText(service.tagline)}</p>
            <div class="feature-grid">
              {service.features.map((feature) => (
                <article class="feature-card">
                  <Icon name={feature.icon} class="feature-icon" />
                  <h3>{safeText(feature.name)}</h3>
                  <p>{safeText(feature.description)}</p>
                </article>
              ))}
            </div>
          </div>
          <aside class="call-card" aria-labelledby="call-title">
            <span>When to call</span>
            <h3 id="call-title">Use the phone when the loss is active or unsafe.</h3>
            <ul>
              {whenToCall.map((item) => <li>{item}</li>)}
            </ul>
            <a class="fd-btn fd-btn-primary" href={cityPhoneHref}>Call {cityData.phone}</a>
          </aside>
        </div>
      </section>

      <section class="section material-section" aria-labelledby="material-title">
        <div class="detail-shell">
          <div class="split-heading">
            <div>
              <p class="eyebrow">Affected-material matrix</p>
              <h2 id="material-title">What gets checked before drying, removal, or reopening</h2>
            </div>
            <p>Commercial scopes depend on how materials, systems, occupants, and operations interact after water travels beyond the visible source.</p>
          </div>
          <div class="material-grid">
            {affectedMaterials.map((item) => (
              <article class="material-card">
                <strong>{safeText(item.material)}</strong>
                <p>{safeText(item.action)}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      {cityContent?.introSection && (
        <section class="section local-intro" aria-labelledby="local-intro-title">
          <div class="detail-shell local-grid">
            <div>
              <p class="eyebrow">Local proof</p>
              <h2 id="local-intro-title">{safeText(cityContent.introSection.headline)}</h2>
              <div class="rich-copy">
                {cityContent.introSection.paragraphs.map((p) => <p>{safeText(p)}</p>)}
              </div>
            </div>
            <aside class="local-note">
              <span>{cityData.name} context</span>
              <p>{safeText(cityContent.introSection.localContext)}</p>
            </aside>
          </div>
        </section>
      )}

      <section class="section process-section" aria-labelledby="process-title">
        <div class="detail-shell">
          <div class="split-heading">
            <div>
              <p class="eyebrow">Process</p>
              <h2 id="process-title">How we serve {cityData.name} businesses</h2>
            </div>
            <p>Process sequencing depends on source control, water category, affected materials, access, and safety conditions.</p>
          </div>
          <ol class="process-list">
            {(cityContent?.processSteps && cityContent.processSteps.length > 0 ? cityContent.processSteps : fallbackProcessSteps).map((step, idx) => (
              <li class="process-card">
                <span>{String(idx + 1).padStart(2, '0')}</span>
                <div>
                  <h3>{safeText(step.title)}</h3>
                  {'timeframe' in step && step.timeframe && <em>{safeText(step.timeframe)}</em>}
                  <p>{safeText(step.description)}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="section documentation-section" aria-labelledby="documentation-title">
        <div class="detail-shell documentation-grid">
          <div>
            <p class="eyebrow">Documentation + equipment proof</p>
            <h2 id="documentation-title">Scope notes that keep stakeholders aligned</h2>
            <p>Documentation support is not a coverage promise. It is the practical record of source, materials, photos, moisture observations, operations impacts, and next-step decisions.</p>
            <ol class="doc-list">
              {documentationItems.map((item) => <li>{safeText(item)}</li>)}
            </ol>
          </div>
          <div class="proof-tool-grid">
            {equipmentProof.map((item) => (
              <article>
                <span>{safeText(item.label)}</span>
                <p>{safeText(item.body)}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      {cityContent?.localChallenges && cityContent.localChallenges.length > 0 && (
        <section class="section challenges-section" aria-labelledby="challenges-title">
          <div class="detail-shell">
            <div class="split-heading">
              <div>
                <p class="eyebrow">Local challenges</p>
                <h2 id="challenges-title">{cityData.name} conditions we plan around</h2>
              </div>
              <p>Generated city content is preserved here, but grouped into problem-and-response cards for easier scanning.</p>
            </div>
            <div class="challenge-grid">
              {cityContent.localChallenges.map((challenge) => (
                <article class="challenge-card">
                  <h3>{safeText(challenge.title)}</h3>
                  <p>{safeText(challenge.description)}</p>
                  <div>
                    <span>Our response</span>
                    <p>{safeText(challenge.solution)}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>
      )}

      {cityContent?.equipmentSection && (
        <section class="section equipment-section" aria-labelledby="equipment-title">
          <div class="detail-shell">
            <div class="split-heading">
              <div>
                <p class="eyebrow">Equipment</p>
                <h2 id="equipment-title">{safeText(cityContent.equipmentSection.headline)}</h2>
              </div>
              <p>{safeText(cityContent.equipmentSection.localNote)}</p>
            </div>
            <div class="equipment-grid">
              {cityContent.equipmentSection.equipment.map((item) => (
                <article class="equipment-card">
                  <h3>{safeText(item.name)}</h3>
                  {item.brand && <span>{safeText(item.brand)}</span>}
                  <p>{safeText(item.purpose)}</p>
                </article>
              ))}
            </div>
          </div>
        </section>
      )}

      {cityContent?.pricingSection && (
        <section class="section pricing-section" aria-labelledby="pricing-title">
          <div class="detail-shell pricing-panel">
            <div>
              <p class="eyebrow">Cost factors</p>
              <h2 id="pricing-title">{safeText(cityContent.pricingSection.headline)}</h2>
              <p>{safeText(cityContent.pricingSection.intro)}</p>
              <strong>{safeText(cityContent.pricingSection.cta)}</strong>
            </div>
            <ul>
              {cityContent.pricingSection.factors.map((factor) => <li>{safeText(factor)}</li>)}
            </ul>
          </div>
        </section>
      )}

      {isCityVariant && cityContent?.serviceAreaSection && (cityContent.serviceAreaSection.responseTime || cityServiceAreaChips.length > 0 || nearbyCommunityChips.length > 0) && (
        <section class="section area-section" aria-labelledby="area-title">
          <div class="detail-shell area-panel">
            <div>
              <p class="eyebrow">Service area</p>
              <h2 id="area-title">{service.name} throughout {cityData.name}</h2>
              {cityContent.serviceAreaSection.responseTime && <p>{safeText(cityContent.serviceAreaSection.responseTime)}</p>}
            </div>
            <div class="area-chip-stack">
              {cityServiceAreaChips.length > 0 && (
                <div class="neighborhoods" aria-label="Neighborhoods and local service areas">
                  {cityServiceAreaChips.map((n) => <span>{safeText(n)}</span>)}
                </div>
              )}
              {nearbyCommunityChips.length > 0 && (
                <div class="nearby-communities" aria-label="Nearby communities">
                  <strong>Nearby communities</strong>
                  <div class="neighborhoods nearby-list">
                    {nearbyCommunityChips.map((n) => <span>{safeText(n)}</span>)}
                  </div>
                </div>
              )}
            </div>
          </div>
        </section>
      )}

      <section class="section related-section" aria-labelledby="related-title">
        <div class="detail-shell related-grid">
          <div>
            <p class="eyebrow">Related internal links</p>
            <h2 id="related-title">Keep moving through the service map</h2>
            <p>Related services and adjacent pages help narrow the scope without changing the canonical route or generated content.</p>
          </div>
          <div class="related-cards">
            {siblingServices.map((node) => (
              <a href={node.path} class="related-card">
                <strong>{node.name}</strong>
                <span>{safeText(node.description)}</span>
              </a>
            ))}
            {service.relatedFeatures.slice(0, 4).map((feature) => (
              <article class="related-card muted-card">
                <strong>{safeText(feature.name)}</strong>
                <span>{safeText(feature.description)}</span>
              </article>
            ))}
          </div>
        </div>
      </section>

      {relatedBlogs.length > 0 && (
        <section class="section articles-section" aria-labelledby="articles-title">
          <div class="detail-shell">
            <div class="split-heading">
              <div>
                <p class="eyebrow">Learn more</p>
                <h2 id="articles-title">Related articles</h2>
              </div>
              <p>City-specific editorial links are preserved when the generated content provides them.</p>
            </div>
            <div class="article-grid">
              {relatedBlogs.map((post) => (
                <a href={post.href} class="article-card">
                  <img src={post.imageUrl} alt={post.title} loading="lazy" decoding="async" width="640" height="360" />
                  <div>
                    <span>{post.category.title}</span>
                    <strong>{post.title}</strong>
                    <p>{safeText(post.description)}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="section faq-section" aria-labelledby="faq-title">
        <div class="detail-shell faq-wrap">
          <p class="eyebrow">FAQ</p>
          <h2 id="faq-title">Frequently asked questions</h2>
          <FAQAccordion client:visible faqs={safeFaqs} />
        </div>
      </section>

      <section class="final-cta" aria-labelledby="final-title">
        <div class="detail-shell final-panel">
          <div>
            <p class="eyebrow">Request Service / Call Now</p>
            <h2 id="final-title">{safeText(cityContent?.finalCTA?.headline ?? `Need ${service.name} in ${cityData.name}?`)}</h2>
            <p>{safeText(cityContent?.finalCTA?.paragraph ?? 'Share what happened, where water or contamination traveled, and whether the source is controlled. Call if the situation is active or unsafe.')}</p>
          </div>
          <div class="action-row final-actions">
            <a class="fd-btn fd-btn-primary" href={cityPhoneHref}>Call Now {cityData.phone}</a>
            <a class="fd-btn fd-btn-outline" href="/request">{cityRequestLabel}</a>
          </div>
        </div>
      </section>
    </main>
  </BaseLayout>
) : (
  <BaseLayout title="Not Found" noIndex>
    <div class="not-found-panel">
      <h1>Page not found</h1>
      <p>The service you're looking for doesn't exist.</p>
      <a href="/services/commercial">Back to Commercial Services</a>
    </div>
  </BaseLayout>
)}

