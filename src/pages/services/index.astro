---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Icon from '../../components/Icon.astro'
import FAQAccordion from '../../components/islands/FAQAccordion.tsx'
import { cityData } from '../../data/cities'
import { allServices } from '../../data/services'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Restoration Services in ${cityData.name}`,
  description: `Professional water damage restoration, mold remediation, and emergency cleanup services in ${cityData.name}, ${cityData.state}.`,
  itemListElement: allServices.map((service, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Service',
      name: service.name,
      url: `/services/${service.slug}`,
    },
  })),
}

const serviceCategories = [
  {
    name: 'Water Damage Restoration',
    description: 'Emergency water extraction, structural drying, and complete property restoration from any water damage event.',
    href: '/services/water-damage-restoration',
    icon: 'bolt',
  },
  {
    name: 'Mold Remediation',
    description: 'Professional mold inspection, containment, removal, and prevention to protect your family\'s health.',
    href: '/services/mold-remediation',
    icon: 'shield-check',
  },
  {
    name: 'Flood Cleanup',
    description: 'Comprehensive flood damage cleanup including debris removal, sanitization, and structural assessment.',
    href: '/services/flood-cleanup',
    icon: 'cloud-arrow-up',
  },
  {
    name: 'Sewage Cleanup',
    description: 'Safe handling and disposal of Category 3 black water contamination with full decontamination protocols.',
    href: '/services/sewage-cleanup',
    icon: 'beaker',
  },
  {
    name: 'Structural Drying',
    description: 'Advanced commercial drying systems with daily moisture monitoring to achieve pre-loss conditions.',
    href: '/services/structural-drying',
    icon: 'home-modern',
  },
  {
    name: 'Emergency Board-Up',
    description: 'Immediate property securing with board-up, roof tarping, and temporary barriers to prevent further damage.',
    href: '/services/emergency-board-up',
    icon: 'lock-closed',
  },
]

const stats = [
  { label: 'Years of Experience', value: '15+' },
  { label: 'Certified Technicians', value: '24' },
  { label: 'Cities Served', value: '13' },
  { label: 'Insurance Partners', value: '45+' },
]

const faqs = [
  { question: 'What services do you offer?', answer: 'We provide comprehensive water damage restoration services including emergency water extraction, structural drying, mold remediation, flood cleanup, sewage cleanup, content restoration, reconstruction, and insurance coordination.' },
  { question: 'Do you offer free estimates?', answer: 'Yes, we provide free on-site estimates for all restoration services. Our certified estimators will assess the damage, document everything for insurance purposes, and provide a detailed scope of work.' },
  { question: 'Are your technicians certified?', answer: 'All of our technicians hold IICRC certifications in water damage restoration (WRT), applied structural drying (ASD), and mold remediation. We maintain ongoing training to stay current with industry best practices.' },
  { question: 'What areas do you serve?', answer: `We serve ${cityData.name} and surrounding communities including ${cityData.serviceAreas?.slice(0, 5).join(', ') || 'the greater metro area'}. Contact us to confirm coverage for your location.` },
]
---

<BaseLayout
  title="Our Services"
  description={`Professional water damage restoration services in ${cityData.name}. Emergency response, mold remediation, flood cleanup, and more.`}
  structuredData={structuredData}
>
  <!-- ═══ HERO ═══ -->
  <div class="relative isolate">
    <svg
      aria-hidden="true"
      class="absolute inset-x-0 top-0 -z-10 h-[64rem] w-full mask-[radial-gradient(32rem_32rem_at_center,white,transparent)] stroke-gray-200 dark:stroke-white/10"
    >
      <defs>
        <pattern x="50%" y="-1" id="services-hero-pattern" width="200" height="200" patternUnits="userSpaceOnUse">
          <path d="M.5 200V.5H200" fill="none" />
        </pattern>
      </defs>
      <svg x="50%" y="-1" class="overflow-visible fill-gray-100 dark:fill-gray-800">
        <path d="M-200 0h201v201h-201Z M600 0h201v201h-201Z M-400 600h201v201h-201Z M200 800h201v201h-201Z" stroke-width="0" />
      </svg>
      <rect fill="url(#services-hero-pattern)" width="100%" height="100%" stroke-width="0" />
    </svg>
    <div
      aria-hidden="true"
      class="absolute top-0 right-0 left-1/2 -z-10 -ml-24 transform-gpu overflow-hidden blur-3xl lg:ml-24 xl:ml-48"
    >
      <div
        style="clip-path: polygon(63.1% 29.5%, 100% 17.1%, 76.6% 3%, 48.4% 0%, 44.6% 4.7%, 54.5% 25.3%, 59.8% 49%, 55.2% 57.8%, 44.4% 57.2%, 27.8% 47.9%, 35.1% 81.5%, 0% 97.7%, 39.2% 100%, 35.2% 81.4%, 97.2% 52.8%, 63.1% 29.5%)"
        class="aspect-[801/1036] w-[50.0625rem] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 dark:opacity-30"
      ></div>
    </div>
    <div class="overflow-hidden">
      <div class="mx-auto max-w-7xl px-6 pt-36 pb-32 sm:pt-60 lg:px-8 lg:pt-32">
        <div class="mx-auto max-w-2xl gap-x-14 lg:mx-0 lg:flex lg:max-w-none lg:items-center">
          <div class="relative w-full lg:max-w-xl lg:shrink-0 xl:max-w-2xl">
            <h1 class="text-5xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-7xl">
              Restoration Services in {cityData.name}
            </h1>
            <p class="mt-8 text-lg font-medium text-pretty text-gray-600 dark:text-gray-400 sm:max-w-md sm:text-xl/8 lg:max-w-none">
              From emergency water extraction to complete reconstruction, our IICRC-certified team handles every
              aspect of property restoration. Available 24/7 with guaranteed 60-minute response times.
            </p>
            <div class="mt-10 flex items-center gap-x-6">
              <a
                href="/request"
                class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"
              >
                Get a Free Estimate
              </a>
              <a href={`tel:${cityData.phone.replace(/[^0-9+]/g, '')}`} class="text-sm/6 font-semibold text-gray-900 dark:text-white">
                Call {cityData.phone} <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
          <div class="mt-14 flex justify-end gap-8 sm:-mt-44 sm:justify-start sm:pl-20 lg:mt-0 lg:pl-0">
            <div class="ml-auto w-44 flex-none space-y-8 pt-32 sm:ml-0 sm:pt-80 lg:order-last lg:pt-36 xl:order-0 xl:pt-80">
              <div class="relative">
                <img alt="Water extraction" src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
            </div>
            <div class="mr-auto w-44 flex-none space-y-8 sm:mr-0 sm:pt-52 lg:pt-36">
              <div class="relative">
                <img alt="Drying equipment" src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
              <div class="relative">
                <img alt="Moisture testing" src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
            </div>
            <div class="w-44 flex-none space-y-8 pt-32 sm:pt-0">
              <div class="relative">
                <img alt="Restored property" src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
              <div class="relative">
                <img alt="Professional team" src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ LOGO CLOUD ═══ -->
  <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 class="text-center text-lg/8 font-semibold text-gray-900 dark:text-white">Certified & Trusted by Industry Leaders</h2>
      <div class="mx-auto mt-10 grid max-w-lg grid-cols-4 items-center gap-x-8 gap-y-10 sm:max-w-xl sm:grid-cols-6 sm:gap-x-10 lg:mx-0 lg:max-w-none lg:grid-cols-5">
        <img alt="IICRC Certified" src="https://tailwindcss.com/plus-assets/img/logos/158x48/transistor-logo-white.svg" width="158" height="48" class="col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 lg:col-span-1" />
        <img alt="RIA Member" src="https://tailwindcss.com/plus-assets/img/logos/158x48/reform-logo-white.svg" width="158" height="48" class="col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 lg:col-span-1" />
        <img alt="EPA Lead-Safe" src="https://tailwindcss.com/plus-assets/img/logos/158x48/tuple-logo-white.svg" width="158" height="48" class="col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 lg:col-span-1" />
        <img alt="BBB Accredited" src="https://tailwindcss.com/plus-assets/img/logos/158x48/savvycal-logo-white.svg" width="158" height="48" class="col-span-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 sm:col-start-2 lg:col-span-1" />
        <img alt="State Farm Partner" src="https://tailwindcss.com/plus-assets/img/logos/158x48/statamic-logo-white.svg" width="158" height="48" class="col-span-2 col-start-2 max-h-12 w-full object-contain dark:brightness-100 brightness-0 sm:col-start-auto lg:col-span-1" />
      </div>
    </div>
  </div>

  <!-- ═══ CONTENT — Sticky screenshot layout ═══ -->
  <div class="relative isolate overflow-hidden bg-white dark:bg-gray-900 px-6 py-24 sm:py-32 lg:overflow-visible lg:px-0">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <svg
        aria-hidden="true"
        class="absolute top-0 left-[max(50%,25rem)] h-[64rem] w-[128rem] -translate-x-1/2 mask-[radial-gradient(64rem_64rem_at_top,white,transparent)] stroke-gray-200 dark:stroke-gray-800"
      >
        <defs>
          <pattern x="50%" y="-1" id="services-content-pattern" width="200" height="200" patternUnits="userSpaceOnUse">
            <path d="M100 200V.5M.5 .5H200" fill="none" />
          </pattern>
        </defs>
        <svg x="50%" y="-1" class="overflow-visible fill-gray-100 dark:fill-gray-800/50">
          <path d="M-100.5 0h201v201h-201Z M699.5 0h201v201h-201Z M499.5 400h201v201h-201Z M-300.5 600h201v201h-201Z" stroke-width="0" />
        </svg>
        <rect fill="url(#services-content-pattern)" width="100%" height="100%" stroke-width="0" />
      </svg>
    </div>
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-start lg:gap-y-10">
      <div class="lg:col-span-2 lg:col-start-1 lg:row-start-1 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8">
        <div class="lg:pr-4">
          <div class="lg:max-w-lg">
            <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Full-Service Restoration</p>
            <h2 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
              One Call Handles It All
            </h2>
            <p class="mt-6 text-xl/8 text-gray-600 dark:text-gray-300">
              When water damage strikes, you need a single team that can handle everything — from the initial emergency response
              through complete reconstruction. That's exactly what Flood Doctor delivers.
            </p>
          </div>
        </div>
      </div>
      <div class="-mt-12 -ml-12 p-12 lg:sticky lg:top-4 lg:col-start-2 lg:row-span-2 lg:row-start-1 lg:overflow-hidden">
        <img
          alt="Flood Doctor restoration process"
          src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1470&q=80"
          class="w-[48rem] max-w-none rounded-xl bg-gray-100 dark:bg-gray-800 shadow-xl ring-1 ring-gray-200 dark:ring-white/10 sm:w-[57rem]"
        />
      </div>
      <div class="lg:col-span-2 lg:col-start-1 lg:row-start-2 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8">
        <div class="lg:pr-4">
          <div class="max-w-xl text-base/7 text-gray-600 dark:text-gray-400 lg:max-w-lg">
            <p>
              Our IICRC-certified technicians bring years of hands-on experience to every project. We follow
              industry-standard protocols (S500, S520) and use state-of-the-art equipment including thermal imaging
              cameras, commercial dehumidifiers, and industrial air movers.
            </p>
            <ul role="list" class="mt-8 space-y-8 text-gray-600 dark:text-gray-400">
              <li class="flex gap-x-3">
                <Icon name="bolt" class="mt-1 size-5 flex-none text-indigo-600 dark:text-indigo-400" />
                <span>
                  <strong class="font-semibold text-gray-900 dark:text-white">60-Minute Response.</strong> Our strategically
                  stationed teams guarantee arrival within one hour of your emergency call, 24/7/365.
                </span>
              </li>
              <li class="flex gap-x-3">
                <Icon name="shield-check" class="mt-1 size-5 flex-none text-indigo-600 dark:text-indigo-400" />
                <span>
                  <strong class="font-semibold text-gray-900 dark:text-white">Insurance Direct Billing.</strong> We work with all
                  major carriers and handle claims documentation, so you never have to chase paperwork.
                </span>
              </li>
              <li class="flex gap-x-3">
                <Icon name="wrench-screwdriver" class="mt-1 size-5 flex-none text-indigo-600 dark:text-indigo-400" />
                <span>
                  <strong class="font-semibold text-gray-900 dark:text-white">Complete Reconstruction.</strong> From drywall and
                  flooring to cabinetry and paint — we rebuild everything to pre-loss condition.
                </span>
              </li>
            </ul>
            <p class="mt-8">
              Every property and every water damage event is unique. That's why we create a customized restoration
              plan for each project, tailored to the specific type of damage, affected materials, and your
              property's construction.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ SERVICE CATEGORIES — Feature grid ═══ -->
  <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Our Specialties</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
          Comprehensive Restoration Services
        </p>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
          Professional restoration services tailored to every type of water damage emergency in {cityData.name}.
        </p>
      </div>
      <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 text-base/7 text-gray-600 dark:text-gray-400 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 lg:gap-x-16">
        {serviceCategories.map((service) => (
          <div class="relative pl-9">
            <dt class="inline font-semibold text-gray-900 dark:text-white">
              <Icon name={service.icon} class="absolute top-1 left-1 size-5 text-indigo-600 dark:text-indigo-500" />
              <a href={service.href} class="hover:text-indigo-600 dark:hover:text-indigo-400">{service.name}</a>
            </dt>{' '}
            <dd class="inline">{service.description}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- ═══ STATS + ABOUT ═══ -->
  <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">
        <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Why Flood Doctor</p>
        <h2 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
          {cityData.name}'s Preferred Restoration Company
        </h2>
        <div class="mt-10 grid max-w-xl grid-cols-1 gap-8 text-base/7 text-gray-600 dark:text-gray-300 lg:max-w-none lg:grid-cols-2">
          <div>
            <p>
              For over 15 years, Flood Doctor has been the trusted name in water damage restoration across
              Northern Virginia. Our commitment to fast response, quality craftsmanship, and transparent
              communication has earned us the trust of thousands of homeowners and dozens of insurance partners.
            </p>
            <p class="mt-8">
              Every member of our team holds IICRC certifications and undergoes continuous training on the
              latest restoration techniques and equipment. When you call Flood Doctor, you're getting the
              most qualified team in the region.
            </p>
          </div>
          <div>
            <p>
              We understand that water damage is more than just a property issue — it's a disruption to your
              life. That's why we assign a dedicated project manager to every job, serving as your single
              point of contact from the initial emergency call through final walkthrough.
            </p>
            <p class="mt-8">
              Our direct billing relationships with all major insurance carriers mean less hassle for you.
              We handle the documentation, communication, and payment coordination so you can focus on
              what matters most.
            </p>
          </div>
        </div>
        <dl class="mt-16 grid grid-cols-1 gap-x-8 gap-y-12 sm:mt-20 sm:grid-cols-2 sm:gap-y-16 lg:mt-28 lg:grid-cols-4">
          {stats.map((stat) => (
            <div class="flex flex-col-reverse gap-y-3 border-l border-gray-300 dark:border-white/20 pl-6">
              <dt class="text-base/7 text-gray-600 dark:text-gray-300">{stat.label}</dt>
              <dd class="text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>

  <!-- ═══ BENTO GRID — Service showcase ═══ -->
  <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
      <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Our Process</h2>
      <p class="mt-2 max-w-lg text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
        From Emergency to Restored
      </p>
      <div class="mt-10 grid grid-cols-1 gap-4 sm:mt-16 lg:grid-cols-6 lg:grid-rows-2">
        <div class="relative lg:col-span-3">
          <div class="absolute inset-0 rounded-lg bg-white dark:bg-gray-800 max-lg:rounded-t-[2rem] lg:rounded-tl-[2rem]" />
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] max-lg:rounded-t-[calc(2rem+1px)] lg:rounded-tl-[calc(2rem+1px)]">
            <img alt="Emergency response" src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" class="h-80 object-cover object-left" />
            <div class="p-10 pt-4">
              <h3 class="text-sm/4 font-semibold text-indigo-600 dark:text-indigo-400">Step 1</h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-900 dark:text-white">Emergency Response & Assessment</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400">
                Within 60 minutes, our certified team arrives with thermal imaging cameras and moisture meters
                to map the full extent of damage and create your restoration plan.
              </p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm outline outline-1 outline-gray-200 dark:outline-white/15 max-lg:rounded-t-[2rem] lg:rounded-tl-[2rem]" />
        </div>
        <div class="relative lg:col-span-3">
          <div class="absolute inset-0 rounded-lg bg-white dark:bg-gray-800 lg:rounded-tr-[2rem]" />
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] lg:rounded-tr-[calc(2rem+1px)]">
            <img alt="Water extraction" src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" class="h-80 object-cover object-left lg:object-right" />
            <div class="p-10 pt-4">
              <h3 class="text-sm/4 font-semibold text-indigo-600 dark:text-indigo-400">Step 2</h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-900 dark:text-white">Water Extraction & Drying</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400">
                Industrial-grade pumps remove standing water, followed by strategic placement of commercial
                dehumidifiers and air movers for complete structural drying.
              </p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm outline outline-1 outline-gray-200 dark:outline-white/15 lg:rounded-tr-[2rem]" />
        </div>
        <div class="relative lg:col-span-2">
          <div class="absolute inset-0 rounded-lg bg-white dark:bg-gray-800 lg:rounded-bl-[2rem]" />
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] lg:rounded-bl-[calc(2rem+1px)]">
            <div class="p-10">
              <h3 class="text-sm/4 font-semibold text-indigo-600 dark:text-indigo-400">Step 3</h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-900 dark:text-white">Mold Prevention</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400">
