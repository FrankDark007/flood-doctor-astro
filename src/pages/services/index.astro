---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Icon from '../../components/Icon.astro'
import FAQAccordion from '../../components/islands/FAQAccordion.tsx'
import { cityData } from '../../data/cities'
import { getDivisionCategories } from '../../data/services/service-tree'
import { breadcrumbSchema, cityBaseUrl } from '../../utils/schema'
import { toTelHref } from '../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)
const _base = cityBaseUrl()

const residentialCategories = getDivisionCategories('residential')
const commercialCategories = getDivisionCategories('commercial')

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `Restoration Services in ${cityData.name}`,
    description: `Professional water damage restoration, mold remediation, and emergency cleanup services in ${cityData.name}, ${cityData.state}.`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, item: { '@type': 'Service', name: 'Residential Services', url: `${_base}/services/residential/` } },
      { '@type': 'ListItem', position: 2, item: { '@type': 'Service', name: 'Commercial Services', url: `${_base}/services/commercial/` } },
    ],
  },
  breadcrumbSchema([
    { name: 'Home', url: `${_base}/` },
    { name: 'Services', url: `${_base}/services/` },
  ]),
]

const serviceStandards = [
  { label: 'Emergency intake', value: '24/7', body: 'Tell us what happened, what is still wet, and whether the source is controlled.' },
  { label: 'Property types', value: 'Home + business', body: 'Residential rooms, commercial spaces, specialty facilities, and multi-unit properties.' },
  { label: 'Documentation', value: 'Photos + notes', body: 'Scope notes and moisture details help keep owners, managers, and carriers aligned.' },
  { label: 'Next step', value: 'Request or call', body: 'Use the form for service details; call when water is active or safety is uncertain.' },
]

const faqs = [
  { question: 'What services do you offer?', answer: 'We provide comprehensive water damage restoration services for both residential and commercial properties, including emergency water extraction, structural drying, mold remediation, flood cleanup, sewage cleanup, fire and smoke restoration, content restoration, and insurance coordination.' },
  { question: 'How do service requests work?', answer: 'Submit the request form or call us. We confirm the issue, collect the property details, and explain the next steps before dispatch or scheduling.' },
  { question: 'Who handles the restoration work?', answer: 'Restoration crews use industry-standard drying, cleanup, and documentation practices. Call us to confirm availability and service details for your property.' },
  { question: 'What areas do you serve?', answer: `We serve ${cityData.name} and surrounding communities including ${cityData.serviceArea?.slice(0, 5).join(', ') || 'the greater metro area'}. Contact us to confirm coverage for your location.` },
]
---

<BaseLayout
  title={`Our Services | Flood Doctor ${cityData.name}`}
  description={`Professional water damage restoration services in ${cityData.name}. Residential and commercial emergency response, mold remediation, flood cleanup, and more.`}
  structuredData={structuredData}
>
  <main class="service-system">
    <section class="command-hero" aria-labelledby="services-title">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="service-shell hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Emergency Service Command Center</p>
          <h1 id="services-title">Restoration Services in {cityData.name}</h1>
          <p class="hero-lede">
            Water damage gets expensive when decisions are delayed. Start here to route the right residential or
            commercial response: intake, water removal, drying, cleanup, documentation, and next-step repair planning.
          </p>
          <div class="action-row" aria-label="Service request actions">
            <a class="fd-btn fd-btn-primary" href="/request">Request Emergency Service</a>
            <a class="fd-btn fd-btn-secondary" href={cityPhoneHref}>Call {cityData.phone}</a>
          </div>
        </div>
        <aside class="command-panel" aria-label="Emergency triage priorities">
          <span class="panel-kicker">When to call now</span>
          <ul>
            <li>Water is still entering or spreading.</li>
            <li>Electrical, sewage, ceiling, or structural hazards are possible.</li>
            <li>Wet drywall, flooring, insulation, or contents need documentation.</li>
          </ul>
          <a href={cityPhoneHref}>Call Now <span aria-hidden="true">&rarr;</span></a>
        </aside>
      </div>
    </section>

    <section class="choice-section" aria-labelledby="service-paths-title">
      <div class="service-shell">
        <div class="split-heading">
          <div>
            <p class="eyebrow">Choose the property type</p>
            <h2 id="service-paths-title">Two service paths, one emergency-first system</h2>
          </div>
          <p>
            Each hub groups services by what has to happen next: stabilize the loss, remove water or contamination,
            dry affected materials, and organize the documentation.
          </p>
        </div>
        <div class="division-grid">
          <article class="division-card division-card-blue">
            <span class="division-tag">For homeowners</span>
            <h3><a href="/services/residential">Residential Services</a></h3>
            <p>Water damage, flood cleanup, mold remediation, and specialty drying for houses, townhomes, condos, and basements.</p>
            <div class="mini-card-grid">
              {residentialCategories.map((category) => (
                <a href={category.path} class="mini-card">
                  <Icon name={category.icon || 'check'} class="mini-icon" />
                  <span>{category.name}</span>
                </a>
              ))}
            </div>
          </article>
          <article class="division-card division-card-navy">
            <span class="division-tag">For businesses</span>
            <h3><a href="/services/commercial">Commercial Services</a></h3>
            <p>Large-loss response, commercial cleanup, specialty facilities, technical consulting, and downtime-aware coordination.</p>
            <div class="mini-card-grid">
              {commercialCategories.map((category) => (
                <a href={category.path} class="mini-card">
                  <Icon name={category.icon || 'check'} class="mini-icon" />
                  <span>{category.name}</span>
                </a>
              ))}
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="standards-section" aria-labelledby="standards-title">
      <div class="service-shell">
        <div class="section-heading">
          <p class="eyebrow">Operating standards</p>
          <h2 id="standards-title">Built for urgent property damage, not generic lead capture</h2>
        </div>
        <div class="standards-grid">
          {serviceStandards.map((stat) => (
            <article class="standard-card">
              <span>{stat.label}</span>
              <strong>{stat.value}</strong>
              <p>{stat.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-section" aria-labelledby="services-cta-title">
      <div class="service-shell cta-panel">
        <div>
          <p class="eyebrow">Water damage emergency?</p>
          <h2 id="services-cta-title">Tell us what happened and where the water went</h2>
          <p>Request service so intake can confirm details and coordinate the right restoration response for {cityData.name}.</p>
        </div>
        <div class="action-row cta-actions">
          <a class="fd-btn fd-btn-primary" href="/request">Request Emergency Service</a>
          <a class="fd-btn fd-btn-outline" href={cityPhoneHref}>Call {cityData.phone}</a>
        </div>
      </div>
    </section>

    <section class="faq-section" aria-labelledby="services-faq-title">
      <div class="service-shell faq-wrap">
        <p class="eyebrow">FAQ</p>
        <h2 id="services-faq-title">Frequently asked questions</h2>
        <FAQAccordion client:visible faqs={faqs} />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .service-system {
    --navy: #06172e;
    --navy-2: #08203f;
    --blue: #1478e6;
    --blue-dark: #0b63ce;
    --orange: #d94a12;
    --orange-dark: #b9380c;
    --ink: #102033;
    --muted: #53647a;
    --line: #d9e6f5;
    --soft: #f4f9ff;
    width: 100%;
    max-width: 100%;
    overflow-x: clip;
    background: #ffffff;
    color: var(--ink);
    font-family: 'Avenir Next', 'Trebuchet MS', Verdana, sans-serif;
  }

  .service-shell {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .command-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 18%, rgba(20, 120, 230, 0.28), transparent 24rem),
      linear-gradient(135deg, var(--navy), var(--navy-2));
    padding: clamp(5rem, 9vw, 8rem) 0 clamp(4rem, 7vw, 6rem);
  }

  .command-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255,255,255,.055) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.055) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(180deg, black, transparent 82%);
    z-index: -1;
  }

  .hero-glow {
    position: absolute;
    right: -12rem;
    bottom: -18rem;
    width: min(46rem, 90vw);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(217, 74, 18, 0.28), transparent 64%);
    z-index: -1;
  }

  .hero-grid,
  .split-heading,
  .cta-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 .75rem;
    color: var(--orange);
    font-size: .78rem;
    font-weight: 900;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .command-hero .eyebrow,
  .cta-section .eyebrow,
  .division-card-navy .division-tag {
    color: #fed7aa;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: -.055em;
    line-height: 1;
  }

  h1 {
    max-width: 11ch;
    color: #ffffff;
    font-size: clamp(2.6rem, 8vw, 5.6rem);
    font-weight: 920;
  }

  h2 {
    color: var(--navy);
    font-size: clamp(2rem, 4.4vw, 3.4rem);
    font-weight: 880;
  }

  h3 {
    color: var(--navy);
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    font-weight: 880;
  }

  .hero-lede,
  .split-heading > p,
  .section-heading + p,
  .cta-panel p {
    margin: 1.25rem 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.16rem);
    font-weight: 560;
    line-height: 1.75;
  }

  .hero-lede,
  .command-panel li {
    color: #c9d7e8;
  }

  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: .85rem;
    margin-top: 1.8rem;
  }

  .command-panel {
    min-width: 0;
    border: 1px solid rgba(255,255,255,.14);
    border-radius: 1.5rem;
    background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.06));
    box-shadow: 0 24px 80px rgba(6, 23, 46, .34);
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .panel-kicker,
  .division-tag,
  .standard-card span {
    display: block;
    color: var(--blue-dark);
    font-size: .76rem;
    font-weight: 900;
    letter-spacing: .11em;
    text-transform: uppercase;
  }

  .command-panel ul {
    display: grid;
    gap: .9rem;
    margin: 1.25rem 0;
    padding: 0;
    list-style: none;
  }

  .command-panel li {
    position: relative;
    padding-left: 1.35rem;
    line-height: 1.55;
  }

  .command-panel li::before {
    content: '';
    position: absolute;
    top: .58rem;
    left: 0;
    width: .5rem;
    height: .5rem;
    border-radius: 999px;
    background: var(--orange);
  }

  .command-panel a,
  .mini-card,
  .division-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .command-panel a {
    color: #ffffff;
    font-weight: 850;
  }

  .choice-section,
  .standards-section,
  .faq-section {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
  }

  .choice-section,
  .faq-section {
    background: linear-gradient(180deg, #f7fbff, #ffffff);
  }

  .division-grid,
  .standards-grid,
  .mini-card-grid {
    display: grid;
    gap: 1rem;
  }

  .division-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 2rem;
  }

  .division-card,
  .standard-card {
    min-width: 0;
    border-radius: 1.5rem;
    box-shadow: 0 18px 55px rgba(6, 23, 46, .12);
  }

  .division-card {
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .division-card-blue {
    border: 1px solid rgba(20, 120, 230, .18);
    background: linear-gradient(135deg, #ffffff, #eef6ff);
  }

  .division-card-navy {
    border: 1px solid rgba(255,255,255,.12);
    background:
      radial-gradient(circle at top right, rgba(20, 120, 230, .24), transparent 22rem),
      linear-gradient(135deg, var(--navy-2), var(--navy));
  }

  .division-card-navy h3,
  .division-card-navy p {
    color: #ffffff;
  }

  .division-card p,
  .standard-card p {
    margin: 1rem 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .division-card-navy p {
    color: #c9d7e8;
  }

  .mini-card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1.4rem;
  }

  .mini-card {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: .7rem;
    border: 1px solid rgba(15,79,184,.14);
    border-radius: 1rem;
    background: rgba(255,255,255,.82);
    padding: .85rem;
    color: var(--navy);
    font-weight: 800;
    line-height: 1.2;
  }

  .division-card-navy .mini-card {
    border-color: rgba(255,255,255,.14);
    background: rgba(255,255,255,.08);
    color: #ffffff;
  }

  .mini-icon {
    width: 1.1rem;
    height: 1.1rem;
    flex: 0 0 auto;
    color: var(--blue-dark);
  }

  .division-card-navy .mini-icon {
    color: #93c5fd;
  }

  .standards-section {
    background: #ffffff;
  }

  .standards-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 2rem;
  }

  .standard-card {
    border: 1px solid var(--line);
    background: #ffffff;
    padding: 1.25rem;
  }

  .standard-card strong {
    display: block;
    margin-top: .7rem;
    color: var(--navy);
    font-size: 1.45rem;
    letter-spacing: -.04em;
    line-height: 1;
  }

  .cta-section {
    background: var(--navy);
    color: #ffffff;
    padding: clamp(4rem, 7vw, 6rem) 0;
  }

  .cta-section h2,
  .cta-section p {
    color: #ffffff;
  }

  .cta-actions {
    justify-content: end;
  }

  .faq-wrap {
    max-width: 56rem;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .split-heading,
    .cta-panel,
    .division-grid,
    .standards-grid {
      grid-template-columns: 1fr;
    }

    .cta-actions {
      justify-content: start;
    }
  }

  @media (max-width: 560px) {
    .service-shell {
      width: min(100% - 1.25rem, 1120px);
    }

    h1 {
      max-width: 100%;
      font-size: clamp(2.2rem, 11vw, 3rem);
    }

    .action-row {
      flex-direction: column;
    }

    .action-row :global(.fd-btn) {
      width: 100%;
    }

    .mini-card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
