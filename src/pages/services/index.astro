---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Icon from '../../components/Icon.astro'
import LogoCloud from '../../components/sections/LogoCloud.astro'
import CTABand from '../../components/sections/CTABand.astro'
import TestimonialSection from '../../components/sections/TestimonialSection.astro'
import FAQAccordion from '../../components/islands/FAQAccordion.tsx'
import { cityData } from '../../data/cities'
import { serviceTree, getDivisionCategories } from '../../data/services/service-tree'
import { toTelHref } from '../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)

const residentialCategories = getDivisionCategories('residential')
const commercialCategories = getDivisionCategories('commercial')

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Restoration Services in ${cityData.name}`,
  description: `Professional water damage restoration, mold remediation, and emergency cleanup services in ${cityData.name}, ${cityData.state}.`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, item: { '@type': 'Service', name: 'Residential Services', url: '/services/residential' } },
    { '@type': 'ListItem', position: 2, item: { '@type': 'Service', name: 'Commercial Services', url: '/services/commercial' } },
  ],
}

const stats = [
  { label: 'Years of Experience', value: '15+' },
  { label: 'Certified Technicians', value: '24' },
  { label: 'Cities Served', value: '17' },
  { label: 'Insurance Partners', value: '45+' },
]

const faqs = [
  { question: 'What services do you offer?', answer: 'We provide comprehensive water damage restoration services for both residential and commercial properties, including emergency water extraction, structural drying, mold remediation, flood cleanup, sewage cleanup, fire and smoke restoration, content restoration, and insurance coordination.' },
  { question: 'Do you offer free estimates?', answer: 'Yes, we provide free on-site estimates for all restoration services. Our certified estimators will assess the damage, document everything for insurance purposes, and provide a detailed scope of work.' },
  { question: 'Are your technicians certified?', answer: 'All of our technicians hold IICRC certifications in water damage restoration (WRT), applied structural drying (ASD), and mold remediation. We maintain ongoing training to stay current with industry best practices.' },
  { question: 'What areas do you serve?', answer: `We serve ${cityData.name} and surrounding communities including ${cityData.serviceAreas?.slice(0, 5).join(', ') || 'the greater metro area'}. Contact us to confirm coverage for your location.` },
]
---

<BaseLayout
  title={`Our Services | Flood Doctor ${cityData.name}`}
  description={`Professional water damage restoration services in ${cityData.name}. Residential and commercial emergency response, mold remediation, flood cleanup, and more.`}
  structuredData={structuredData}
>
  <!-- ═══ HERO ═══ -->
  <div class="relative isolate">
    <svg
      aria-hidden="true"
      class="absolute inset-x-0 top-0 -z-10 h-[64rem] w-full mask-[radial-gradient(32rem_32rem_at_center,white,transparent)] stroke-gray-200 dark:stroke-white/10"
    >
      <defs>
        <pattern x="50%" y="-1" id="services-hero-pattern" width="200" height="200" patternUnits="userSpaceOnUse">
          <path d="M.5 200V.5H200" fill="none" />
        </pattern>
      </defs>
      <rect fill="url(#services-hero-pattern)" width="100%" height="100%" stroke-width="0" />
    </svg>
    <div class="overflow-hidden">
      <div class="mx-auto max-w-7xl px-6 pt-36 pb-32 sm:pt-60 lg:px-8 lg:pt-32">
        <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">
          <h1 class="text-5xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-7xl">
            Restoration Services in {cityData.name}
          </h1>
          <p class="mt-8 text-lg font-medium text-pretty text-gray-600 dark:text-gray-400 sm:text-xl/8">
            From emergency water extraction to complete reconstruction, our IICRC-certified team handles every
            aspect of property restoration — residential and commercial. Available 24/7.
          </p>
          <div class="mt-10 flex items-center gap-x-6">
            <a
              href="/request"
              class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400"
            >
              Get a Free Estimate
            </a>
            <a href={cityPhoneHref} class="text-sm/6 font-semibold text-gray-900 dark:text-white">
              Call {cityData.phone} <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- LOGO CLOUD -->
  <LogoCloud cityName={cityData.name} />

  <!-- RESIDENTIAL -->
  <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">For Homeowners</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
          <a href="/services/residential" class="hover:text-indigo-600 dark:hover:text-indigo-400">Residential Services</a>
        </p>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
          Complete water damage restoration, cleanup, and specialty services for your home.
        </p>
      </div>
      <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 text-base/7 text-gray-600 dark:text-gray-400 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 lg:gap-x-16">
        {residentialCategories.map((category) => (
          <div class="relative pl-9">
            <dt class="inline font-semibold text-gray-900 dark:text-white">
              <Icon name={category.icon || 'check'} class="absolute top-1 left-1 size-5 text-indigo-600 dark:text-indigo-500" />
              <a href={category.path} class="hover:text-indigo-600 dark:hover:text-indigo-400">{category.name}</a>
            </dt>{' '}
            <dd class="inline">{category.description}</dd>
          </div>
        ))}
      </dl>
      <div class="mt-10">
        <a href="/services/residential" class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
          View all residential services <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>

  <!-- ═══ COMMERCIAL ═══ -->
  <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">For Businesses</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
          <a href="/services/commercial" class="hover:text-indigo-600 dark:hover:text-indigo-400">Commercial Services</a>
        </p>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
          Enterprise-grade restoration, cleanup, and technical services for businesses and commercial facilities.
        </p>
      </div>
      <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 text-base/7 text-gray-600 dark:text-gray-400 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-4 lg:gap-x-16">
        {commercialCategories.map((category) => (
          <div class="relative pl-9">
            <dt class="inline font-semibold text-gray-900 dark:text-white">
              <Icon name={category.icon || 'check'} class="absolute top-1 left-1 size-5 text-indigo-600 dark:text-indigo-500" />
              <a href={category.path} class="hover:text-indigo-600 dark:hover:text-indigo-400">{category.name}</a>
            </dt>{' '}
            <dd class="inline">{category.description}</dd>
          </div>
        ))}
      </dl>
      <div class="mt-10">
        <a href="/services/commercial" class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
          View all commercial services <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>

  <!-- ═══ STATS ═══ -->
  <div class="bg-gray-50 dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">
        <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Why Flood Doctor</p>
        <h2 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
          {cityData.name}'s Preferred Restoration Company
        </h2>
        <dl class="mt-16 grid grid-cols-1 gap-x-8 gap-y-12 sm:mt-20 sm:grid-cols-2 sm:gap-y-16 lg:mt-28 lg:grid-cols-4">
          {stats.map((stat) => (
            <div class="flex flex-col-reverse gap-y-3 border-l border-gray-300 dark:border-white/20 pl-6">
              <dt class="text-base/7 text-gray-600 dark:text-gray-300">{stat.label}</dt>
              <dd class="text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>

  <!-- TESTIMONIAL -->
  <TestimonialSection
    quote='"After a pipe burst in our ceiling, Flood Doctor had everything dried out and repaired within a week. Their team was professional, thorough, and made the insurance process painless."'
    authorName="James Rodriguez"
    authorRole="Homeowner"
    cityName={cityData.name}
    authorImage="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=1024&h=1024&q=80"
  />

  <!-- CTA BAND -->
  <CTABand
    heading="Water damage emergency?"
    description="Don't wait — every minute counts. Our certified team responds in under 60 minutes with industrial-grade equipment."
    primaryText="Request Free Estimate"
    primaryHref="/request"
    secondaryText={`Call ${cityData.phone}`}
    secondaryHref={cityPhoneHref}
  />

  <!-- FAQ -->
  <div class="bg-white dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8 lg:py-40">
      <div class="mx-auto max-w-4xl">
        <h2 class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Frequently asked questions</h2>
        <FAQAccordion client:visible faqs={faqs} />
      </div>
    </div>
  </div>
</BaseLayout>
