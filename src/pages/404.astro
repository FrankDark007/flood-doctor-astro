---
import BaseLayout from '../layouts/BaseLayout.astro'
import { cityData } from '../data/cities'
---

<BaseLayout title={`Page Not Found | Flood Doctor ${cityData.name}`} noIndex={true}>
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
      <p class="text-base/8 font-semibold text-indigo-400">404</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-tight text-balance text-white sm:text-7xl">
        Page not found
      </h1>
      <p class="mt-6 text-lg/8 text-pretty text-gray-400 sm:text-xl/8">
        Sorry, we couldn't find the page you're looking for.
      </p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a
          href="/"
          class="rounded-md bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400"
        >
          Go back home
        </a>
        <a href="/contact" class="text-sm font-semibold text-gray-300 hover:text-white">
          Contact us <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
