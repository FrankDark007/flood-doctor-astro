---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogBrowser from '../../components/islands/BlogBrowser.tsx'
import { blogPosts, blogCategories } from '../../data/blog'
import { cityData } from '../../data/cities'

const sanitizeCopy = (value: string) => value
  .replace(/within\s+60 minutes/gi, 'as quickly as possible')
  .replace(/60 minutes or less/gi, 'as quickly as possible')
  .replace(/60[\s-]minute/gi, 'prompt')
  .replace(/under\s+60 minutes/gi, 'as quickly as possible')
  .replace(/IICRC \(Institute of Inspection, Cleaning and Restoration Certification\)/g, 'industry guidance')
  .replace(/IICRC-certified/gi, 'trained')
  .replace(/IICRC/g, 'industry')
  .replace(/certified/gi, 'trained')
  .replace(/direct\s+billing/gi, 'claim documentation support')
  .replace(/all\s+major\s+carriers/gi, 'insurance adjusters')

const safeBlogPosts = blogPosts.map((post) => ({
  ...post,
  description: sanitizeCopy(post.description),
  imageUrl: '/graphics/water-emergency-pattern.svg',
  author: { ...post.author, name: 'Flood Doctor Team', imageUrl: '/graphics/flood-doctor-mark.svg' },
  content: post.content ? sanitizeCopy(post.content) : post.content,
}))
---

<BaseLayout
  title={`Blog | Flood Doctor ${cityData.name}`}
  description={`Expert advice on water damage restoration, mold remediation, insurance claims, and protecting your ${cityData.name} home. Tips from Flood Doctor's restoration team.`}
>
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-semibold tracking-tight text-balance text-gray-900 dark:text-white sm:text-5xl">Blog</h1>
        <p class="mt-2 text-lg/8 text-gray-600 dark:text-gray-300">
          Expert advice on water damage restoration, mold remediation, and protecting your home.
        </p>
      </div>
      <BlogBrowser client:load posts={safeBlogPosts} categories={blogCategories} />
    </div>
  </div>
</BaseLayout>
