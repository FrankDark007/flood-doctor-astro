---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { blogPosts } from '../../data/blog'
import { cityData } from '../../data/cities'
import { blogPostingSchema, breadcrumbSchema, cityBaseUrl } from '../../utils/schema'
import { toTelHref } from '../../utils/phone'
const cityPhoneHref = toTelHref(cityData.phone)

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props
const sanitizeCopy = (value: string) => value
  .replace(/within\s+60 minutes/gi, 'as quickly as possible')
  .replace(/60 minutes or less/gi, 'as quickly as possible')
  .replace(/60[\s-]minute/gi, 'prompt')
  .replace(/under\s+60 minutes/gi, 'as quickly as possible')
  .replace(/IICRC \(Institute of Inspection, Cleaning and Restoration Certification\)/g, 'industry guidance')
  .replace(/IICRC-certified/gi, 'trained')
  .replace(/IICRC/g, 'industry')
  .replace(/certified/gi, 'trained')
  .replace(/direct\s+billing/gi, 'claim documentation support')
  .replace(/all\s+major\s+carriers/gi, 'insurance adjusters')
  .replace(/Free[ \t]+Estimate/g, 'Request Service')

const safePost = {
  ...post,
  description: sanitizeCopy(post.description),
  imageUrl: '/graphics/water-emergency-pattern.svg',
  author: { ...post.author, name: 'Flood Doctor Team', imageUrl: '/graphics/flood-doctor-mark.svg' },
  content: post.content ? sanitizeCopy(post.content) : post.content,
}
const relatedPosts = blogPosts
  .filter((p) => p.slug !== post.slug)
  .slice(0, 3)
  .map((p) => ({
    ...p,
    description: sanitizeCopy(p.description),
    imageUrl: '/graphics/water-emergency-pattern.svg',
    author: { ...p.author, name: 'Flood Doctor Team', imageUrl: '/graphics/flood-doctor-mark.svg' },
  }))

const _base = cityBaseUrl()
const structuredData = [
  blogPostingSchema(safePost),
  breadcrumbSchema([
    { name: 'Home', url: `${_base}/` },
    { name: 'Blog', url: `${_base}/blog/` },
    { name: safePost.title, url: `${_base}/blog/${safePost.slug}/` },
  ]),
]
---

<BaseLayout
  title={`${safePost.title} | Flood Doctor ${cityData.name}`}
  description={safePost.description}
  structuredData={structuredData}
>
  <div class="content-page">
    <section class="hero article-hero" aria-labelledby="post-title">
      <div class="page-shell hero-grid">
        <div>
          <div class="meta-row">
            <time datetime={safePost.datetime}>{safePost.date}</time>
            <span class="meta-pill">{safePost.category.title}</span>
          </div>
          <h1 id="post-title">{safePost.title}</h1>
          <p class="hero-lede">{safePost.description}</p>
          <div class="button-row">
            <a class="button button-primary" href="/request">Request Service</a>
            <a class="button button-secondary" href={cityPhoneHref}>Call {cityData.phone}</a>
          </div>
        </div>
        <aside class="hero-card reading-card">
          <p class="eyebrow">Article Briefing</p>
          <h2>Read this as guidance, not a site-owned guarantee</h2>
          <ul class="brief-list">
            <li><strong>Category:</strong> {safePost.category.title}</li>
            <li><strong>Updated:</strong> <time datetime={safePost.datetime}>{safePost.date}</time></li>
            <li><strong>Source:</strong> Flood Doctor editorial review</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section soft">
      <div class="page-shell article-grid">
        <article>
          <p class="article-kicker">Field Guide</p>
          <div class="legal-copy prose-wrap" set:html={safePost.content} />
          <div class="article-note">
            <strong>Editorial note:</strong> This article is written to help with owner decisions. Active leaks, sewage, electrical concerns, or structural questions need live professional intake.
          </div>
        </article>
        <aside class="side-card">
          <p class="eyebrow dark">Need Emergency Help?</p>
          <h2>Move from reading to intake</h2>
          <p>If this article matches an active problem at your property, use the intake path so details can be reviewed in context.</p>
          <div class="button-row">
            <a class="button button-primary" href="/request">Request Service</a>
            <a class="button button-light" href={cityPhoneHref}>Call {cityData.phone}</a>
          </div>
          <h3>Related Articles</h3>
          <ul class="clean-list">
            {relatedPosts.map((related) => (
              <li><a class="text-link" href={related.href}>{related.title}</a></li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="section" aria-labelledby="more-blog-title">
      <div class="page-shell">
        <div class="section-heading">
          <p class="eyebrow dark">Related Reading</p>
          <h2 id="more-blog-title">Continue with adjacent decisions</h2>
        </div>
        <div class="card-grid">
          {relatedPosts.map((item) => (
            <article class="article-card">
              <h3><a class="card-link" href={item.href}>{item.title}</a></h3>
              <p>{item.description}</p>
              <p><a class="text-link" href={item.href}>Read article <span aria-hidden="true">&rarr;</span></a></p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>


<style>
  :global(html) {
    overflow-x: hidden;
  }

  .content-page {
    --fd-blue: #1a73e8;
    --fd-blue-dark: #0f4fb8;
    --fd-navy: #071a33;
    --fd-navy-2: #0b1f3a;
    --fd-ink: #102033;
    --fd-muted: #53647a;
    --fd-soft: #eef6ff;
    --fd-soft-2: #f7fbff;
    --fd-orange: #c2410c;
    --fd-orange-dark: #9a3412;
    --fd-line: #d9e6f5;
    --fd-white: #ffffff;
    width: 100%;
    overflow-x: clip;
    background: linear-gradient(180deg, #f7fbff 0%, #ffffff 34%, #eef6ff 100%);
    color: var(--fd-ink);
    font-family: 'Avenir Next', 'Trebuchet MS', Verdana, sans-serif;
  }

  .page-shell {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 18%, rgba(26, 115, 232, 0.38), transparent 34rem),
      radial-gradient(circle at 16% 100%, rgba(194, 65, 12, 0.22), transparent 30rem),
      linear-gradient(135deg, var(--fd-navy), var(--fd-navy-2));
    color: white;
    padding: clamp(4.5rem, 9vw, 7rem) 0;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.12;
    background-image: url('/graphics/water-emergency-pattern.svg');
    background-size: 420px 420px;
    mix-blend-mode: screen;
  }

  .hero-grid,
  .split-grid,
  .article-grid,
  .contact-grid,
  .request-grid,
  .legal-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 0.8fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .eyebrow {
    margin: 0 0 0.85rem;
    color: #fed7aa;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .eyebrow.dark {
    color: var(--fd-orange-dark);
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    color: white;
    font-size: clamp(2.65rem, 7vw, 5.4rem);
    font-weight: 900;
    letter-spacing: -0.07em;
    line-height: 0.95;
    text-wrap: balance;
  }

  h2 {
    margin: 0;
    color: var(--fd-navy);
    font-size: clamp(1.95rem, 4vw, 3.1rem);
    font-weight: 880;
    letter-spacing: -0.052em;
    line-height: 1;
  }

  h3 {
    margin: 0;
    color: var(--fd-navy);
    font-size: 1.08rem;
    font-weight: 830;
    letter-spacing: -0.025em;
    line-height: 1.25;
  }

  .hero-lede,
  .section-lede {
    margin: 1.25rem 0 0;
    max-width: 44rem;
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 560;
    line-height: 1.75;
  }

  .hero-lede {
    color: #d7e5f7;
  }

  .section-lede,
  .card p,
  .side-card p,
  .check-card li,
  .legal-copy p,
  .article-card p {
    color: var(--fd-muted);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    margin-top: 1.75rem;
  }

  .button {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.82rem 1.18rem;
    font-size: 0.94rem;
    font-weight: 850;
    line-height: 1.15;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button:focus-visible,
  .text-link:focus-visible,
  .card-link:focus-visible {
    outline: 3px solid rgba(26, 115, 232, 0.45);
    outline-offset: 3px;
  }

  .button-primary {
    background: var(--fd-orange);
    color: white;
    box-shadow: 0 16px 30px rgba(249, 115, 22, 0.24);
  }

  .button-primary:hover {
    background: var(--fd-orange-dark);
  }

  .button-secondary {
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.08);
    color: white;
  }

  .button-light {
    border: 1px solid rgba(11, 31, 58, 0.16);
    background: white;
    color: var(--fd-navy);
    box-shadow: 0 12px 28px rgba(15, 79, 184, 0.12);
  }

  .section {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
  }

  .section.soft {
    background: linear-gradient(180deg, var(--fd-soft-2), #ffffff);
  }

  .section.navy {
    background: var(--fd-navy);
    color: white;
  }

  .section.navy h2,
  .section.navy h3 {
    color: white;
  }

  .section.navy .section-lede,
  .section.navy p {
    color: #c9d7e8;
  }

  .section-heading {
    max-width: 48rem;
  }

  .section-heading.center {
    margin-inline: auto;
    text-align: center;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .card-grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card-grid.four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card,
  .side-card,
  .form-panel,
  .check-card,
  .article-card,
  .legal-copy,
  .review-placeholder {
    min-width: 0;
    border: 1px solid var(--fd-line);
    border-radius: 1.35rem;
    background: white;
    box-shadow: 0 12px 34px rgba(11, 31, 58, 0.07);
  }

  .card,
  .side-card,
  .check-card,
  .article-card,
  .legal-copy,
  .review-placeholder {
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .card p,
  .side-card p,
  .article-card p {
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.4rem;
  }

  .pill {
    border: 1px solid rgba(217, 230, 245, 0.82);
    border-radius: 999px;
    background: white;
    color: var(--fd-navy);
    padding: 0.52rem 0.75rem;
    font-size: 0.86rem;
    font-weight: 780;
  }

  .hero-card,
  .navy-card {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 1.5rem;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.055));
    padding: clamp(1.25rem, 4vw, 2rem);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  .hero-card h2,
  .hero-card h3,
  .navy-card h2,
  .navy-card h3 {
    color: white;
  }

  .hero-card p,
  .hero-card li,
  .navy-card p,
  .navy-card li {
    color: #d7e5f7;
  }

  .number-list,
  .clean-list,
  .columns-list {
    display: grid;
    gap: 0.85rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .columns-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .number-list li,
  .clean-list li,
  .columns-list li {
    position: relative;
    padding-left: 1.7rem;
    line-height: 1.55;
  }

  .number-list li::before,
  .clean-list li::before,
  .columns-list li::before {
    content: '';
    position: absolute;
    top: 0.58rem;
    left: 0;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--fd-orange);
  }

  .text-link,
  .card-link {
    color: var(--fd-blue-dark);
    font-weight: 850;
    text-decoration: none;
  }

  .prose-wrap :global(h2) {
    margin-top: 2.6rem;
    color: var(--fd-navy);
    font-size: clamp(1.65rem, 3vw, 2.2rem);
    letter-spacing: -0.04em;
  }

  .prose-wrap :global(h2:first-child) {
    margin-top: 0;
  }

  .prose-wrap :global(p),
  .prose-wrap :global(li) {
    color: var(--fd-muted);
    line-height: 1.78;
  }

  .prose-wrap :global(a) {
    color: var(--fd-blue-dark);
    font-weight: 800;
  }

  .prose-wrap :global(strong) {
    color: var(--fd-navy);
  }

  .prose-wrap :global(blockquote) {
    margin: 2rem 0;
    border-left: 4px solid var(--fd-orange);
    border-radius: 1rem;
    background: var(--fd-soft);
    padding: 1rem 1.25rem;
  }

  .visual-card {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 1.6rem;
    background: rgba(255, 255, 255, 0.08);
  }

  .visual-card img {
    display: block;
    width: 100%;
    height: auto;
  }

  .resource-browser,
  .dark-island {
    border-radius: 1.5rem;
    background: var(--fd-navy);
    padding: clamp(1rem, 3vw, 2rem);
    box-shadow: 0 24px 70px rgba(11, 31, 58, 0.16);
  }

  .form-panel {
    overflow: hidden;
    background: var(--fd-navy);
  }

  .form-panel :global(form) {
    padding: clamp(1.25rem, 4vw, 2rem) !important;
  }

  .form-panel :global(label),
  .form-panel :global(h3),
  .form-panel :global(button) {
    color: white;
  }

  .form-panel :global(button[type='submit']) {
    border-radius: 999px;
    background: var(--fd-orange);
  }

  .form-panel :global(button[type='submit']:hover) {
    background: var(--fd-orange-dark);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    margin-bottom: 1.25rem;
    color: #d7e5f7;
    font-size: 0.9rem;
  }

  .meta-pill {
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    padding: 0.4rem 0.7rem;
    color: white;
    font-weight: 780;
  }

  .article-image {
    overflow: hidden;
    margin-top: 2rem;
    border-radius: 1.35rem;
    background: var(--fd-soft);
  }

  .article-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 920px) {
    .hero-grid,
    .split-grid,
    .article-grid,
    .contact-grid,
    .request-grid,
    .legal-grid {
      grid-template-columns: 1fr;
    }

    .card-grid,
    .card-grid.four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .page-shell {
      width: min(100% - 1.25rem, 1120px);
    }

    .hero {
      padding: 4.5rem 0 4rem;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(2.2rem, 11vw, 3rem);
      letter-spacing: -0.052em;
      line-height: 0.99;
    }

    h2 {
      font-size: clamp(1.8rem, 9vw, 2.35rem);
    }

    .button-row {
      align-items: stretch;
      flex-direction: column;
    }

    .button {
      width: 100%;
      text-align: center;
    }

    .card-grid,
    .card-grid.two,
    .card-grid.four,
    .columns-list {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .button {
      transition: none;
    }

    .button:hover {
      transform: none;
    }
  }


  .hero-link {
    color: #fed7aa;
    font-weight: 850;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.22em;
  }

  .source-list,
  .brief-list,
  .resource-list,
  .proof-list {
    display: grid;
    gap: 0.85rem;
    margin: 1.2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .source-list li,
  .brief-list li,
  .resource-list li,
  .proof-list li {
    color: #d7e5f7;
    line-height: 1.55;
  }


  .rail-card strong,
  .jump-card strong,
  .source-proof-card strong {
    display: block;
    color: var(--fd-navy);
  }

  .rail-card span,
  .jump-card span,
  .source-proof-card span {
    display: block;
    margin-top: 0.35rem;
    color: var(--fd-muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }


  .article-hero {
    background:
      linear-gradient(135deg, rgba(7, 26, 51, 0.96), rgba(8, 47, 73, 0.98)),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px) 0 0 / 3.75rem 3.75rem;
  }

  .article-kicker,
  .article-note {
    width: fit-content;
  }

  .article-kicker {
    border: 1px solid rgba(194, 65, 12, 0.22);
    border-radius: 999px;
    margin: 0 0 1rem;
    padding: 0.32rem 0.72rem;
    background: #fff7ed;
    color: var(--fd-orange-dark);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-note {
    border-left: 4px solid var(--fd-orange);
    border-radius: 1rem;
    margin-top: 1.5rem;
    padding: 1rem 1.15rem;
    background: #fff7ed;
    color: var(--fd-muted);
    line-height: 1.65;
  }


  @media (max-width: 920px) {
    .editorial-rail,
    .faq-jump-strip,
    .checklist-index,
    .proof-strip {
      grid-template-columns: 1fr;
    }
  }

</style>
