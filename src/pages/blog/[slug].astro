---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { blogPosts } from '../../data/blog'
import { cityData } from '../../data/cities'

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props
const relatedPosts = blogPosts.filter((p) => p.slug !== post.slug).slice(0, 3)

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  image: post.imageUrl,
  datePublished: post.datetime,
  author: {
    '@type': 'Person',
    name: post.author.name,
    jobTitle: post.author.role,
  },
  publisher: {
    '@type': 'Organization',
    name: `Flood Doctor ${cityData.name}`,
  },
}
---

<BaseLayout
  title={`${post.title} | Flood Doctor ${cityData.name}`}
  description={post.description}
  structuredData={structuredData}
>
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-12 gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        <!-- Article content -->
        <div class="lg:col-span-2">
          <div class="flex items-center gap-x-4 text-xs">
            <time datetime={post.datetime} class="text-gray-400">{post.date}</time>
            <span class="rounded-full bg-gray-800/60 px-3 py-1.5 font-medium text-gray-300">
              {post.category.title}
            </span>
          </div>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">{post.title}</h1>
          <div class="mt-6 flex items-center gap-x-4">
            <img alt="" src={post.author.imageUrl} class="size-10 rounded-full bg-gray-800" />
            <div class="text-sm/6">
              <p class="font-semibold text-white">{post.author.name}</p>
              <p class="text-gray-400">{post.author.role}</p>
            </div>
          </div>

          <div class="relative mt-10">
            <img alt="" src={post.imageUrl} class="aspect-video w-full rounded-2xl bg-gray-800 object-cover" />
            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/10"></div>
          </div>

          {post.content && (
            <div
              class="prose prose-invert prose-lg mt-12 max-w-none prose-headings:text-white prose-p:text-gray-300 prose-a:text-indigo-400 prose-blockquote:border-indigo-500 prose-blockquote:text-gray-300 prose-strong:text-white prose-li:text-gray-300"
              set:html={post.content}
            />
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10">
            <h3 class="text-lg font-semibold text-white">Need Emergency Water Damage Help?</h3>
            <p class="mt-2 text-sm text-gray-400">
              Our team responds within 60 minutes, 24/7. Call now for immediate assistance.
            </p>
            <a
              href="/request"
              class="mt-6 block w-full rounded-md bg-indigo-500 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-indigo-400"
            >
              Get Free Estimate
            </a>
            <a
              href={`tel:${cityData.phone}`}
              class="mt-3 block w-full rounded-md bg-white/10 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-white/20"
            >
              Call {cityData.phone}
            </a>
          </div>

          <div class="mt-10">
            <h3 class="text-lg font-semibold text-white">Related Articles</h3>
            <div class="mt-6 space-y-6">
              {relatedPosts.map((related) => (
                <article class="relative flex gap-x-4">
                  <img alt="" src={related.imageUrl} class="size-16 shrink-0 rounded-lg bg-gray-800 object-cover" />
                  <div>
                    <h4 class="text-sm font-semibold text-white">
                      <a href={related.href}>
                        <span class="absolute inset-0"></span>
                        {related.title}
                      </a>
                    </h4>
                    <p class="mt-1 text-xs text-gray-400">{related.date}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- More articles -->
      <div class="mt-24 border-t border-white/10 pt-16">
        <h2 class="text-2xl font-semibold text-white">More from our blog</h2>
        <div class="mt-8 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-20 lg:max-w-none lg:grid-cols-3">
          {relatedPosts.map((post) => (
            <article class="flex flex-col items-start justify-between">
              <div class="relative w-full">
                <img alt="" src={post.imageUrl} class="aspect-video w-full rounded-2xl bg-gray-800 object-cover sm:aspect-[2/1] lg:aspect-[3/2]" />
                <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/10"></div>
              </div>
              <div class="flex max-w-xl grow flex-col justify-between">
                <div class="mt-8 flex items-center gap-x-4 text-xs">
                  <time datetime={post.datetime} class="text-gray-400">{post.date}</time>
                  <span class="rounded-full bg-gray-800/60 px-3 py-1.5 font-medium text-gray-300">{post.category.title}</span>
                </div>
                <div class="group relative grow">
                  <h3 class="mt-3 text-lg/6 font-semibold text-white group-hover:text-gray-300">
                    <a href={post.href}><span class="absolute inset-0"></span>{post.title}</a>
                  </h3>
                  <p class="mt-5 line-clamp-3 text-sm/6 text-gray-400">{post.description}</p>
                </div>
                <div class="relative mt-8 flex items-center gap-x-4 justify-self-end">
                  <img alt="" src={post.author.imageUrl} class="size-10 rounded-full bg-gray-800" />
                  <div class="text-sm/6">
                    <p class="font-semibold text-white">{post.author.name}</p>
                    <p class="text-gray-400">{post.author.role}</p>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
