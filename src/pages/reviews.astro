---
import BaseLayout from '../layouts/BaseLayout.astro'
import ReviewsList from '../components/islands/ReviewsList.tsx'
import { cityData } from '../data/cities'
import { reviewsSourceUrl } from '../data/reviews'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `Customer Reviews | Flood Doctor ${cityData.name}`,
  description: `Customer feedback and Google review links for Flood Doctor ${cityData.name}.`,
}
---

<BaseLayout
  title={`Customer Reviews | Flood Doctor ${cityData.name}`}
  description={`Read selected customer feedback for Flood Doctor ${cityData.name} and visit our Google profile for current customer feedback.`}
  structuredData={structuredData}
>
  <div class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl">
          Customer Reviews
        </h1>
        <p class="mt-2 text-lg/8 text-gray-300">
          Selected customer feedback for Flood Doctor {cityData.name} and Northern Virginia. For the latest public customer feedback, use our Google profile.
        </p>
      </div>
    </div>
  </div>

  <div class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-12 lg:gap-8">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-8 space-y-6">
            <div class="rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10">
              <h2 class="text-2xl font-semibold text-white">Google Reviews</h2>
              <p class="mt-4 text-sm/6 text-gray-400">
                We keep public feedback sourced to Google instead of publishing site-owned score summaries. Use the Google profile for current review details.
              </p>
              <a
                href={reviewsSourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex w-full justify-center rounded-md bg-indigo-500 px-6 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"
              >
                See Reviews on Google
              </a>
            </div>

            <div class="rounded-2xl bg-white/5 p-8 outline-1 -outline-offset-1 outline-white/10 text-center">
              <h3 class="text-lg font-semibold text-white">Have we worked together?</h3>
              <p class="mt-2 text-sm text-gray-400">
                Sharing your experience helps neighbors make a faster, more confident decision during water damage emergencies.
              </p>
              <a
                href={reviewsSourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-block rounded-md bg-white/10 px-6 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-white/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
              >
                Write a Review
              </a>
            </div>
          </div>
        </div>

        <div class="mt-10 lg:col-span-8 lg:mt-0">
          <ReviewsList client:load />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
