---
import BaseLayout from '../layouts/BaseLayout.astro'
import BrandLogo from '../components/BrandLogo.astro'
import RestorationBadge from '../components/RestorationBadge.astro'
import ContactForm from '../components/islands/ContactForm.tsx'
import { cityData } from '../data/cities'
import { localBusinessSchema, webSiteSchema } from '../utils/schema'
import { toTelHref } from '../utils/phone'

const cityPhoneHref = toTelHref(cityData.phone)
const structuredData = [localBusinessSchema(), webSiteSchema()]

const cityLabel = cityData.name
const serviceAreaLead = cityData.slug === 'main'
  ? 'Serving Northern Virginia and the DC Metro service area.'
  : `Serving ${cityData.name} as part of our Northern Virginia service area.`
const serviceAreaCities = cityData.serviceArea?.slice(0, 12) ?? []

const processSteps = [
  {
    step: '01',
    title: 'Call or request service',
    body: 'Share what happened, whether water is still entering, and the safest way to reach the property.',
  },
  {
    step: '02',
    title: 'Stabilize the source',
    body: 'The first priority is safety, source control, and separating urgent mitigation from repair decisions.',
  },
  {
    step: '03',
    title: 'Inspect and remove water',
    body: 'Affected rooms are checked for visible water, moisture concerns, contents exposure, and immediate cleanup needs.',
  },
  {
    step: '04',
    title: 'Dry, monitor, and document',
    body: 'Drying equipment may be placed and adjusted while notes, photos, and moisture readings support next steps.',
  },
]

const services = [
  {
    title: 'Emergency water extraction',
    body: 'Standing water removal for leaks, overflows, storm intrusion, and wet basements.',
    icon: 'M12 3.5C9.1 7.2 6.5 10.1 6.5 13.3a5.5 5.5 0 0 0 11 0C17.5 10.1 14.9 7.2 12 3.5Z',
  },
  {
    title: 'Structural drying support',
    body: 'Air movement and dehumidification planning for affected floors, walls, and cavities.',
    icon: 'M4 8h10a2 2 0 1 0-2-2M4 12h14a2 2 0 1 1-2 2M4 16h8',
  },
  {
    title: 'Moisture inspection',
    body: 'Moisture checks help identify affected areas before repairs or close-out decisions.',
    icon: 'M5 14a7 7 0 1 1 14 0v5H5v-5Zm4 1 3-5 3 5',
  },
  {
    title: 'Cleanup and removal',
    body: 'Practical cleanup for wet materials, debris, and contents that need to be separated or protected.',
    icon: 'M6 7h12M9 7V5h6v2m-8 3 1 10h8l1-10',
  },
  {
    title: 'Basement water damage',
    body: 'Help for finished and unfinished basements after seepage, appliance leaks, or plumbing failures.',
    icon: 'M4 12 12 5l8 7M6.5 10.5V20h11v-9.5M9 20v-5h6v5',
  },
  {
    title: 'Documentation for claims',
    body: 'Photos, scope notes, and moisture readings organized for your insurance conversation.',
    icon: 'M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm3 5h4M9 12h6M9 16h6',
  },
]

const faqs = [
  {
    question: 'What should I do first after a leak or flood?',
    answer: 'If it is safe, stop the water source and avoid rooms with electrical hazards or sagging materials. Then call so the situation can be triaged quickly.',
  },
  {
    question: 'Do you help with insurance paperwork?',
    answer: 'Flood Doctor can organize job documentation such as photos, notes, moisture readings, and scope details that may support your claim conversation.',
  },
  {
    question: 'Do I need service if the water looks gone?',
    answer: 'Maybe. Water can remain under flooring, behind trim, or inside wall assemblies. A moisture inspection helps determine what still needs drying or removal.',
  },
]
---

<BaseLayout structuredData={structuredData}>
  <main class="home-page">
    <section class="hero-section" aria-labelledby="home-hero-title">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="section-shell hero-grid">
        <div class="hero-copy">
          <BrandLogo cityName={cityLabel} showCity showTagline variant="full" size="lg" class="hero-logo" />
          <p class="eyebrow">Water damage response and drying support</p>
          <h1 id="home-hero-title">Water Damage Help for {cityLabel} Homes and Businesses</h1>
          <p class="hero-lede">
            Flood Doctor helps property owners move from a water emergency to a documented mitigation plan: intake,
            safety checks, water removal, drying support, and claim-ready notes.
          </p>
          <div class="hero-actions" aria-label="Emergency service actions">
            <a class="button button-primary" href="/request">Request Emergency Service</a>
            <a class="button button-secondary" href={cityPhoneHref}>Call Now {cityData.phone}</a>
          </div>
          <div class="badge-row" aria-label="Service highlights">
            <RestorationBadge kind="emergency" compact />
            <RestorationBadge kind="inspection" compact />
            <RestorationBadge kind="documentation" compact />
          </div>
        </div>

        <div class="hero-visual" aria-label="Flood Doctor restoration process illustration">
          <div class="visual-card visual-card-main">
            <img src="/graphics/restoration-process.svg" alt="Four step restoration process: call, extract, dry, document" width="960" height="720" />
          </div>
          <div class="status-card status-card-top">
            <span class="status-kicker">First priority</span>
            <strong>Stop active water when safe</strong>
            <span>Then inspect affected rooms and materials.</span>
          </div>
          <div class="status-card status-card-bottom">
            <span class="status-kicker">Documentation</span>
            <strong>Photos, notes, moisture readings</strong>
            <span>Organized for the owner and claim conversation.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="process-section" aria-labelledby="process-title">
      <div class="section-shell">
        <div class="section-heading compact-heading">
          <p class="eyebrow">Emergency Process</p>
          <h2 id="process-title">What happens after you contact Flood Doctor</h2>
          <p>
            The work starts with practical triage. No manufactured urgency, no unsupported arrival promises: just the steps
            that help limit damage and keep decisions organized.
          </p>
        </div>
        <ol class="process-grid" aria-label="Emergency water damage process">
          {processSteps.map((item) => (
            <li class="process-card">
              <span class="process-step">{item.step}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="services-section" aria-labelledby="services-title">
      <div class="section-shell">
        <div class="section-heading split-heading">
          <div>
            <p class="eyebrow">Services Overview</p>
            <h2 id="services-title">Water mitigation services without template promises</h2>
          </div>
          <p>
            Scope depends on water source, affected materials, access, and safety conditions. Flood Doctor focuses on
            clear next steps for properties in the {cityLabel} service area.
          </p>
        </div>
        <div class="service-grid">
          {services.map((service) => (
            <article class="service-card">
              <div class="service-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d={service.icon} />
                </svg>
              </div>
              <h3>{service.title}</h3>
              <p>{service.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="support-section" aria-labelledby="support-title">
      <div class="section-shell support-grid">
        <div class="support-panel">
          <p class="eyebrow">Insurance & Documentation Support</p>
          <h2 id="support-title">Clear records for a stressful claim conversation</h2>
          <p>
            Flood Doctor can help collect the job information owners commonly need after water damage: what was
            affected, what was removed, where moisture was found, and what drying steps were taken.
          </p>
          <div class="support-badges">
            <RestorationBadge kind="documentation" />
            <RestorationBadge kind="insurance-support" />
            <RestorationBadge kind="safety" />
          </div>
        </div>
        <div class="document-card" aria-label="Documentation checklist">
          <span class="document-label">Documentation may include</span>
          <ul>
            <li>Job photos and affected-area notes</li>
            <li>Moisture readings where accessible</li>
            <li>Initial scope and drying equipment notes</li>
            <li>Owner-facing summary for next steps</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="area-section" aria-labelledby="area-title">
      <div class="section-shell area-grid">
        <div>
          <p class="eyebrow">Service Area</p>
          <h2 id="area-title">Northern Virginia water damage support</h2>
          <p>
            {serviceAreaLead} Service availability is confirmed by phone so the right details are collected before a
            visit is scheduled.
          </p>
          <div class="area-actions">
            <a class="button button-primary" href="/request">Request Service</a>
            <a class="text-link" href={cityPhoneHref}>Call Now {cityData.phone}</a>
          </div>
        </div>
        <div class="area-list" aria-label="Representative service area communities">
          {serviceAreaCities.map((city) => <span>{city}</span>)}
        </div>
      </div>
    </section>

    <section class="faq-section" aria-labelledby="faq-title">
      <div class="section-shell faq-grid">
        <div class="section-heading faq-heading">
          <p class="eyebrow">FAQ / What To Expect</p>
          <h2 id="faq-title">Straight answers before the visit</h2>
          <p>
            Water damage decisions are easier when the first steps are clear. These answers avoid guarantees and focus
            on safe expectations.
          </p>
        </div>
        <div class="faq-list">
          {faqs.map((item) => (
            <article class="faq-card">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="final-section" aria-labelledby="final-title">
      <div class="section-shell final-grid">
        <div class="final-copy">
          <p class="eyebrow">Ready When You Need Direction</p>
          <h2 id="final-title">Tell us what happened and where the water went</h2>
          <p>
            Use the form for service requests and non-immediate details. If water is actively entering, electrical
            hazards are possible, or you need urgent guidance, call instead.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/request">Request Emergency Service</a>
            <a class="button button-secondary dark-button" href={cityPhoneHref}>Call Now {cityData.phone}</a>
          </div>
          <address>
            Flood Doctor<br />
            Service area: {cityLabel}, {cityData.state}
          </address>
        </div>
        <div class="form-wrap" aria-label="Contact form">
          <ContactForm city={cityData.slug} client:load />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(html) {
    overflow-x: hidden;
  }

  .home-page {
    --fd-blue: #1a73e8;
    --fd-blue-dark: #0f4fb8;
    --fd-navy: #0b1f3a;
    --fd-ink: #102033;
    --fd-muted: #53647a;
    --fd-soft: #eef6ff;
    --fd-soft-2: #f7fbff;
    --fd-orange: #c2410c;
    --fd-orange-dark: #9a3412;
    --fd-line: #d9e6f5;
    --fd-white: #ffffff;
    width: 100%;
    max-width: 100%;
    overflow-x: clip;
    background: var(--fd-white);
    color: var(--fd-ink);
    font-family: 'Avenir Next', 'Trebuchet MS', Verdana, sans-serif;
  }

  .section-shell {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .hero-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(238, 246, 255, 0.96), rgba(255, 255, 255, 0.92) 42%, rgba(255, 247, 237, 0.9)),
      url('/graphics/water-emergency-pattern.svg');
    background-size: auto, 440px 440px;
    padding: clamp(5.5rem, 9vw, 8rem) 0 clamp(4rem, 7vw, 6rem);
  }

  .hero-bg {
    position: absolute;
    inset: auto -12rem -20rem auto;
    width: min(48rem, 90vw);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(26, 115, 232, 0.18), rgba(249, 115, 22, 0.1) 44%, transparent 68%);
    z-index: -1;
  }

  .hero-grid,
  .support-grid,
  .area-grid,
  .faq-grid,
  .final-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.82fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .hero-copy,
  .section-heading,
  .support-panel,
  .final-copy {
    min-width: 0;
  }

  .hero-logo {
    margin-bottom: 1.5rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--fd-orange-dark);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 11ch;
    margin: 0;
    color: var(--fd-navy);
    font-size: clamp(2.7rem, 8.2vw, 5.8rem);
    font-weight: 900;
    letter-spacing: -0.075em;
    line-height: 0.93;
  }

  h2 {
    margin: 0;
    color: var(--fd-navy);
    font-size: clamp(2rem, 4.4vw, 3.45rem);
    font-weight: 880;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  h3 {
    margin: 0;
    color: var(--fd-navy);
    font-size: 1.08rem;
    font-weight: 830;
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .hero-lede,
  .section-heading p,
  .support-panel p,
  .area-grid p,
  .final-copy p {
    margin: 1.25rem 0 0;
    max-width: 42rem;
    color: var(--fd-muted);
    font-size: clamp(1rem, 2vw, 1.18rem);
    font-weight: 560;
    line-height: 1.75;
  }

  .hero-actions,
  .area-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    margin-top: 1.75rem;
    max-width: 100%;
    min-width: 0;
  }

  .button {
    display: inline-flex;
    max-width: 100%;
    min-width: 0;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.8rem 1.15rem;
    font-size: 0.94rem;
    font-weight: 850;
    line-height: 1.15;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    white-space: normal;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button:focus-visible,
  .text-link:focus-visible {
    outline: 3px solid rgba(26, 115, 232, 0.45);
    outline-offset: 3px;
  }

  .button-primary {
    background: var(--fd-orange);
    color: white;
    box-shadow: 0 16px 30px rgba(249, 115, 22, 0.24);
  }

  .button-primary:hover {
    background: var(--fd-orange-dark);
  }

  .button-secondary {
    border: 1px solid rgba(11, 31, 58, 0.16);
    background: white;
    color: var(--fd-navy);
    box-shadow: 0 12px 28px rgba(15, 79, 184, 0.12);
  }

  .dark-button {
    border-color: rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.08);
    color: white;
  }

  .badge-row,
  .support-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.4rem;
    max-width: 100%;
  }

  .hero-visual {
    position: relative;
    min-width: 0;
  }

  .visual-card {
    overflow: hidden;
    border: 1px solid rgba(26, 115, 232, 0.16);
    border-radius: 2rem;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 30px 80px rgba(11, 31, 58, 0.16);
  }

  .visual-card img {
    display: block;
    width: 100%;
    height: auto;
  }

  .status-card {
    position: absolute;
    max-width: 16rem;
    border: 1px solid rgba(217, 230, 245, 0.92);
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 18px 50px rgba(11, 31, 58, 0.14);
    padding: 1rem;
  }

  .status-card strong,
  .status-card span {
    display: block;
  }

  .status-card strong {
    color: var(--fd-navy);
    font-size: 0.95rem;
    line-height: 1.2;
  }

  .status-card span:last-child {
    margin-top: 0.35rem;
    color: var(--fd-muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .status-kicker {
    margin-bottom: 0.35rem;
    color: var(--fd-blue-dark);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .status-card-top {
    top: 1.25rem;
    right: -1rem;
  }

  .status-card-bottom {
    bottom: 1.25rem;
    left: -1rem;
  }

  .process-section,
  .faq-section {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
    background: var(--fd-white);
  }

  .compact-heading {
    max-width: 48rem;
  }

  .process-grid,
  .service-grid,
  .faq-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .process-card,
  .service-card,
  .faq-card,
  .document-card {
    min-width: 0;
    border: 1px solid var(--fd-line);
    border-radius: 1.35rem;
    background: white;
    box-shadow: 0 12px 34px rgba(11, 31, 58, 0.07);
  }

  .process-card {
    padding: 1.25rem;
  }

  .process-card p,
  .service-card p,
  .faq-card p {
    margin: 0.75rem 0 0;
    color: var(--fd-muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .process-step {
    display: inline-flex;
    margin-bottom: 1rem;
    border-radius: 999px;
    background: var(--fd-soft);
    color: var(--fd-blue-dark);
    padding: 0.4rem 0.65rem;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .services-section,
  .area-section {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
    background: linear-gradient(180deg, var(--fd-soft-2), #ffffff);
  }

  .split-heading {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.8fr);
    gap: 2rem;
    align-items: end;
  }

  .split-heading p:last-child {
    margin: 0;
  }

  .service-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .service-card {
    padding: 1.35rem;
  }

  .service-icon {
    display: inline-flex;
    width: 2.8rem;
    height: 2.8rem;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, #eaf3ff, #fff7ed);
    color: var(--fd-blue-dark);
  }

  .service-icon svg {
    width: 1.45rem;
    height: 1.45rem;
  }

  .service-icon path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .support-section,
  .final-section {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
    background: var(--fd-navy);
    color: white;
  }

  .support-section h2,
  .support-section h3,
  .final-section h2,
  .final-section h3 {
    color: white;
  }

  .support-section .eyebrow,
  .final-section .eyebrow {
    color: #fed7aa;
  }

  .support-panel p,
  .final-copy p,
  .final-copy address {
    color: #c9d7e8;
  }

  .document-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.06));
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow: none;
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .document-label {
    display: block;
    margin-bottom: 1rem;
    color: #fed7aa;
    font-size: 0.82rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .document-card ul {
    display: grid;
    gap: 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .document-card li {
    position: relative;
    padding-left: 1.5rem;
    color: white;
    font-weight: 650;
    line-height: 1.45;
  }

  .document-card li::before {
    content: '';
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--fd-orange);
  }

  .area-grid {
    grid-template-columns: minmax(0, 0.8fr) minmax(280px, 1fr);
  }

  .area-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    min-width: 0;
  }

  .area-list span {
    min-width: 0;
    border: 1px solid #cfe0f4;
    border-radius: 999px;
    background: white;
    color: var(--fd-navy);
    padding: 0.55rem 0.78rem;
    font-size: 0.9rem;
    font-weight: 780;
    overflow-wrap: anywhere;
  }

  .text-link {
    color: var(--fd-blue-dark);
    font-weight: 850;
    text-decoration: none;
  }

  .faq-grid {
    grid-template-columns: minmax(0, 0.72fr) minmax(280px, 1fr);
    align-items: start;
  }

  .faq-list {
    grid-template-columns: 1fr;
    margin: 0;
  }

  .faq-card {
    padding: 1.25rem;
  }

  .final-grid {
    grid-template-columns: minmax(0, 0.72fr) minmax(300px, 1fr);
    align-items: start;
  }

  .final-copy address {
    margin-top: 2rem;
    font-style: normal;
    line-height: 1.7;
  }

  .form-wrap {
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.04);
  }

  .form-wrap :global(form) {
    padding: clamp(1.25rem, 4vw, 2rem) !important;
  }

  @media (max-width: 920px) {
    .hero-grid,
    .support-grid,
    .area-grid,
    .faq-grid,
    .final-grid,
    .split-heading {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      max-width: 38rem;
      margin-inline: auto;
    }

    .process-grid,
    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    h1 {
      max-width: 12ch;
    }
  }

  @media (max-width: 560px) {
