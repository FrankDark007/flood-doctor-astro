---
import BaseLayout from '../layouts/BaseLayout.astro'
import { cityData } from '../data/cities'
---
<BaseLayout>
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h1 class="text-4xl font-bold">Flood Doctor {cityData.name}</h1>
      <p class="mt-4 text-gray-500 dark:text-gray-400">Layout scaffold working. Pages coming in Phase 5.</p>
    </div>
  </div>
</BaseLayout>
