---
import BaseLayout from '../layouts/BaseLayout.astro'
import BrandLogo from '../components/BrandLogo.astro'
import RestorationBadge from '../components/RestorationBadge.astro'
import ContactForm from '../components/islands/ContactForm.tsx'
import { cityData } from '../data/cities'
import { localBusinessSchema, webSiteSchema } from '../utils/schema'
import { toTelHref } from '../utils/phone'

const cityPhoneHref = toTelHref(cityData.phone)
const structuredData = [localBusinessSchema(), webSiteSchema()]

const cityLabel = cityData.name
const serviceAreaLead = cityData.slug === 'main'
  ? 'Serving Northern Virginia, Washington DC, and nearby Maryland communities by availability.'
  : `Serving ${cityData.name} as part of the Northern Virginia and DC Metro response area.`
const serviceAreaCities = cityData.serviceArea?.slice(0, 12) ?? []

const proofItems = [
  {
    value: '24/7',
    label: 'Emergency intake',
    body: 'A call or request starts with the address, active water source, affected rooms, and safety concerns.',
  },
  {
    value: 'Local',
    label: 'Service-area confirmation',
    body: 'Northern Virginia and DC Metro availability is confirmed before dispatch expectations are set.',
  },
  {
    value: 'Field records',
    label: 'Documentation-minded work',
    body: 'Photos, notes, affected-area details, and moisture readings are collected when applicable.',
  },
]

const intakeChecks = [
  'Where the water started and whether it is still active',
  'Rooms, flooring, trim, walls, ceilings, and contents affected',
  'Safety concerns: electrical exposure, sagging materials, or questionable water',
  'Access details for technician dispatch and equipment staging',
]

const services = [
  {
    title: 'Water extraction and pump-out',
    body: 'Remove accessible standing water from floors, basements, and affected rooms before damage spreads further.',
    detail: 'Standing water first',
    icon: 'M12 3.5C9.1 7.2 6.5 10.1 6.5 13.3a5.5 5.5 0 0 0 11 0C17.5 10.1 14.9 7.2 12 3.5Z',
  },
  {
    title: 'Moisture mapping',
    body: 'Check flooring, baseboards, drywall, cavities, and nearby rooms so the scope is based on conditions, not guesswork.',
    detail: 'Find hidden wet areas',
    icon: 'M5 14a7 7 0 1 1 14 0v5H5v-5Zm4 1 3-5 3 5M8 19h8',
  },
  {
    title: 'Drying equipment setup',
    body: 'Place air movement and dehumidification where assemblies can be dried in place and monitored safely.',
    detail: 'Dry with control',
    icon: 'M4 8h10a2 2 0 1 0-2-2M4 12h14a2 2 0 1 1-2 2M4 16h8',
  },
  {
    title: 'Selective material removal',
    body: 'Remove saturated porous materials, damaged trim, and debris when they cannot reasonably remain or dry in place.',
    detail: 'Remove what cannot stay',
    icon: 'M6 7h12M9 7V5h6v2m-8 3 1 10h8l1-10',
  },
  {
    title: 'Basement and lower-level losses',
    body: 'Triage seepage, appliance leaks, sump issues, and finished-basement water with source-aware mitigation steps.',
    detail: 'Basements need triage',
    icon: 'M4 12 12 5l8 7M6.5 10.5V20h11v-9.5M9 20v-5h6v5',
  },
  {
    title: 'Claim documentation support',
    body: 'Organize job photos, scope notes, affected-area details, and moisture readings for owner and claim conversations.',
    detail: 'Records reduce confusion',
    icon: 'M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm3 5h4M9 12h6M9 16h6',
  },
]

const processSteps = [
  {
    step: '01',
    title: 'Emergency intake',
    body: 'Call with the address, water source, affected rooms, and any hazards. If the situation is active or unsafe, phone is the priority.',
  },
  {
    step: '02',
    title: 'Dispatch and source awareness',
    body: 'Availability, access, and likely equipment needs are confirmed. Active water and safety concerns are handled before cleanup decisions.',
  },
  {
    step: '03',
    title: 'Extract and inspect',
    body: 'Accessible water is removed, affected assemblies are checked, and the technician maps what needs drying, removal, or follow-up.',
  },
  {
    step: '04',
    title: 'Drying, monitoring, and records',
    body: 'Drying equipment, moisture readings, photos, and job notes help owners understand the recovery path and next decisions.',
  },
]

const reviewChecks = [
  'What caused the water and whether it is still active',
  'Which rooms, floors, walls, trim, and contents were affected',
  'What was extracted, removed, dried, or recommended next',
  'What documentation may help the owner and insurance conversation',
]

const faqs = [
  {
    question: 'What should I do first after a leak or flood?',
    answer: 'If it is safe, stop the water source and stay out of areas with electrical hazards, sagging materials, or contaminated water. Then call so the emergency can be triaged.',
  },
  {
    question: 'Do you serve DC or Maryland?',
    answer: 'Flood Doctor is focused on Northern Virginia and the DC Metro. Availability outside the core area is confirmed by phone before scheduling.',
  },
  {
    question: 'Do you help with insurance documentation?',
    answer: 'Flood Doctor can organize job photos, notes, scope details, and moisture readings that may support your claim conversation.',
  },
]
---

<BaseLayout structuredData={structuredData}>
  <main class="home-page" id="main-content">
    <section class="hero-section" aria-labelledby="home-hero-title">
      <div class="hero-mesh" aria-hidden="true"></div>
      <div class="section-shell hero-grid">
        <div class="hero-copy">
          <BrandLogo cityName={cityLabel} showCity showTagline variant="full" size="lg" tone="dark" class="hero-logo" />
          <div class="alert-pill" aria-label="Emergency water damage service">
            <span class="alert-dot"></span>
            Emergency water damage response
          </div>
          <h1 id="home-hero-title">Water damage emergency? Call Flood Doctor first.</h1>
          <p class="hero-lede">
            Phone triage, technician dispatch, water extraction, drying support, and documentation for homes and properties
            in the Northern Virginia and DC Metro service area.
          </p>
          <div class="hero-actions" aria-label="Emergency service actions">
            <a class="button button-call" href={cityPhoneHref}>Call {cityData.phone}</a>
            <a class="button button-request" href="/request">Request Service</a>
          </div>
          <p class="service-area-line">{serviceAreaLead}</p>
        </div>

        <aside class="hero-visual" aria-label="What happens when you contact Flood Doctor">
          <div class="response-panel">
            <div class="response-panel-header">
              <span class="panel-kicker">What happens next</span>
              <strong>Intake -> dispatch -> extraction -> drying records</strong>
            </div>
            <ul class="intake-list">
              {intakeChecks.map((item) => <li>{item}</li>)}
            </ul>
            <div class="field-card">
              <span>Field focus</span>
              <strong>Stabilize the loss before repair decisions.</strong>
              <p>Remove accessible water, check materials, set drying priorities, and keep the owner-facing record clear.</p>
            </div>
            <div class="mini-process" aria-hidden="true">
              <span>Call</span>
              <span>Dispatch</span>
              <span>Extract</span>
              <span>Dry</span>
              <span>Document</span>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="proof-section" aria-labelledby="proof-title">
      <div class="section-shell proof-wrap">
        <div class="proof-intro">
          <p class="eyebrow">Verified-neutral proof</p>
          <h2 id="proof-title">Real mitigation steps, no unsupported promises.</h2>
          <p>No fake reviews, no invented arrival times, no coverage guarantees. Just the practical information a property owner needs in the first call.</p>
        </div>
        <dl class="proof-grid">
          {proofItems.map((item) => (
            <div class="proof-item">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
              <p>{item.body}</p>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <section class="services-section" aria-labelledby="services-title">
      <div class="section-shell">
        <div class="section-heading split-heading">
          <div>
            <p class="eyebrow">Mitigation Services</p>
            <h2 id="services-title">Built around the field work after water gets inside.</h2>
          </div>
          <p>
            Flood Doctor keeps the homepage focused on restoration actions: extract the water, identify affected materials,
            dry what can be saved, remove what cannot, and document the work clearly.
          </p>
        </div>
        <div class="bento-grid">
          {services.map((service, index) => (
            <article class:list={['service-card', index === 0 && 'service-card-large']}>
              <div class="service-card-shine" aria-hidden="true"></div>
              <div class="service-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d={service.icon} /></svg>
              </div>
              <p class="service-detail">{service.detail}</p>
              <h3>{service.title}</h3>
              <p>{service.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="process-section" aria-labelledby="process-title">
      <div class="section-shell process-layout">
        <div class="section-heading sticky-heading">
          <p class="eyebrow">Emergency Process</p>
          <h2 id="process-title">A restoration sequence a stressed owner can understand.</h2>
          <p>
            The first priority is not a glossy dashboard. It is a clear phone path, safe source control, water removal,
            drying decisions, and useful documentation.
          </p>
          <div class="process-actions">
            <a class="text-link" href={cityPhoneHref}>Call {cityData.phone}</a>
            <a class="text-link" href="/request">Request service</a>
          </div>
        </div>
        <ol class="process-list" aria-label="Emergency water damage process">
          {processSteps.map((item) => (
            <li class="process-card">
              <span class="process-step">{item.step}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="review-section" aria-labelledby="review-title">
      <div class="section-shell review-grid">
        <div class="review-panel">
          <p class="eyebrow">Review-Ready Records</p>
          <h2 id="review-title">Documentation that makes the recovery easier to review.</h2>
          <p>
            Water losses can become confusing quickly. Flood Doctor can organize the field notes an owner commonly needs
            after mitigation, without inventing claim outcomes or coverage promises.
          </p>
          <div class="support-badges">
            <RestorationBadge kind="documentation" />
            <RestorationBadge kind="insurance-support" />
            <RestorationBadge kind="safety" />
          </div>
        </div>
        <div class="checklist-card" aria-label="Documentation checklist">
          <span class="document-label">Field notes may cover</span>
          <ul>
            {reviewChecks.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="area-section" aria-labelledby="area-title">
      <div class="section-shell area-grid">
        <div>
          <p class="eyebrow">Service Area</p>
          <h2 id="area-title">Northern Virginia, DC Metro, and nearby Maryland by availability.</h2>
          <p>
            {serviceAreaLead} The fastest way to confirm service is to call with the property address, water source,
            and current conditions.
          </p>
          <div class="area-actions">
            <a class="button button-request" href="/request">Request Service</a>
            <a class="button button-outline" href={cityPhoneHref}>Call {cityData.phone}</a>
          </div>
        </div>
        <div class="area-list" aria-label="Representative service area communities">
          {serviceAreaCities.map((city) => <span>{city}</span>)}
        </div>
      </div>
    </section>

    <section class="faq-section" aria-labelledby="faq-title">
      <div class="section-shell faq-grid">
        <div class="section-heading faq-heading">
          <p class="eyebrow">FAQ / What To Expect</p>
          <h2 id="faq-title">Straight answers before the visit.</h2>
        </div>
        <div class="faq-list">
          {faqs.map((item) => (
            <article class="faq-card">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="final-section" aria-labelledby="final-title">
      <div class="section-shell final-grid">
        <div class="final-copy">
          <p class="eyebrow">Request Service</p>
          <h2 id="final-title">Send the details or call if water is active now.</h2>
          <p>
            Use the form for service requests and non-immediate details. If water is actively entering, electrical
            hazards are possible, or you need urgent guidance, call instead.
          </p>
          <div class="hero-actions">
            <a class="button button-call" href={cityPhoneHref}>Call {cityData.phone}</a>
            <a class="button button-outline-light" href="/request">Open request page</a>
          </div>
          <address>
            Flood Doctor<br />
            Service area: {cityLabel}, {cityData.state}
          </address>
        </div>
        <div class="form-wrap" aria-label="Contact form">
          <ContactForm city={cityData.slug} client:load />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(html) {
    overflow-x: hidden;
  }

  .home-page {
    --fd-navy: #07172d;
    --fd-navy-2: #0b1f3a;
    --fd-blue: #1a73e8;
    --fd-blue-2: #5aa7ff;
    --fd-orange: #ea580c;
    --fd-orange-2: #fb923c;
    --fd-ink: #102033;
    --fd-muted: #53647a;
    --fd-slate: #e7edf5;
    --fd-soft: #f4f8fc;
    --fd-line: #d9e6f5;
    --fd-white: #ffffff;
    width: 100%;
    max-width: 100%;
    overflow-x: clip;
    background: var(--fd-white);
    color: var(--fd-ink);
    font-family: 'Avenir Next', 'Trebuchet MS', Verdana, sans-serif;
  }

  .section-shell {
    width: min(1180px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .hero-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(7, 23, 45, 0.96), rgba(7, 23, 45, 0.82)),
      radial-gradient(circle at 78% 22%, rgba(26, 115, 232, 0.32), transparent 27rem),
      radial-gradient(circle at 18% 80%, rgba(234, 88, 12, 0.22), transparent 23rem),
      linear-gradient(135deg, #061225 0%, #07172d 46%, #102b4f 100%);
    color: white;
    padding: clamp(5.2rem, 8vw, 7rem) 0 clamp(4.25rem, 7vw, 6.25rem);
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      url('/graphics/water-emergency-pattern.svg');
    background-size: 92px 92px, 92px 92px, 520px 520px;
    background-blend-mode: screen, screen, soft-light;
    opacity: 0.16;
  }

  .hero-mesh {
    position: absolute;
    inset: auto -22rem -24rem 48%;
    z-index: -1;
    width: min(56rem, 95vw);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(90, 167, 255, 0.36), rgba(234, 88, 12, 0.12) 44%, transparent 69%);
    filter: blur(5px);
  }

  .hero-grid,
  .review-grid,
  .area-grid,
  .faq-grid,
  .final-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.82fr);
    gap: clamp(2rem, 5vw, 4.75rem);
    align-items: center;
  }

  .hero-copy,
  .section-heading,
  .review-panel,
  .final-copy {
    min-width: 0;
  }

  :global(.brand-logo.hero-logo) {
    margin-bottom: clamp(1.25rem, 3vw, 2.1rem);
  }

  .alert-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(251, 146, 60, 0.42);
    border-radius: 999px;
    background: rgba(234, 88, 12, 0.13);
    color: #fed7aa;
    padding: 0.45rem 0.7rem;
    font-size: 0.75rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .alert-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--fd-orange-2);
    box-shadow: 0 0 0 6px rgba(251, 146, 60, 0.15);
  }

  .eyebrow,
  .panel-kicker,
  .document-label {
    margin: 0 0 0.75rem;
    color: var(--fd-orange);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 13ch;
    margin: 1.2rem 0 0;
    color: white;
    font-size: clamp(2.65rem, 5.6vw, 4.9rem);
    font-family: 'Helvetica Neue', 'Avenir Next', Verdana, sans-serif;
    font-weight: 720;
    letter-spacing: -0.04em;
    line-height: 1.02;
    text-wrap: balance;
  }

  h2 {
    margin: 0;
    color: var(--fd-navy);
    font-size: clamp(2.05rem, 4.7vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.062em;
    line-height: 0.98;
    text-wrap: balance;
  }

  h3 {
    margin: 0;
    color: var(--fd-navy);
    font-size: 1.08rem;
    font-weight: 850;
    letter-spacing: -0.025em;
    line-height: 1.18;
  }

  .hero-lede,
  .section-heading p,
  .review-panel p,
  .area-grid p,
  .final-copy p {
    margin: 1.25rem 0 0;
    max-width: 45rem;
    color: var(--fd-muted);
    font-size: clamp(1rem, 2vw, 1.14rem);
    font-weight: 560;
    line-height: 1.72;
  }

  .hero-lede {
    color: #d9e6f5;
    max-width: 42rem;
  }

  .service-area-line {
    margin: 1rem 0 0;
    max-width: 40rem;
    color: #a9bdd6;
    font-size: 0.95rem;
    font-weight: 650;
    line-height: 1.55;
  }

  .hero-actions,
  .area-actions,
  .process-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    margin-top: 1.75rem;
    max-width: 100%;
    min-width: 0;
  }

  .button {
    display: inline-flex;
    max-width: 100%;
    min-width: 0;
    min-height: 3.25rem;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.9rem 1.22rem;
    font-size: 0.94rem;
    font-weight: 900;
    line-height: 1.15;
    text-decoration: none;
    transition: transform 170ms ease, box-shadow 170ms ease, background 170ms ease, border-color 170ms ease;
    white-space: normal;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button:focus-visible,
  .text-link:focus-visible {
    outline: 3px solid rgba(90, 167, 255, 0.55);
    outline-offset: 3px;
  }

  .button-call {
    background: var(--fd-orange);
    color: white;
    box-shadow: 0 20px 42px rgba(234, 88, 12, 0.34);
  }

  .button-call:hover {
    background: #c2410c;
  }

  .button-request {
    background: var(--fd-blue);
    color: white;
    box-shadow: 0 18px 38px rgba(26, 115, 232, 0.24);
  }

  .button-request:hover {
    background: #155fc0;
  }

  .button-outline,
  .button-outline-light {
    background: white;
    border-color: rgba(11, 31, 58, 0.14);
    color: var(--fd-navy);
    box-shadow: 0 12px 28px rgba(11, 31, 58, 0.08);
  }

  .button-outline-light {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.24);
    color: white;
    box-shadow: none;
  }

  .support-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.35rem;
    max-width: 100%;
  }

  .hero-visual {
    position: relative;
    min-width: 0;
  }

  .response-panel {
    position: relative;
    display: grid;
    gap: 1rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 1.7rem;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.055));
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.3);
    padding: clamp(1rem, 3vw, 1.35rem);
    backdrop-filter: blur(18px);
  }

  .response-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.14), transparent 34%), url('/graphics/restoration-process.svg') center bottom / 110% auto no-repeat;
    opacity: 0.16;
    pointer-events: none;
  }

  .response-panel > * {
    position: relative;
    z-index: 1;
  }

  .response-panel-header {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 1.25rem;
    background: rgba(7, 23, 45, 0.72);
    padding: clamp(1rem, 3vw, 1.35rem);
  }

  .panel-kicker {
    display: block;
    color: #fed7aa;
  }

  .response-panel-header strong,
  .field-card strong {
    display: block;
    color: white;
    font-size: clamp(1.18rem, 2.8vw, 1.55rem);
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 1.12;
  }

  .intake-list {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .intake-list li {
    position: relative;
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1rem;
    background: rgba(7, 23, 45, 0.66);
    color: #d9e6f5;
    font-size: 0.92rem;
    font-weight: 680;
    line-height: 1.42;
    padding: 0.82rem 0.9rem 0.82rem 2.25rem;
  }

  .intake-list li::before {
    content: '';
    position: absolute;
    top: 1.02rem;
    left: 0.95rem;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--fd-orange-2);
    box-shadow: 0 0 0 5px rgba(251, 146, 60, 0.12);
  }

  .field-card {
    border: 1px solid rgba(251, 146, 60, 0.24);
    border-radius: 1.2rem;
    background: rgba(7, 23, 45, 0.78);
    padding: 1.05rem;
  }

  .field-card span {
    display: block;
    margin-bottom: 0.55rem;
    color: #fed7aa;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .field-card p {
    margin: 0.6rem 0 0;
    color: #bcd0e8;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .mini-process {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.1);
  }

  .mini-process span {
    display: grid;
    min-height: 3.2rem;
    place-items: center;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(7, 23, 45, 0.76);
