---
import BaseLayout from '../layouts/BaseLayout.astro'
import LogoCloud from '../components/sections/LogoCloud.astro'
import TestimonialSection from '../components/sections/TestimonialSection.astro'
import BlogPreview from '../components/sections/BlogPreview.astro'
import FAQAccordion from '../components/islands/FAQAccordion.tsx'
import { cityData } from '../data/cities'
import { allServices } from '../data/services'
import { localBusinessSchema, webSiteSchema } from '../utils/schema'

const structuredData = [localBusinessSchema(), webSiteSchema()]

const features = [
  { name: 'Emergency Water Extraction', description: 'Industrial-grade pumps remove standing water within hours of our arrival, preventing further damage to your property and belongings.', icon: 'bolt' },
  { name: 'Structural Drying', description: 'Commercial dehumidifiers and air movers ensure complete moisture removal from walls, floors, and ceilings to prevent mold.', icon: 'home-modern' },
  { name: 'Mold Prevention', description: 'Antimicrobial treatments and thorough drying protocols eliminate the conditions that lead to dangerous mold growth.', icon: 'shield-check' },
  { name: '24/7 Emergency Response', description: 'Water damage doesn\'t wait for business hours. Our certified team is available around the clock, 365 days a year.', icon: 'clock' },
  { name: 'Insurance Coordination', description: 'We work directly with all major insurance carriers, handling documentation and billing so you can focus on recovery.', icon: 'wrench-screwdriver' },
  { name: 'Moisture Testing', description: 'Scientific moisture mapping with thermal imaging and hygrometers ensures no hidden pockets of moisture remain.', icon: 'beaker' },
]

const blogPosts = [
  {
    title: 'How to Handle Water Damage Before Help Arrives',
    href: '/blog/water-damage-first-steps',
    description: 'Quick actions you can take to minimize damage while waiting for professional restoration services.',
    date: 'Jan 15, 2026',
    datetime: '2026-01-15',
    category: 'Emergency Tips',
    author: { name: 'Dr. Mike Reynolds', role: 'Lead Restoration Specialist' },
  },
  {
    title: 'Understanding Your Water Damage Insurance Claim',
    href: '/blog/insurance-claim-guide',
    description: 'A step-by-step guide to filing and maximizing your water damage insurance claim.',
    date: 'Jan 8, 2026',
    datetime: '2026-01-08',
    category: 'Insurance',
    author: { name: 'Sarah Chen', role: 'Claims Coordinator' },
  },
  {
    title: 'Signs of Hidden Water Damage in Your Home',
    href: '/blog/hidden-water-damage-signs',
    description: 'Learn to spot the subtle warning signs of water damage lurking behind your walls.',
    date: 'Dec 20, 2025',
    datetime: '2025-12-20',
    category: 'Prevention',
    author: { name: 'Tom Alvarez', role: 'Senior Inspector' },
  },
]

const faqs = [
  { question: 'How quickly can you respond to a water damage emergency?', answer: 'We guarantee a response within 60 minutes for all emergency calls within our service area. Our teams are stationed strategically across the region and are available 24/7, 365 days a year.' },
  { question: 'Do you work with insurance companies?', answer: 'Yes, we work with all major insurance carriers and can bill them directly. Our team includes certified estimators who document everything thoroughly to ensure your claim is processed smoothly.' },
  { question: 'What areas do you serve?', answer: `We serve ${cityData.name} and surrounding communities including ${cityData.serviceAreas?.slice(0, 5).join(', ') || 'the greater metro area'}. Contact us to confirm coverage in your specific location.` },
  { question: 'How long does the restoration process take?', answer: 'Emergency water extraction typically takes 4-8 hours. Structural drying usually requires 3-5 days with daily monitoring. Full restoration including reconstruction can take 1-4 weeks depending on scope.' },
  { question: 'Can you prevent mold after water damage?', answer: 'Absolutely. Mold prevention is a critical part of our process. If we respond within 24-48 hours of the water event, mold growth can almost always be prevented entirely through antimicrobial treatments and complete structural drying.' },
  { question: 'What should I do while waiting for your team to arrive?', answer: 'Turn off the water source if possible, move valuable items to dry areas, avoid using electrical devices in wet areas, and document the damage with photos for insurance purposes. Do not attempt to use household vacuums on standing water.' },
]
---

<BaseLayout structuredData={structuredData}>
  <!-- HERO — With image tiles -->
  <div class="relative isolate">
    <svg
      aria-hidden="true"
      class="absolute inset-x-0 top-0 -z-10 h-[64rem] w-full mask-[radial-gradient(32rem_32rem_at_center,white,transparent)] stroke-gray-200 dark:stroke-white/10"
    >
      <defs>
        <pattern x="50%" y="-1" id="home-hero-pattern" width="200" height="200" patternUnits="userSpaceOnUse">
          <path d="M.5 200V.5H200" fill="none" />
        </pattern>
      </defs>
      <svg x="50%" y="-1" class="overflow-visible fill-gray-100 dark:fill-gray-800">
        <path d="M-200 0h201v201h-201Z M600 0h201v201h-201Z M-400 600h201v201h-201Z M200 800h201v201h-201Z" stroke-width="0" />
      </svg>
      <rect fill="url(#home-hero-pattern)" width="100%" height="100%" stroke-width="0" />
    </svg>
    <div
      aria-hidden="true"
      class="absolute top-0 right-0 left-1/2 -z-10 -ml-24 transform-gpu overflow-hidden blur-3xl lg:ml-24 xl:ml-48"
    >
      <div
        style="clip-path: polygon(63.1% 29.5%, 100% 17.1%, 76.6% 3%, 48.4% 0%, 44.6% 4.7%, 54.5% 25.3%, 59.8% 49%, 55.2% 57.8%, 44.4% 57.2%, 27.8% 47.9%, 35.1% 81.5%, 0% 97.7%, 39.2% 100%, 35.2% 81.4%, 97.2% 52.8%, 63.1% 29.5%)"
        class="aspect-[801/1036] w-[50.0625rem] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-20 dark:opacity-30"
      ></div>
    </div>
    <div class="overflow-hidden">
      <div class="mx-auto max-w-7xl px-6 pt-36 pb-32 sm:pt-60 lg:px-8 lg:pt-32">
        <div class="mx-auto max-w-2xl gap-x-14 lg:mx-0 lg:flex lg:max-w-none lg:items-center">
          <div class="relative w-full lg:max-w-xl lg:shrink-0 xl:max-w-2xl">
            <h1 class="text-5xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-7xl">
              {cityData.name}'s Trusted Water Damage Experts
            </h1>
            <p class="mt-8 text-lg font-medium text-pretty text-gray-600 dark:text-gray-400 sm:max-w-md sm:text-xl/8 lg:max-w-none">
              When water damage strikes, every minute counts. Our IICRC-certified team responds in under 60 minutes
              with industrial-grade equipment to protect your property and get your life back to normal.
            </p>
            <div class="mt-10 flex items-center gap-x-6">
              <a
                href="/request"
                class="rounded-md bg-indigo-600 dark:bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 dark:hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"
              >
                Get a Free Estimate
              </a>
              <a href={`tel:${cityData.phone.replace(/[^0-9+]/g, '')}`} class="text-sm/6 font-semibold text-gray-900 dark:text-white">
                Call {cityData.phone} <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
          <div class="mt-14 flex justify-end gap-8 sm:-mt-44 sm:justify-start sm:pl-20 lg:mt-0 lg:pl-0">
            <div class="ml-auto w-44 flex-none space-y-8 pt-32 sm:ml-0 sm:pt-80 lg:order-last lg:pt-36 xl:order-0 xl:pt-80">
              <div class="relative">
                <img alt="Water damage restoration team" src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
            </div>
            <div class="mr-auto w-44 flex-none space-y-8 sm:mr-0 sm:pt-52 lg:pt-36">
              <div class="relative">
                <img alt="Restoration equipment" src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
              <div class="relative">
                <img alt="Moisture testing" src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
            </div>
            <div class="w-44 flex-none space-y-8 pt-32 sm:pt-0">
              <div class="relative">
                <img alt="Restored home interior" src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
              <div class="relative">
                <img alt="Professional team" src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?ixlib=rb-4.0.3&auto=format&fit=crop&h=528&q=80" class="aspect-[2/3] w-full rounded-xl bg-gray-200/50 dark:bg-gray-700/5 object-cover shadow-lg" />
                <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-200 dark:ring-white/10 ring-inset" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- LOGO CLOUD -->
  <LogoCloud cityName={cityData.name} />

  <!-- FEATURES — With large screenshot -->
  <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl sm:text-center">
        <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Complete Restoration</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl sm:text-balance">
          Professional Water Damage Restoration
        </p>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
          From emergency water extraction to complete reconstruction, we handle every aspect of the restoration
          process so you don't have to.
        </p>
      </div>
    </div>
    <div class="relative overflow-hidden pt-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <img
          alt="Flood Doctor restoration process"
          src="https://tailwindcss.com/plus-assets/img/component-images/dark-project-app-screenshot.png"
          width="2432"
          height="1442"
          class="mb-[-12%] rounded-xl shadow-2xl ring-1 ring-gray-200 dark:ring-white/10"
        />
        <div aria-hidden="true" class="relative">
          <div class="absolute -inset-x-20 bottom-0 bg-gradient-to-t from-white dark:from-gray-900 pt-[7%]"></div>
        </div>
      </div>
    </div>
    <div class="mx-auto mt-16 max-w-7xl px-6 sm:mt-20 md:mt-24 lg:px-8">
      <dl class="mx-auto grid max-w-2xl grid-cols-1 gap-x-6 gap-y-10 text-base/7 text-gray-600 dark:text-gray-400 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 lg:gap-x-8 lg:gap-y-16">
        {features.map((feature) => (
          <div class="relative pl-9">
            <dt class="inline font-semibold text-gray-900 dark:text-white">
              <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="absolute top-1 left-1 size-5 text-indigo-600 dark:text-indigo-400">
                <circle cx="10" cy="10" r="3" />
              </svg>
              {feature.name}
            </dt>{' '}
            <dd class="inline">{feature.description}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- CONTENT — Split with sticky image -->
  <div class="relative isolate overflow-hidden bg-white dark:bg-gray-900 px-6 py-24 sm:py-32 lg:overflow-visible lg:px-0">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <svg
        aria-hidden="true"
        class="absolute top-0 left-[max(50%,25rem)] h-256 w-512 -translate-x-1/2 mask-[radial-gradient(64rem_64rem_at_top,white,transparent)] stroke-gray-200 dark:stroke-gray-800"
      >
        <defs>
          <pattern
            x="50%"
            y="-1"
            id="home-content-pattern"
            width="200"
            height="200"
            patternUnits="userSpaceOnUse"
          >
            <path d="M100 200V.5M.5 .5H200" fill="none" />
          </pattern>
        </defs>
        <svg x="50%" y="-1" class="overflow-visible fill-gray-100/50 dark:fill-gray-800/50">
          <path
            d="M-100.5 0h201v201h-201Z M699.5 0h201v201h-201Z M499.5 400h201v201h-201Z M-300.5 600h201v201h-201Z"
            stroke-width="0"
          />
        </svg>
        <rect fill="url(#home-content-pattern)" width="100%" height="100%" stroke-width="0" />
      </svg>
    </div>
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-start lg:gap-y-10">
      <div class="lg:col-span-2 lg:col-start-1 lg:row-start-1 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8">
        <div class="lg:pr-4">
          <div class="lg:max-w-lg">
            <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Our Track Record</p>
            <h2 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white sm:text-5xl">
              Trusted by {cityData.name} Homeowners
            </h2>
            <p class="mt-6 text-xl/8 text-gray-600 dark:text-gray-300">
              With over 2,500 restorations completed and a 98.7% customer satisfaction rate, Flood Doctor is
              Northern Virginia's most trusted water damage restoration company.
            </p>
          </div>
        </div>
      </div>
      <div class="-mt-12 -ml-12 p-12 lg:sticky lg:top-4 lg:col-start-2 lg:row-span-2 lg:row-start-1 lg:overflow-hidden">
        <img
          alt="Flood Doctor restoration process dashboard"
          src="https://tailwindcss.com/plus-assets/img/component-images/dark-project-app-screenshot.png"
          class="w-3xl max-w-none rounded-xl bg-gray-200 dark:bg-gray-800 shadow-xl ring-1 ring-gray-200 dark:ring-white/10 sm:w-228"
        />
      </div>
      <div class="lg:col-span-2 lg:col-start-1 lg:row-start-2 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8">
        <div class="lg:pr-4">
          <div class="max-w-xl text-base/7 text-gray-500 dark:text-gray-400 lg:max-w-lg">
            <p>
              Every restoration starts with a thorough assessment. Our IICRC-certified technicians use thermal imaging
              and moisture meters to map the full extent of water damage — even behind walls and under floors. This
              scientific approach ensures nothing gets missed and your property is restored completely.
            </p>
            <ul role="list" class="mt-8 space-y-8 text-gray-500 dark:text-gray-400">
              <li class="flex gap-x-3">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mt-1 size-5 flex-none text-indigo-600 dark:text-indigo-400">
                  <path fill-rule="evenodd" d="M5.5 17a4.5 4.5 0 0 1-1.44-8.765 4.5 4.5 0 0 1 8.302-3.046 3.5 3.5 0 0 1 4.504 4.272A4 4 0 0 1 15 17H5.5Zm3.75-2.75a.75.75 0 0 0 1.5 0V9.66l1.95 2.1a.75.75 0 1 0 1.1-1.02l-3.25-3.5a.75.75 0 0 0-1.1 0l-3.25 3.5a.75.75 0 1 0 1.1 1.02l1.95-2.1v4.59Z" clip-rule="evenodd" />
                </svg>
                <span>
                  <strong class="font-semibold text-gray-900 dark:text-white">60-minute emergency response.</strong> Our teams are
                  stationed across Northern Virginia and arrive fully equipped with industrial extractors, commercial
                  dehumidifiers, and air movers to begin work immediately.
                </span>
              </li>
              <li class="flex gap-x-3">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mt-1 size-5 flex-none text-indigo-600 dark:text-indigo-400">
                  <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 0 0-4.5 4.5V9H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-.5V5.5A4.5 4.5 0 0 0 10 1Zm3 8V5.5a3 3 0 1 0-6 0V9h6Z" clip-rule="evenodd" />
                </svg>
                <span>
                  <strong class="font-semibold text-gray-900 dark:text-white">Direct insurance billing.</strong> We work with all
                  major carriers and handle the entire claims process — documentation, estimates, and billing — so you
                  don't have to fight with your insurance company.
                </span>
              </li>
              <li class="flex gap-x-3">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mt-1 size-5 flex-none text-indigo-600 dark:text-indigo-400">
                  <path d="M4.632 3.533A2 2 0 0 1 6.577 2h6.846a2 2 0 0 1 1.945 1.533l1.976 8.234A3.489 3.489 0 0 0 16 11.5H4c-.476 0-.93.095-1.344.267l1.976-8.234Z" />
                  <path fill-rule="evenodd" d="M4 13a2 2 0 1 0 0 4h12a2 2 0 1 0 0-4H4Zm11.24 2a.75.75 0 0 1 .75-.75H16a.75.75 0 0 1 0 1.5h-.01a.75.75 0 0 1-.75-.75Zm-2.25-.75a.75.75 0 0 0 0 1.5H13a.75.75 0 0 0 0-1.5h-.01Z" clip-rule="evenodd" />
                </svg>
                <span>
                  <strong class="font-semibold text-gray-900 dark:text-white">Complete restoration.</strong> From emergency
                  extraction through structural drying, mold prevention, and full reconstruction — we handle everything
                  so your property is returned to pre-loss condition.
                </span>
              </li>
            </ul>
            <p class="mt-8">
              Our team monitors the drying process daily with scientific instruments, adjusting equipment placement to
              ensure optimal results. Most residential restorations are complete within 3-5 days, with full
              reconstruction finished in 1-4 weeks depending on the scope of damage.
            </p>
            <h3 class="mt-16 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">No hidden costs. No surprises.</h3>
            <p class="mt-6">
              We provide detailed, line-item estimates before any work begins. Our pricing is transparent, insurance-approved,
              and we never charge for emergency assessments. If your insurance doesn't cover it, we'll tell you upfront —
              no surprise bills, no upselling, no pressure.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SERVICES BENTO GRID -->
  <div class="bg-white dark:bg-gray-900 py-24 sm:py-32">
    <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
      <h2 class="text-center text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">Our Services</h2>
      <p class="mx-auto mt-2 max-w-lg text-center text-4xl font-semibold tracking-tight text-balance text-gray-900 dark:text-white sm:text-5xl">
        Complete Water Damage Solutions
      </p>
      <div class="mt-10 grid gap-4 sm:mt-16 lg:grid-cols-3 lg:grid-rows-2">
        <!-- Emergency Response -->
        <div class="relative lg:row-span-2">
          <div class="absolute inset-px rounded-lg bg-gray-50 dark:bg-gray-800 lg:rounded-l-[2rem]" />
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] lg:rounded-l-[calc(2rem+1px)]">
            <div class="px-8 pt-8 pb-3 sm:px-10 sm:pt-10 sm:pb-0">
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-900 dark:text-white max-lg:text-center">Emergency Response</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400 max-lg:text-center">
                60-minute response time, 24/7/365. Our certified technicians arrive with full equipment ready to begin extraction immediately.
              </p>
            </div>
            <div class="@container relative min-h-[30rem] w-full grow max-lg:mx-auto max-lg:max-w-sm">
              <div class="absolute inset-x-10 top-10 bottom-0 overflow-hidden rounded-t-[12cqw] border-x-[3cqw] border-t-[3cqw] border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 outline outline-1 outline-gray-200/20 dark:outline-white/20">
                <img alt="Emergency response" src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="size-full object-cover object-top" />
              </div>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-px rounded-lg shadow-sm outline outline-1 outline-gray-200 dark:outline-white/15 lg:rounded-l-[2rem]" />
        </div>
        <!-- Speed -->
        <div class="relative max-lg:row-start-1">
          <div class="absolute inset-px rounded-lg bg-gray-50 dark:bg-gray-800 max-lg:rounded-t-[2rem]" />
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] max-lg:rounded-t-[calc(2rem+1px)]">
            <div class="px-8 pt-8 sm:px-10 sm:pt-10">
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-900 dark:text-white max-lg:text-center">Structural Drying</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400 max-lg:text-center">
                Commercial-grade dehumidifiers and air movers for complete moisture removal in 3-5 days.
              </p>
            </div>
            <div class="flex flex-1 items-center justify-center px-8 max-lg:pt-10 max-lg:pb-12 sm:px-10 lg:pb-2">
              <img alt="Drying equipment" src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full max-lg:max-w-xs rounded-lg" />
            </div>
          </div>
          <div class="pointer-events-none absolute inset-px rounded-lg shadow-sm outline outline-1 outline-gray-200 dark:outline-white/15 max-lg:rounded-t-[2rem]" />
        </div>
        <!-- Mold Prevention -->
        <div class="relative max-lg:row-start-3 lg:col-start-2 lg:row-start-2">
          <div class="absolute inset-px rounded-lg bg-gray-50 dark:bg-gray-800" />
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)]">
            <div class="px-8 pt-8 sm:px-10 sm:pt-10">
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-900 dark:text-white max-lg:text-center">Mold Remediation</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400 max-lg:text-center">
                Professional mold inspection, containment, and removal to eliminate health hazards.
              </p>
            </div>
            <div class="@container flex flex-1 items-center max-lg:py-6 lg:pb-2">
