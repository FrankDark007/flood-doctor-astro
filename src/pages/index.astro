---
import BaseLayout from '../layouts/BaseLayout.astro'
import BrandLogo from '../components/BrandLogo.astro'
import RestorationBadge from '../components/RestorationBadge.astro'
import ContactForm from '../components/islands/ContactForm.tsx'
import { cityData } from '../data/cities'
import { localBusinessSchema, webSiteSchema } from '../utils/schema'
import { toTelHref } from '../utils/phone'

const cityPhoneHref = toTelHref(cityData.phone)
const structuredData = [localBusinessSchema(), webSiteSchema()]

const cityLabel = cityData.name
const serviceAreaLead = cityData.slug === 'main'
  ? 'Serving Northern Virginia, Washington DC, and nearby Maryland communities by availability.'
  : `Serving ${cityData.name} as part of the Northern Virginia and DC Metro response area.`
const serviceAreaCities = cityData.serviceArea?.slice(0, 12) ?? []

const proofItems = [
  { value: '24/7', label: 'Emergency intake by phone or request form' },
  { value: 'Local', label: 'Northern Virginia / DC Metro service focus' },
  { value: 'Documented', label: 'Photos, notes, and moisture readings when applicable' },
]

const services = [
  {
    title: 'Emergency water extraction',
    body: 'Standing water removal after supply-line leaks, overflows, storm intrusion, and wet basements.',
    detail: 'First move: remove accessible water fast.',
    icon: 'M12 3.5C9.1 7.2 6.5 10.1 6.5 13.3a5.5 5.5 0 0 0 11 0C17.5 10.1 14.9 7.2 12 3.5Z',
  },
  {
    title: 'Moisture inspection',
    body: 'Checks for affected flooring, trim, walls, and cavities before repair decisions are made.',
    detail: 'Find what is wet, not just what looks wet.',
    icon: 'M5 14a7 7 0 1 1 14 0v5H5v-5Zm4 1 3-5 3 5M8 19h8',
  },
  {
    title: 'Drying equipment planning',
    body: 'Air movement and dehumidification support for rooms and assemblies that can be dried in place.',
    detail: 'Controlled drying beats guesswork.',
    icon: 'M4 8h10a2 2 0 1 0-2-2M4 12h14a2 2 0 1 1-2 2M4 16h8',
  },
  {
    title: 'Cleanup and material removal',
    body: 'Practical cleanup for saturated debris, damaged porous materials, and exposed contents.',
    detail: 'Remove what cannot safely remain.',
    icon: 'M6 7h12M9 7V5h6v2m-8 3 1 10h8l1-10',
  },
  {
    title: 'Basement water damage',
    body: 'Help for finished and unfinished basements after seepage, plumbing failures, or appliance leaks.',
    detail: 'Basements need source-aware triage.',
    icon: 'M4 12 12 5l8 7M6.5 10.5V20h11v-9.5M9 20v-5h6v5',
  },
  {
    title: 'Claim documentation support',
    body: 'Job photos, scope notes, affected-area details, and moisture readings organized for claim conversations.',
    detail: 'Clear records reduce confusion later.',
    icon: 'M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm3 5h4M9 12h6M9 16h6',
  },
]

const processSteps = [
  {
    step: '01',
    title: 'Contact the command desk',
    body: 'Call or request service with the address, source of water, affected rooms, and safety concerns.',
  },
  {
    step: '02',
    title: 'Stabilize what is active',
    body: 'When safe, source control and hazard awareness come before cleanup, demolition, or repair decisions.',
  },
  {
    step: '03',
    title: 'Extract, inspect, and map',
    body: 'Accessible water is removed and affected materials are checked so the mitigation scope is grounded in conditions.',
  },
  {
    step: '04',
    title: 'Dry, monitor, document',
    body: 'Drying steps, readings, photos, and owner-facing notes help keep the recovery path understandable.',
  },
]

const reviewChecks = [
  'What caused the water and whether it is still active',
  'Which rooms, floors, walls, trim, and contents were affected',
  'What was extracted, removed, dried, or recommended next',
  'What documentation may help the owner and insurance conversation',
]

const faqs = [
  {
    question: 'What should I do first after a leak or flood?',
    answer: 'If it is safe, stop the water source and stay out of areas with electrical hazards, sagging materials, or contaminated water. Then call so the emergency can be triaged.',
  },
  {
    question: 'Do you serve DC or Maryland?',
    answer: 'Flood Doctor is focused on Northern Virginia and the DC Metro. Availability outside the core area is confirmed by phone before scheduling.',
  },
  {
    question: 'Do you help with insurance documentation?',
    answer: 'Flood Doctor can organize job photos, notes, scope details, and moisture readings that may support your claim conversation.',
  },
]
---

<BaseLayout structuredData={structuredData}>
  <main class="home-page" id="main-content">
    <section class="hero-section" aria-labelledby="home-hero-title">
      <div class="hero-mesh" aria-hidden="true"></div>
      <div class="section-shell hero-grid">
        <div class="hero-copy">
          <BrandLogo cityName={cityLabel} showCity showTagline variant="full" size="lg" tone="dark" class="hero-logo" />
          <div class="alert-pill" aria-label="Emergency water damage service">
            <span class="alert-dot"></span>
            Emergency water damage response intake
          </div>
          <h1 id="home-hero-title">Emergency water damage help, coordinated fast.</h1>
          <p class="hero-lede">
            Flood Doctor helps homeowners and property managers move from leak, flood, or overflow to a clear mitigation
            plan: phone triage, water extraction, drying support, and documentation for the next decision.
          </p>
          <div class="hero-actions" aria-label="Emergency service actions">
            <a class="button button-call" href={cityPhoneHref}>Call {cityData.phone}</a>
            <a class="button button-request" href="/request">Request Service</a>
          </div>
          <p class="service-area-line">{serviceAreaLead}</p>
          <div class="badge-row" aria-label="Service highlights">
            <RestorationBadge kind="emergency" compact />
            <RestorationBadge kind="inspection" compact />
            <RestorationBadge kind="documentation" compact />
          </div>
        </div>

        <div class="hero-visual" aria-label="Flood Doctor emergency command center illustration">
          <div class="visual-stack">
            <div class="dispatch-card dispatch-card-primary">
              <span class="dispatch-label">Live intake path</span>
              <strong>Tell us where the water went.</strong>
              <p>Source, rooms, flooring, safety concerns, and access details are collected before scheduling.</p>
              <div class="dispatch-meter" aria-hidden="true"><span></span></div>
            </div>
            <div class="image-tile process-tile">
              <img src="/graphics/restoration-process.svg" alt="Four step restoration process: call, extract, dry, document" width="960" height="420" />
            </div>
            <div class="command-grid" aria-hidden="true">
              <span>Source</span>
              <span>Extract</span>
              <span>Dry</span>
              <span>Record</span>
            </div>
            <div class="dispatch-card dispatch-card-secondary">
              <span class="dispatch-label">Safety first</span>
              <strong>Stop active water if safe.</strong>
              <p>Avoid electrical hazards, ceiling sag, and questionable water sources.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="proof-section" aria-labelledby="proof-title">
      <div class="section-shell proof-wrap">
        <div>
          <p class="eyebrow">Proof without overclaiming</p>
          <h2 id="proof-title">Calm triage for a high-stress property emergency.</h2>
        </div>
        <dl class="proof-grid">
          {proofItems.map((item) => (
            <div class="proof-item">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <section class="services-section" aria-labelledby="services-title">
      <div class="section-shell">
        <div class="section-heading split-heading">
          <div>
            <p class="eyebrow">Mitigation Services</p>
            <h2 id="services-title">The right response depends on what the water touched.</h2>
          </div>
          <p>
            Flood Doctor focuses on practical water mitigation steps for properties in and around {cityLabel}: remove
            accessible water, identify affected materials, dry what can be dried, and document the job clearly.
          </p>
        </div>
        <div class="bento-grid">
          {services.map((service, index) => (
            <article class:list={['service-card', index === 0 && 'service-card-large']}>
              <div class="service-card-shine" aria-hidden="true"></div>
              <div class="service-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d={service.icon} /></svg>
              </div>
              <p class="service-detail">{service.detail}</p>
              <h3>{service.title}</h3>
              <p>{service.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="process-section" aria-labelledby="process-title">
      <div class="section-shell process-layout">
        <div class="section-heading sticky-heading">
          <p class="eyebrow">Emergency Process</p>
          <h2 id="process-title">A controlled path from first call to next step.</h2>
          <p>
            The homepage avoids unsupported response-time promises. The process is built around what can be collected,
            inspected, stabilized, and documented after water damage.
          </p>
          <div class="process-actions">
            <a class="text-link" href={cityPhoneHref}>Call {cityData.phone}</a>
            <a class="text-link" href="/request">Request service</a>
          </div>
        </div>
        <ol class="process-list" aria-label="Emergency water damage process">
          {processSteps.map((item) => (
            <li class="process-card">
              <span class="process-step">{item.step}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="review-section" aria-labelledby="review-title">
      <div class="section-shell review-grid">
        <div class="review-panel">
          <p class="eyebrow">Review-Ready Records</p>
          <h2 id="review-title">Documentation that makes the recovery easier to review.</h2>
          <p>
            Water losses can become confusing quickly. Flood Doctor can organize the field notes an owner commonly needs
            after mitigation, without inventing claim outcomes or coverage promises.
          </p>
          <div class="support-badges">
            <RestorationBadge kind="documentation" />
            <RestorationBadge kind="insurance-support" />
            <RestorationBadge kind="safety" />
          </div>
        </div>
        <div class="checklist-card" aria-label="Documentation checklist">
          <span class="document-label">Field notes may cover</span>
          <ul>
            {reviewChecks.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="area-section" aria-labelledby="area-title">
      <div class="section-shell area-grid">
        <div>
          <p class="eyebrow">Service Area</p>
          <h2 id="area-title">Northern Virginia, DC Metro, and nearby Maryland by availability.</h2>
          <p>
            {serviceAreaLead} The fastest way to confirm service is to call with the property address, water source,
            and current conditions.
          </p>
          <div class="area-actions">
            <a class="button button-request" href="/request">Request Service</a>
            <a class="button button-outline" href={cityPhoneHref}>Call {cityData.phone}</a>
          </div>
        </div>
        <div class="area-list" aria-label="Representative service area communities">
          {serviceAreaCities.map((city) => <span>{city}</span>)}
        </div>
      </div>
    </section>

    <section class="faq-section" aria-labelledby="faq-title">
      <div class="section-shell faq-grid">
        <div class="section-heading faq-heading">
          <p class="eyebrow">FAQ / What To Expect</p>
          <h2 id="faq-title">Straight answers before the visit.</h2>
        </div>
        <div class="faq-list">
          {faqs.map((item) => (
            <article class="faq-card">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="final-section" aria-labelledby="final-title">
      <div class="section-shell final-grid">
        <div class="final-copy">
          <p class="eyebrow">Request Service</p>
          <h2 id="final-title">Send the details or call if water is active now.</h2>
          <p>
            Use the form for service requests and non-immediate details. If water is actively entering, electrical
            hazards are possible, or you need urgent guidance, call instead.
          </p>
          <div class="hero-actions">
            <a class="button button-call" href={cityPhoneHref}>Call {cityData.phone}</a>
            <a class="button button-outline-light" href="/request">Open request page</a>
          </div>
          <address>
            Flood Doctor<br />
            Service area: {cityLabel}, {cityData.state}
          </address>
        </div>
        <div class="form-wrap" aria-label="Contact form">
          <ContactForm city={cityData.slug} client:load />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(html) {
    overflow-x: hidden;
  }

  .home-page {
    --fd-navy: #07172d;
    --fd-navy-2: #0b1f3a;
    --fd-blue: #1a73e8;
    --fd-blue-2: #5aa7ff;
    --fd-orange: #ea580c;
    --fd-orange-2: #fb923c;
    --fd-ink: #102033;
    --fd-muted: #53647a;
    --fd-slate: #e7edf5;
    --fd-soft: #f4f8fc;
    --fd-line: #d9e6f5;
    --fd-white: #ffffff;
    width: 100%;
    max-width: 100%;
    overflow-x: clip;
    background: var(--fd-white);
    color: var(--fd-ink);
    font-family: 'Avenir Next', 'Trebuchet MS', Verdana, sans-serif;
  }

  .section-shell {
    width: min(1180px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .hero-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 16%, rgba(26, 115, 232, 0.38), transparent 27rem),
      radial-gradient(circle at 18% 82%, rgba(234, 88, 12, 0.22), transparent 24rem),
      linear-gradient(135deg, #061225 0%, #07172d 42%, #102b4f 100%);
    color: white;
    padding: clamp(5.75rem, 10vw, 8rem) 0 clamp(3.5rem, 7vw, 6.5rem);
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      url('/graphics/water-emergency-pattern.svg');
    background-size: 88px 88px, 88px 88px, 460px 460px;
    background-blend-mode: screen, screen, soft-light;
    opacity: 0.18;
  }

  .hero-mesh {
    position: absolute;
    inset: auto -18rem -22rem 44%;
    z-index: -1;
    width: min(54rem, 95vw);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(90, 167, 255, 0.42), rgba(234, 88, 12, 0.14) 44%, transparent 68%);
    filter: blur(4px);
  }

  .hero-grid,
  .review-grid,
  .area-grid,
  .faq-grid,
  .final-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.86fr);
    gap: clamp(2rem, 5vw, 4.75rem);
    align-items: center;
  }

  .hero-copy,
  .section-heading,
  .review-panel,
  .final-copy {
    min-width: 0;
  }

  .hero-logo {
    margin-bottom: clamp(1.6rem, 4vw, 2.75rem);
  }

  .alert-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(251, 146, 60, 0.42);
    border-radius: 999px;
    background: rgba(234, 88, 12, 0.13);
    color: #fed7aa;
    padding: 0.45rem 0.7rem;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .alert-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--fd-orange-2);
    box-shadow: 0 0 0 6px rgba(251, 146, 60, 0.15);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--fd-orange);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 10.8ch;
    margin: 1.35rem 0 0;
    color: white;
    font-size: clamp(3rem, 8.4vw, 6.55rem);
    font-weight: 900;
    letter-spacing: -0.078em;
    line-height: 0.89;
    text-wrap: balance;
  }

  h2 {
    margin: 0;
    color: var(--fd-navy);
    font-size: clamp(2.05rem, 4.7vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.062em;
    line-height: 0.98;
    text-wrap: balance;
  }

  h3 {
    margin: 0;
    color: var(--fd-navy);
    font-size: 1.08rem;
    font-weight: 850;
    letter-spacing: -0.025em;
    line-height: 1.18;
  }

  .hero-lede,
  .section-heading p,
  .review-panel p,
  .area-grid p,
  .final-copy p {
    margin: 1.35rem 0 0;
    max-width: 44rem;
    color: var(--fd-muted);
    font-size: clamp(1rem, 2vw, 1.16rem);
    font-weight: 560;
    line-height: 1.75;
  }

  .hero-lede {
    color: #d9e6f5;
  }

  .service-area-line {
    margin: 1rem 0 0;
    max-width: 38rem;
    color: #a9bdd6;
    font-size: 0.96rem;
    font-weight: 650;
    line-height: 1.55;
  }

  .hero-actions,
  .area-actions,
  .process-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    margin-top: 1.85rem;
    max-width: 100%;
    min-width: 0;
  }

  .button {
    display: inline-flex;
    max-width: 100%;
    min-width: 0;
    min-height: 3.2rem;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.88rem 1.2rem;
    font-size: 0.94rem;
    font-weight: 900;
    line-height: 1.15;
    text-decoration: none;
    transition: transform 170ms ease, box-shadow 170ms ease, background 170ms ease, border-color 170ms ease;
    white-space: normal;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button:focus-visible,
  .text-link:focus-visible {
    outline: 3px solid rgba(90, 167, 255, 0.55);
    outline-offset: 3px;
  }

  .button-call {
    background: var(--fd-orange);
    color: white;
    box-shadow: 0 20px 42px rgba(234, 88, 12, 0.34);
  }

  .button-call:hover {
    background: #c2410c;
  }

  .button-request {
    background: var(--fd-blue);
    color: white;
    box-shadow: 0 18px 38px rgba(26, 115, 232, 0.24);
  }

  .button-request:hover {
    background: #155fc0;
  }

  .button-outline,
  .button-outline-light {
    background: white;
    border-color: rgba(11, 31, 58, 0.14);
    color: var(--fd-navy);
    box-shadow: 0 12px 28px rgba(11, 31, 58, 0.08);
  }

  .button-outline-light {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.24);
    color: white;
    box-shadow: none;
  }

  .badge-row,
  .support-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.35rem;
    max-width: 100%;
  }

  .hero-visual {
    position: relative;
    min-width: 0;
  }

  .visual-stack {
    position: relative;
    display: grid;
    gap: 1rem;
    padding: clamp(0.75rem, 2vw, 1rem);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 2rem;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04));
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(18px);
  }

  .visual-stack::before {
    content: '';
    position: absolute;
    inset: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.45rem;
    pointer-events: none;
  }

  .dispatch-card,
  .image-tile,
  .command-grid {
    position: relative;
    z-index: 1;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 1.35rem;
    background: rgba(7, 23, 45, 0.78);
  }

  .dispatch-card {
    padding: clamp(1rem, 3vw, 1.45rem);
  }

  .dispatch-card strong,
  .dispatch-card span {
    display: block;
  }

  .dispatch-card strong {
    color: white;
    font-size: clamp(1.2rem, 3vw, 1.7rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .dispatch-card p {
    margin: 0.65rem 0 0;
    color: #bcd0e8;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .dispatch-label,
  .document-label {
    margin-bottom: 0.6rem;
    color: #fed7aa;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .dispatch-meter {
    overflow: hidden;
    height: 0.55rem;
    margin-top: 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
  }

  .dispatch-meter span {
    width: 74%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--fd-orange), var(--fd-blue-2));
  }

  .process-tile {
    overflow: hidden;
    background: rgba(255, 255, 255, 0.96);
  }

  .process-tile img {
    display: block;
    width: 100%;
    height: auto;
  }

  .command-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.1);
  }

  .command-grid span {
    display: grid;
    min-height: 4.2rem;
    place-items: center;
    background: rgba(7, 23, 45, 0.86);
    color: #d9e6f5;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dispatch-card-secondary {
    max-width: 82%;
    margin-left: auto;
    border-color: rgba(251, 146, 60, 0.28);
  }

  .proof-section {
    position: relative;
    z-index: 2;
    background: white;
    padding: 0 0 clamp(3.75rem, 7vw, 6rem);
  }

  .proof-wrap {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    margin-top: -2.25rem;
    border: 1px solid var(--fd-line);
    border-radius: 1.65rem;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 26px 70px rgba(11, 31, 58, 0.13);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .proof-wrap h2 {
    font-size: clamp(1.6rem, 3vw, 2.35rem);
    letter-spacing: -0.05em;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin: 0;
  }

  .proof-item {
